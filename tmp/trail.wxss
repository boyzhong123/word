/* ===== 闯关地图：从上到下的关卡轨道 ===== */
.map-trail {
  position: relative;
  width: 692rpx;
  margin: 6rpx auto 0;
  padding-bottom: 30rpx;
}

.trail-stop {
  position: relative;
  width: 692rpx;
  height: 200rpx;
}

.trail-stop-monster {
  height: 220rpx;
}

/* 关卡之间的虚线连线（由 JS 计算长度与角度） */
.trail-connector {
  position: absolute;
  z-index: 1;
  top: 100rpx;
  height: 0;
  border-top: 8rpx dotted #d8e2ec;
  border-radius: 8rpx;
  transform-origin: left center;
}

.trail-connector-completed {
  border-top-color: #7fd79a;
}

.trail-connector-active {
  border-top-color: #9bd2ff;
}

.trail-connector-upcoming {
  border-top-color: #e2e2dc;
}

/* 关卡路牌 */
.trail-sign {
  position: absolute;
  z-index: 3;
  top: 50rpx;
  left: 50%;
  transform: translateX(-50%);
  min-width: 250rpx;
  height: 100rpx;
  padding: 0 34rpx 0 26rpx;
  box-sizing: border-box;
  display: flex;
  align-items: center;
  gap: 14rpx;
  background: linear-gradient(180deg, #ffb84d 0%, #ff9a1f 100%);
  border: 4rpx solid #ffffff;
  border-radius: 22rpx;
  box-shadow: 0 8rpx 0 #e07e12, 0 12rpx 20rpx rgba(224, 126, 18, 0.24);
}

.trail-sign-flag {
  font-size: 38rpx;
  line-height: 1;
}

.trail-sign-copy {
  display: flex;
  align-items: baseline;
  gap: 12rpx;
}

.trail-sign-level {
  color: #ffffff;
  font-size: 34rpx;
  line-height: 1;
  font-weight: 800;
  text-shadow: 0 2rpx 0 rgba(176, 96, 8, 0.4);
}

.trail-sign-words {
  color: #fff6e6;
  font-size: 24rpx;
  line-height: 1;
  font-weight: 700;
}

.trail-sign-locked {
  background: linear-gradient(180deg, #c4c8cc 0%, #a9adb1 100%);
  box-shadow: 0 8rpx 0 #8d9195, 0 12rpx 20rpx rgba(120, 124, 128, 0.22);
}

.trail-sign-completed {
  background: linear-gradient(180deg, #58d27a 0%, #2fb557 100%);
  box-shadow: 0 8rpx 0 #1f9445, 0 12rpx 20rpx rgba(31, 148, 69, 0.24);
}

/* 任务关卡节点 */
.trail-node {
  position: absolute;
  z-index: 3;
  top: 22rpx;
  width: 150rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.trail-node-coin-wrap {
  position: relative;
  width: 150rpx;
  height: 150rpx;
  transition: transform 0.15s ease;
}

.trail-node:active .trail-node-coin-wrap {
  transform: translateY(7rpx) scale(0.97);
}

.trail-node-coin {
  position: absolute;
  top: 0;
  left: 0;
  width: 150rpx;
  height: 150rpx;
}

.trail-node-glyph {
  position: absolute;
  top: 38rpx;
  left: 42rpx;
  width: 66rpx;
  height: 66rpx;
}

.trail-node-lock {
  width: 52rpx;
  height: 52rpx;
  top: 44rpx;
  left: 49rpx;
  opacity: 0.85;
}

.trail-node-label {
  margin-top: 4rpx;
  color: #4a4f55;
  font-size: 22rpx;
  line-height: 30rpx;
  font-weight: 700;
}

.trail-node-label-locked {
  color: #a8acb0;
}

.trail-node-label-upcoming {
  color: #9097a0;
}

.trail-node-current {
  position: absolute;
  top: -28rpx;
  left: 50%;
  transform: translateX(-50%);
  min-width: 70rpx;
  height: 34rpx;
  padding: 0 14rpx;
  box-sizing: border-box;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #0a7aeb;
  font-size: 18rpx;
  line-height: 1;
  font-weight: 800;
  white-space: nowrap;
  background: #ffffff;
  border: 3rpx solid #9ad9ff;
  border-radius: 18rpx;
  box-shadow: 0 5rpx 10rpx rgba(49, 137, 222, 0.18);
  animation: trail-bounce 1.1s ease-in-out infinite;
}

@keyframes trail-bounce {
  0%, 100% {
    transform: translateX(-50%) translateY(0);
  }
  50% {
    transform: translateX(-50%) translateY(-6rpx);
  }
}

/* 小怪兽 BOSS */
.trail-monster {
  position: absolute;
  z-index: 2;
  top: 20rpx;
  width: 166rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.trail-monster-locked {
  opacity: 0.62;
}

.trail-monster-defeated {
  opacity: 0.88;
}

.trail-monster-tag {
  margin-top: -8rpx;
  min-width: 64rpx;
  height: 30rpx;
  padding: 0 14rpx;
  box-sizing: border-box;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #ffffff;
  font-size: 18rpx;
  line-height: 1;
  font-weight: 800;
  letter-spacing: 1rpx;
  background: linear-gradient(180deg, #ff6a6a 0%, #ec4040 100%);
  border-radius: 16rpx;
  box-shadow: 0 4rpx 8rpx rgba(214, 50, 50, 0.26);
}

.trail-monster-tag-locked {
  background: linear-gradient(180deg, #b9bdc1 0%, #9ca0a4 100%);
  box-shadow: none;
}

.trail-monster-tag-defeated {
  background: linear-gradient(180deg, #9bd1a8 0%, #6fbe83 100%);
  box-shadow: none;
}

