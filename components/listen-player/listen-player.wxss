/* 随身听全屏覆盖层（从 pages/listen/listen.wxss 抽出播放器部分）。
   作为 custom-tab-bar 的子组件全屏盖在页面与底栏之上。 */

.listen-page {
  position: fixed;
  inset: 0;
  z-index: 999;
  display: flex;
  flex-direction: column;
  background: linear-gradient(180deg, #dfd8ee 0%, #ddd9f1 22%, #ddddf7 38%, #bdd0fb 56%, #a5c5fe 76%, #8bb6fa 100%);
  overflow: hidden;
  will-change: transform;
}

.listen-page-preenter {
  transform: translateY(100%);
}

.listen-page-enter {
  animation: listen-slide-up 0.32s cubic-bezier(0.22, 1, 0.36, 1) forwards;
}

.listen-page-leaving {
  animation: listen-slide-down 0.3s cubic-bezier(0.4, 0, 0.2, 1) forwards;
}

/* 小程序里 SVG image 在 transform 收起的 fixed 容器中偶发合成层残留。
   关闭时先隐藏播放器内容，只让背景容器执行下滑，避免图标漏到首页。 */
.listen-page-leaving .listen-nav,
.listen-page-leaving .page-dots,
.listen-page-leaving .stage,
.listen-page-leaving .controls {
  visibility: hidden;
}

@keyframes listen-slide-up {
  from {
    transform: translateY(100%);
  }

  to {
    transform: translateY(0);
  }
}

@keyframes listen-slide-down {
  from {
    transform: translateY(0);
  }

  to {
    transform: translateY(100%);
  }
}
.listen-nav-title-wrap {
  position: absolute;
  left: 0;
  right: 0;
  top: 0;
  bottom: 0;
  box-sizing: border-box;
  display: flex;
  align-items: center;
  justify-content: center;
  pointer-events: none;
}

.listen-nav-title-wrap .listen-nav-title {
  margin: 0;
  flex: none;
}

/* ---------------- 随身听导航 ---------------- */
.listen-nav {
  position: relative;
  z-index: 99;
  flex-shrink: 0;
  background: transparent;
}

.listen-nav-bar {
  position: relative;
  display: flex;
  flex-direction: row;
  align-items: center;
}

.listen-nav-back {
  display: flex;
  align-items: center;
  justify-content: center;
  margin-left: 8rpx;
  min-width: 64rpx;
  height: 100%;
  padding: 0 8rpx;
  box-sizing: border-box;
}

.listen-nav-back-icon {
  width: 32rpx;
  height: 32rpx;
}

.listen-nav-title {
  max-width: 52%;
  font-size: 34rpx;
  font-weight: 600;
  line-height: 1.2;
  color: #1e353c;
  text-align: center;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}
/* ---------------- 主体 ---------------- */
.stage {
  flex: 1;
  width: 100%;
}
.cover-page {
  height: 100%;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
}
/* QQ 音乐风格白色圆角卡片（CSS 卡片 + 按素材内容实际边界定位） */
.player-card {
  position: relative;
  width: 620rpx;
  height: 620rpx;
  background: #ffffff;
  border-radius: 56rpx;
  box-shadow: 0 18rpx 40rpx rgba(96, 114, 140, 0.16), 0 4rpx 12rpx rgba(96, 114, 140, 0.08);
  overflow: visible;
}
.turntable {
  position: absolute;
  left: 70rpx;
  top: 70rpx;
  width: 480rpx;
  height: 480rpx;
  z-index: 2;
}
/* 托盘 PNG 内容圆约占画布 55.8%，放大居中后内容圆 ≈ 500rpx */
.disc-tray {
  position: absolute;
  left: -208rpx;
  top: -208rpx;
  width: 896rpx;
  height: 896rpx;
  pointer-events: none;
}
.disc-stack {
  position: absolute;
  left: 0;
  top: 0;
  width: 480rpx;
  height: 480rpx;
  border-radius: 50%;
  overflow: hidden;
}
/* 白胶碟纹理：内容圆约占画布 61%，放大后铺满 480rpx 碟面 */
.disc-texture {
  position: absolute;
  left: -153rpx;
  top: -153rpx;
  width: 787rpx;
  height: 787rpx;
  pointer-events: none;
}
/* 封面只占碟心（约 55%），外圈露出白胶碟；
   显式定位代替百分比 translate（小程序里父级旋转动画下百分比变换易偏移） */
.cover-disc {
  position: absolute;
  left: 108rpx;
  top: 108rpx;
  width: 264rpx;
  height: 264rpx;
  border-radius: 50%;
  box-shadow: 0 0 0 3rpx rgba(150, 170, 195, 0.4);
}
/* 转轴小圆点：固定在碟面正中，不随碟旋转 */
.disc-spindle {
  position: absolute;
  left: 233rpx;
  top: 233rpx;
  width: 14rpx;
  height: 14rpx;
  border-radius: 50%;
  background: #f4f5f7;
  box-shadow: inset 0 1rpx 2rpx rgba(0, 0, 0, 0.18), 0 1rpx 1rpx rgba(255, 255, 255, 0.8);
  z-index: 4;
}
.spinning {
  transform-origin: 240rpx 240rpx;
  animation: spin 16s linear infinite;
}
@keyframes spin {
  from { transform: rotate(0deg); }
  to { transform: rotate(360deg); }
}
/* 碟面径向高光（银白 vinyl 质感） */
.disc-sheen {
  position: absolute;
  inset: 0;
  border-radius: 50%;
  pointer-events: none;
  z-index: 4;
  background:
    radial-gradient(ellipse 78% 52% at 34% 26%, rgba(255, 255, 255, 0.36) 0%, rgba(255, 255, 255, 0) 68%),
    radial-gradient(ellipse 62% 44% at 72% 62%, rgba(255, 255, 255, 0.16) 0%, rgba(255, 255, 255, 0) 64%),
    linear-gradient(145deg, rgba(255, 255, 255, 0.14) 0%, rgba(255, 255, 255, 0) 42%, rgba(255, 255, 255, 0.1) 100%);
  mix-blend-mode: soft-light;
}
/* 唱臂：紧裁素材（轴心在 80%/20% 旋钮中心），容器绕轴旋转；
   停放时向盘外抬起，播放时落到盘内 */
.tonearm {
  position: absolute;
  left: 402rpx;
  top: -71rpx;
  width: 216rpx;
  height: 565rpx;
  z-index: 5;
  pointer-events: none;
  /* 旋钮圆心实测在素材 (77.49%, 19.74%) 处，即 (569, 40)，与轴座底圆同心 */
  transform-origin: 167.4rpx 111.5rpx;
  transform: rotate(-14deg);
  transition: transform 0.9s cubic-bezier(0.34, 0.1, 0.27, 1);
}
.tonearm.tonearm-on-disc {
  transform: rotate(4deg);
}
.tonearm-img {
  display: block;
  width: 100%;
  height: 100%;
}
.cover-hint {
  margin-top: 70rpx;
  font-size: 28rpx;
  color: #5d6e66;
  letter-spacing: 2rpx;
}

.lyrics {
  height: 100%;
  width: 100%;
  box-sizing: border-box;
  padding: 0;
  text-align: left;
}
.lyrics-pad {
  height: 40rpx;
}
.lyric-item {
  transition: all 0.2s;
  text-align: left;
}
/* 单词 / 例句：统一字号 */
.lyric-word {
  padding: 26rpx 0 12rpx;
}
.lyric-sentence {
  padding: 10rpx 0;
}
.lyric-head {
  display: flex;
  align-items: flex-start;
  gap: 12rpx;
  padding: 0 56rpx;
  box-sizing: border-box;
}
.lyric-tag {
  flex: none;
  width: 48rpx;
  height: 48rpx;
  margin-top: 2rpx;
}
.lyric-en {
  flex: 1;
  min-width: 0;
  padding: 0;
  font-size: 36rpx;
  color: #41514a;
  line-height: 1.35;
  font-weight: 400;
}
.lyric-cn {
  margin-top: 6rpx;
  padding: 0 56rpx 0 116rpx;
  font-size: 36rpx;
  color: #51605a;
  line-height: 1.35;
  font-weight: 400;
}
/* 当前播放 / 展开条目高亮 */
.lyric-active .lyric-en,
.lyric-expanded .lyric-en {
  color: #111318;
}
.lyric-active .lyric-cn,
.lyric-expanded .lyric-cn {
  color: #111318;
}

/* ---------------- 跟读测评：展开面板（全屏白色遮罩，黑色图标居中） ---------------- */
/* .lyrics 已无左右内边距，例句/单词的缩进改放在文字上，
   所以面板直接 width:100% 就能铺满整屏，不再依赖 100vw + 负 margin（会被 scroll-view 裁切） */
.follow-panel {
  width: 100%;
  margin: 24rpx 0 0;
  box-sizing: border-box;
  position: relative;
  overflow: visible;
}
.follow-card {
  background: rgba(255, 255, 255, 0.34);
  border-top: 1rpx solid rgba(255, 255, 255, 0.48);
  border-bottom: 1rpx solid rgba(255, 255, 255, 0.48);
  box-shadow: 0 12rpx 30rpx rgba(74, 126, 132, 0.12);
}
.follow-recite-panel {
  padding: 8rpx 0 4rpx;
  overflow: visible;
}
/* media 组件：示范音 / 录音 / 回放打分，三键整体水平居中 */
.follow-media {
  width: 100%;
  box-sizing: border-box;
  justify-content: space-around !important;
  padding: 32rpx 0 28rpx !important;
  min-height: 200rpx;
}
.follow-media .media-action-icon {
  filter: grayscale(1) brightness(0);
}
.follow-media .good .media-action-icon,
.follow-media .bad.media-action-icon {
  filter: none;
}
.follow-media .frames {
  width: 55rpx;
  height: 47rpx;
}
.follow-media .record {
  width: 92rpx;
  max-height: 118rpx;
}
.follow-media .replay {
  width: 80rpx;
  height: 80rpx;
}
.follow-media .recording {
  z-index: 2;
}
.follow-media .recording-wave {
  width: 100%;
  min-width: 480rpx;
  height: 106rpx;
}

/* ---------------- 页码指示点 ---------------- */
.page-dots {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 4rpx 0 12rpx;
}
.page-dot {
  width: 12rpx;
  height: 12rpx;
  border-radius: 12rpx;
  background: rgba(80, 125, 170, 0.3);
  margin: 0 7rpx;
  transition: all 0.25s;
}
.page-dot-active {
  width: 32rpx;
  background: #1e353c;
}

/* ---------------- 控制区 ---------------- */
.controls {
  padding: 0 40rpx;
}
.seek-row {
  display: flex;
  align-items: center;
}
.seek {
  position: relative;
  flex: 1;
  height: 72rpx;
  margin-right: 16rpx;
  display: flex;
  align-items: center;
}
.seek-track {
  width: 100%;
  height: 12rpx;
  border-radius: 12rpx;
  background: rgba(255, 255, 255, 0.85);
  overflow: hidden;
  box-shadow: 0 1rpx 2rpx rgba(40, 60, 55, 0.15) inset;
}
.seek-fill {
  height: 100%;
  border-radius: 12rpx;
  background: linear-gradient(90deg, #1a1a1a, #2d2d2d);
}
.seek-thumb {
  position: absolute;
  top: 50%;
  width: 80rpx;
  height: 80rpx;
  transform: translate(-50%, -100%);
  filter: drop-shadow(0 4rpx 10rpx rgba(30, 53, 60, 0.32));
  pointer-events: none;
}
.speed-badge {
  min-width: 72rpx;
  height: 44rpx;
  padding: 0 14rpx;
  border-radius: 24rpx;
  background: rgba(255, 255, 255, 0.7);
  color: #3f4b45;
  font-size: 24rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}
.time-row {
  display: flex;
  justify-content: space-between;
  margin-top: 2rpx;
  font-size: 22rpx;
  color: rgba(60, 75, 68, 0.7);
}

.buttons {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-top: 40rpx;
  padding: 0 6rpx;
}
.ctrl {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  width: 96rpx;
  height: 96rpx;
}
.ctrl-icon {
  width: 52rpx;
  height: 52rpx;
}

/* 循环 */
.ctrl-loop {
  position: relative;
}
.loop-icon {
  width: 56rpx;
  height: 56rpx;
}
.loop-label {
  position: absolute;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -44%);
  font-size: 20rpx;
  font-weight: 500;
  color: #2f3a35;
}

/* 播放 / 暂停 */
.ctrl-play {
  width: 132rpx;
  height: 132rpx;
}
.play-icon {
  width: 132rpx;
  height: 132rpx;
}

/* ---------------- 期切换面板 ---------------- */
.sheet-mask {
  position: absolute;
  inset: 0;
  z-index: 50;
  background: rgba(0, 0, 0, 0.4);
}
.sheet {
  position: absolute;
  left: 0;
  right: 0;
  bottom: 0;
  max-height: 70%;
  background: #ffffff;
  border-radius: 28rpx 28rpx 0 0;
  transform: translateY(100%);
  transition: transform 0.28s ease;
  display: flex;
  flex-direction: column;
}
.sheet-show .sheet {
  transform: translateY(0);
}
.sheet-head {
  display: flex;
  align-items: baseline;
  justify-content: space-between;
  padding: 34rpx 40rpx 20rpx;
}
.sheet-title {
  font-size: 34rpx;
  font-weight: 700;
  color: #1f2329;
}
.sheet-count {
  font-size: 24rpx;
  color: #9498a3;
}
.sheet-list {
  flex: 1;
  max-height: 640rpx;
}
.sheet-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 28rpx 40rpx;
  border-top: 1rpx solid #f0f1f3;
}
.sheet-item-active {
  background: rgba(17, 19, 24, 0.04);
}
.sheet-item-main {
  display: flex;
  flex-direction: column;
}
.sheet-item-name {
  font-size: 30rpx;
  color: #2b2f36;
}
.sheet-item-active .sheet-item-name {
  color: #111318;
  font-weight: 700;
}
.sheet-item-sub {
  margin-top: 6rpx;
  font-size: 22rpx;
  color: #9498a3;
}
.sheet-vip {
  font-size: 22rpx;
  color: #c79a3a;
  background: #fbf2dc;
  padding: 4rpx 16rpx;
  border-radius: 20rpx;
}
.sheet-playing {
  font-size: 24rpx;
  color: #111318;
}
.sheet-close {
  text-align: center;
  padding: 30rpx 0;
  font-size: 30rpx;
  color: #5a6068;
  border-top: 1rpx solid #f0f1f3;
}

/* ---------------- 加载 ---------------- */
.loading {
  position: absolute;
  inset: 0;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 0 48rpx;
  box-sizing: border-box;
  z-index: 20;
}
.loading-panel {
  min-width: 280rpx;
  max-width: 72%;
  padding: 34rpx 38rpx 31rpx;
  box-sizing: border-box;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  background: rgba(255, 255, 255, 0.62);
  border: 1rpx solid rgba(255, 255, 255, 0.7);
  border-radius: 24rpx;
  box-shadow: 0 14rpx 36rpx rgba(70, 110, 170, 0.18), inset 0 1rpx 0 rgba(255, 255, 255, 0.6);
  backdrop-filter: blur(12rpx);
  animation: loading-pop 0.45s cubic-bezier(0.22, 1, 0.36, 1);
}
.loading-mascot-wrap {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 160rpx;
  height: 160rpx;
  filter: drop-shadow(0 6rpx 11rpx rgba(17, 19, 24, 0.22));
}
.loading-title {
  margin-top: 28rpx;
  width: 100%;
  color: #1e3a4a;
  font-size: 26rpx;
  line-height: 36rpx;
  font-weight: 400;
  letter-spacing: 0.5rpx;
  text-align: center;
  white-space: nowrap;
}
.loading-sub {
  margin-top: 8rpx;
  width: 100%;
  color: rgba(71, 100, 130, 0.62);
  font-size: 20rpx;
  line-height: 28rpx;
  text-align: center;
  white-space: nowrap;
}
@keyframes loading-pop {
  from { opacity: 0; transform: translateY(10rpx) scale(0.94); }
  to { opacity: 1; transform: translateY(0) scale(1); }
}
