<view class="navigation-container" style="{{'height: ' + navigationBarAndStatusBarHeight + '; background:' + background}}">
  <!--空白来占位状态栏-->
  <view style="{{'height: ' + statusBarHeight}}"></view>
  <!--自定义导航栏-->
  <view class="navigation-bar" style="{{'height:' + navigationBarHeight}}">
    <view class="navigation-buttons" style="{{'height:' + menuButtonHeight}}" bindtap="back">
      <image mode="heightFix" class="{{home ? 'nav-home-icon' : 'nav-action-icon'}}" src="../../images/{{home?'icon_home.png':white?'icon_back_white.svg':backIcon}}" />
    </view>
    <view class="navigation-title">
      <slot></slot>
    </view>
  </view>
</view>
