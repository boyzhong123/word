/* navigationBar.wxss */
.navigation-container {
  position: relative;
  width: 100%;
  z-index: 99;
  top: 0;
  left: 0;
  background-color: #ffffff;
}
.navigation-bar {
  position: relative;
  display: flex;
  flex-direction: row;
  align-items: center;
}
.navigation-buttons {
  display: flex;
  align-items: center;
  margin-left: 15rpx;
}
.nav-img {
  height: 32rpx;
  max-width: 20rpx;
  padding: 15rpx;
}
.nav-img-home {
  max-width: 36rpx;
}
