.dialog {
  position: fixed;
  display: flex;
  align-items: center;
  justify-content: center;
  left: 0;
  top: 0;
  right: 0;
  bottom: 0;
  width: 100%;
  height: 100%;
  background: rgba(0, 0, 0, .5);
  z-index: 9999;
}

.dialog-bg {
  width: 640rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-direction: column;
  border-radius: 15rpx;
  position: relative;
  background: white;
  box-shadow: 0 0 20rpx 0 rgba(0, 0, 0, 0.06);
  z-index: 1;
}

.dialog-title {
  word-break: break-all;
  text-align: center;
  margin: 56rpx 10rpx 0;
  padding: 0 10rpx;
  font-size: 32rpx;
  font-family: PingFang SC;
  font-weight: bold;
  color: #343434;
  line-height: 32rpx;
}

.dialog-content {
  word-break: break-all;
  text-align: center;
  margin: 33rpx 10rpx 0;
  padding: 0 10rpx;
  font-size: 32rpx;
  font-family: PingFang SC;
  color: #696969;
  line-height: 48rpx;
}

.dialog-subtitle {
  word-break: break-all;
  text-align: center;
  margin: 16rpx 32rpx 0;
  padding: 0 10rpx;
  font-size: 26rpx;
  font-family: PingFang SC;
  color: #9a9a9a;
  line-height: 40rpx;
}

.dialog-button-container {
  padding: 46rpx 0 56rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-direction: row;
}

.dialog-button {
  width: 240rpx;
  margin: 0;
  box-sizing: border-box;
  font-size: 28rpx;
  font-family: PingFang SC;
  font-weight: 700;
  border-radius: 999rpx;
  text-align: center;
  padding: 16rpx 0;
  line-height: 52rpx;
}

.dialog-button + .dialog-button {
  margin-left: 56rpx;
}

.negetive {
  color: #111318;
  background: #ffffff;
  border: 2rpx solid rgba(17, 19, 24, 0.2);
  box-shadow: none;
}

.positive {
  color: #ffffff;
  background: #111318;
  box-shadow: 0 8rpx 18rpx rgba(17, 19, 24, 0.18);
}

.title-row {
  margin-top: 56rpx;
  position: relative;
  display: flex;
  align-items: center;
  justify-content: center;
  width: 100%;
  flex-direction: row;
}

.dot {
  width: 14rpx;
  height: 14rpx;
  background: #263f45;
  border-radius: 50%;
}

.dot-title {
  padding: 0 10rpx;
  width: 126rpx;
  height: 31rpx;
  font-size: 31rpx;
  font-family: PingFang SC;
  font-weight: bold;
  color: #263f45;
  line-height: 31rpx;
}

.text-bg {
  margin: 22rpx 20rpx 0;
  border-radius: 30rpx;
  background: #F8F8F8;
}

.normal-text {
  font-size: 24rpx;
  font-family: PingFang SC;
  font-weight: 500;
  color: #696969;
  line-height: 40rpx;
}

.img {
  margin-left: 10rpx;
  width: 16rpx;
  height: 22rpx;
}

.go-vip-bg {
  bottom: 60rpx;
  left: 0;
  right: 0;
  display: block;
  margin: 0 auto;
  width: 690rpx;
  position: absolute;
}

.close-img {
  width: 24rpx;
  height: 24rpx;
  padding: 20rpx;
  margin: 26rpx 16rpx 0 auto;
  display: block;
}

.vip-tip{
  margin-top: 36rpx;
  font-size: 32rpx;
  font-family: PingFangSC-Regular, PingFang SC;
  color: #333333;
  word-break: break-all;
  text-align: center;
}

.vip-btn {
  margin: 60rpx 36rpx 48rpx;
  background: #111318;
  height: 100rpx;
  border-radius: 999rpx;
  color: #ffffff;
  font-size: 36rpx;
  font-weight: 700;
  line-height: 100rpx;
  text-align: center;
  box-shadow: 0 8rpx 18rpx rgba(17, 19, 24, 0.18);
}

.slide-bottom {
  animation: slide-bottom 0.4s linear 0s;
  animation-fill-mode: forwards;
}

@keyframes slide-bottom {
  0% {
    bottom: -100%;
  }

  100% {
    bottom: 60rpx;
  }
}
