/**app.wxss**/
.container {
  height: 100%;
  display: flex;
  flex-direction: column;/*主轴垂直 起点在上*/
  box-sizing: border-box;
  background-color: #fbfbfc;
} 
::-webkit-scrollbar {
  width: 0;
  height: 0;
  color: transparent;
}
/* 导航返回/关闭图标：统一 32 方框内等比缩放，避免 heightFix + max-width 把下箭头拉扁 */
.nav-action-icon {
  width: 32rpx;
  height: 32rpx;
}

.nav-title {
  font-size: 40rpx;
  font-family: PingFangSC-Medium, PingFang SC;
  font-weight: bold;
  color: #333333;
  line-height: 56px;
  flex: 1;
  text-align: center;
  margin-right: 84rpx;
}

.stress {
  font-weight: bold;
}

/* 全局按钮：主按钮黑底白字，次按钮半透明白底黑字 */
.app-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  box-sizing: border-box;
  font-family: PingFang SC, PingFangSC-Regular, sans-serif;
  font-weight: 700;
  border-radius: 999rpx;
}

.app-btn-primary {
  color: #ffffff;
  background: #111318;
  box-shadow: 0 8rpx 18rpx rgba(17, 19, 24, 0.18);
}

.app-btn-secondary {
  color: #111318;
  background: rgba(255, 255, 255, 0.55);
  border: 1rpx solid rgba(255, 255, 255, 0.72);
  box-shadow: none;
}

.app-btn-primary:active,
.app-btn-secondary:active {
  opacity: 0.88;
}