/**app.wxss**/
.container {
  height: 100%;
  display: flex;
  flex-direction: column;/*主轴垂直 起点在上*/
  box-sizing: border-box;
  background-color: #fbfbfc;
} 
::-webkit-scrollbar {
  width: 0;
  height: 0;
  color: transparent;
}
/* 导航返回/关闭图标：统一尺寸；返回为左箭头，关闭为下箭头，见 icon_back_deep.svg / icon_close_deep.svg */
.nav-action-icon {
  height: 48rpx;
  width: 48rpx;
}

.nav-title {
  font-size: 40rpx;
  font-family: PingFangSC-Medium, PingFang SC;
  font-weight: bold;
  color: #333333;
  line-height: 56px;
  flex: 1;
  text-align: center;
  margin-right: 84rpx;
}

.stress {
  font-weight: bold;
}