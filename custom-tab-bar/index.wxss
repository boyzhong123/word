.bottom-nav {
  position: fixed;
  z-index: 100;
  left: 0;
  right: 0;
  bottom: 0;
  min-height: 87rpx;
  display: flex;
  align-items: flex-start;
  justify-content: space-around;
  background: rgba(255, 255, 255, 0.98);
  border-radius: 36rpx 36rpx 0 0;
  box-shadow: 0 -5rpx 22rpx rgba(79, 79, 79, 0.045);
}

.bottom-nav-item {
  width: 180rpx;
  padding-top: 8rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  color: #151515;
  font-size: 20rpx;
  line-height: 26rpx;
}

.bottom-nav-icon {
  width: 68rpx;
  height: 68rpx;
}

.bottom-nav-active {
  color: #111318;
}

/* ----------------------------- 迷你播放器 ----------------------------- */
.mini-player {
  --mini-shadow: rgba(31, 45, 61, 0.2);
  position: fixed;
  z-index: 101;
  left: 20rpx;
  right: 20rpx;
  margin-bottom: 16rpx;
  background: #b8c4d0;
  border-radius: 30rpx;
  border: 1rpx solid rgba(255, 255, 255, 0.4);
  box-shadow:
    0 14rpx 40rpx var(--mini-shadow),
    0 4rpx 12rpx rgba(31, 45, 61, 0.08);
  overflow: hidden;
}

.mini-bg {
  position: absolute;
  inset: -32rpx;
  z-index: 0;
  overflow: hidden;
}

.mini-bg-img {
  width: 100%;
  height: 100%;
  transform: scale(1.18);
  filter: blur(20px) saturate(1.6);
}

/* 封面主色层：半透明盖在模糊封面上，既统一色调又透出封面纹理；
   取色失败 miniBg 为空时露出模糊封面兜底 */
.mini-bg-color {
  position: absolute;
  inset: 0;
  opacity: 0.86;
}

/* 左侧暖光：呼应旋转封面位置，让色块有光感不死板 */
.mini-bg-glow {
  position: absolute;
  inset: 0;
  background: radial-gradient(
    120% 160% at 12% 0%,
    rgba(255, 255, 255, 0.32) 0%,
    rgba(255, 255, 255, 0.08) 38%,
    rgba(255, 255, 255, 0) 62%
  );
}

/* 离屏取色 canvas：移出可视区，不占布局 */
.mini-color-canvas {
  position: fixed;
  left: -9999rpx;
  top: -9999rpx;
  width: 2px;
  height: 2px;
}

/* 顶部 1px 高光线 + 底部轻微压暗：模拟玻璃质感 */
.mini-bg-shade {
  position: absolute;
  inset: 0;
  background: linear-gradient(
    180deg,
    rgba(255, 255, 255, 0.18) 0%,
    rgba(255, 255, 255, 0) 22%,
    rgba(0, 0, 0, 0) 60%,
    rgba(0, 0, 0, 0.18) 100%
  );
}

.mini-player-playing {
  animation: mini-glow 2.4s ease-in-out infinite;
}

@keyframes mini-glow {
  0%, 100% {
    box-shadow:
      0 14rpx 40rpx var(--mini-shadow),
      0 4rpx 12rpx rgba(31, 45, 61, 0.08);
  }
  50% {
    box-shadow:
      0 18rpx 52rpx var(--mini-shadow),
      0 4rpx 12rpx rgba(31, 45, 61, 0.08);
  }
}

.mini-progress-track {
  position: relative;
  z-index: 1;
  height: 12rpx;
  background: rgba(0, 0, 0, 0.16);
}

.mini-progress {
  position: relative;
  height: 100%;
  background: linear-gradient(
    180deg,
    #ffffff 0%,
    rgba(255, 255, 255, 0.88) 100%
  );
  border-radius: 0 12rpx 12rpx 0;
  box-shadow: 0 0 12rpx rgba(255, 255, 255, 0.75);
  transition: width 0.2s linear;
}

/* 进度头部圆点：标记当前播放位置 */
.mini-progress::after {
  content: '';
  position: absolute;
  right: -2rpx;
  top: 50%;
  width: 16rpx;
  height: 16rpx;
  transform: translateY(-50%);
  border-radius: 50%;
  background: #ffffff;
  box-shadow: 0 0 10rpx rgba(255, 255, 255, 0.9);
}

.mini-body {
  position: relative;
  z-index: 1;
  display: flex;
  align-items: center;
  padding: 18rpx 20rpx 20rpx;
}

.mini-cover-wrap {
  position: relative;
  width: 76rpx;
  height: 76rpx;
  flex-shrink: 0;
}

.mini-cover {
  width: 76rpx;
  height: 76rpx;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.2);
  border: 3rpx solid rgba(255, 255, 255, 0.6);
  box-sizing: border-box;
  box-shadow: 0 4rpx 14rpx rgba(0, 0, 0, 0.22);
}

.mini-cover-spin {
  animation: mini-spin 8s linear infinite;
}

.mini-cover-ring {
  position: absolute;
  inset: -6rpx;
  border-radius: 50%;
  border: 2rpx solid rgba(255, 255, 255, 0.35);
  animation: mini-ring 2s ease-in-out infinite;
}

@keyframes mini-spin {
  from { transform: rotate(0deg); }
  to { transform: rotate(360deg); }
}

@keyframes mini-ring {
  0%, 100% { transform: scale(1); opacity: 0.55; }
  50% { transform: scale(1.06); opacity: 1; }
}

.mini-info {
  flex: 1;
  min-width: 0;
  margin: 0 18rpx;
  display: flex;
  flex-direction: column;
}

.mini-title {
  font-size: 28rpx;
  font-weight: 700;
  color: #ffffff;
  line-height: 38rpx;
  text-shadow: 0 1rpx 4rpx rgba(0, 0, 0, 0.14);
  overflow: hidden;
  white-space: nowrap;
  text-overflow: ellipsis;
}

.mini-sub-row {
  display: flex;
  align-items: center;
  margin-top: 4rpx;
}

.mini-sub {
  font-size: 20rpx;
  color: rgba(255, 255, 255, 0.82);
  line-height: 28rpx;
  flex-shrink: 0;
}

.mini-eq {
  display: flex;
  align-items: flex-end;
  gap: 4rpx;
  height: 22rpx;
  margin: 0 10rpx;
}

.mini-eq-bar {
  width: 4rpx;
  border-radius: 4rpx;
  background: #ffffff;
  animation: mini-eq 0.9s ease-in-out infinite;
}

.mini-eq-bar:nth-child(1) {
  height: 10rpx;
  animation-delay: 0s;
}

.mini-eq-bar:nth-child(2) {
  height: 18rpx;
  animation-delay: 0.15s;
}

.mini-eq-bar:nth-child(3) {
  height: 12rpx;
  animation-delay: 0.3s;
}

@keyframes mini-eq {
  0%, 100% { transform: scaleY(0.45); }
  50% { transform: scaleY(1); }
}

.mini-status {
  font-size: 20rpx;
  color: rgba(255, 255, 255, 0.72);
  line-height: 28rpx;
  flex-shrink: 0;
}

.mini-btn {
  width: 72rpx;
  height: 72rpx;
  flex-shrink: 0;
  display: flex;
  align-items: center;
  justify-content: center;
}

.mini-btn-icon {
  width: 72rpx;
  height: 72rpx;
}

.mini-close {
  width: 52rpx;
  height: 52rpx;
  flex-shrink: 0;
  margin-left: 6rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.mini-close:active {
  opacity: 0.6;
}

.mini-close-icon {
  width: 28rpx;
  height: 28rpx;
  opacity: 0.92;
}
