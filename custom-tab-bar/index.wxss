.bottom-nav {
  position: fixed;
  z-index: 100;
  left: 0;
  right: 0;
  bottom: 0;
  min-height: 87rpx;
  display: flex;
  align-items: flex-start;
  justify-content: space-around;
  background: rgba(255, 255, 255, 0.98);
  border-radius: 36rpx 36rpx 0 0;
  box-shadow: 0 -5rpx 22rpx rgba(79, 79, 79, 0.045);
}

.bottom-nav-item {
  width: 180rpx;
  padding-top: 12rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  color: #151515;
  font-size: 20rpx;
  line-height: 26rpx;
}

.bottom-nav-item image {
  width: 54rpx;
  height: 50rpx;
}

.bottom-nav-active {
  color: #2f80ed;
}

/* ----------------------------- 迷你播放器 ----------------------------- */
.mini-player {
  position: fixed;
  z-index: 101;
  left: 20rpx;
  right: 20rpx;
  margin-bottom: 16rpx;
  background: #b8c4d0;
  border-radius: 28rpx;
  box-shadow:
    0 12rpx 36rpx rgba(31, 45, 61, 0.16),
    0 4rpx 12rpx rgba(31, 45, 61, 0.1);
  overflow: hidden;
}

.mini-bg {
  position: absolute;
  inset: -32rpx;
  z-index: 0;
  overflow: hidden;
}

.mini-bg-img {
  width: 100%;
  height: 100%;
  transform: scale(1.18);
  filter: blur(18px);
}

.mini-bg-shade {
  position: absolute;
  inset: 0;
  background: linear-gradient(
    135deg,
    rgba(255, 255, 255, 0.1) 0%,
    rgba(0, 0, 0, 0.24) 100%
  );
}

.mini-player-playing {
  animation: mini-glow 2.4s ease-in-out infinite;
}

@keyframes mini-glow {
  0%, 100% {
    box-shadow:
      0 12rpx 36rpx rgba(31, 45, 61, 0.16),
      0 4rpx 12rpx rgba(31, 45, 61, 0.1);
  }
  50% {
    box-shadow:
      0 16rpx 44rpx rgba(31, 45, 61, 0.24),
      0 4rpx 12rpx rgba(31, 45, 61, 0.1);
  }
}

.mini-progress-track {
  position: relative;
  z-index: 1;
  height: 8rpx;
  background: rgba(255, 255, 255, 0.34);
}

.mini-progress {
  height: 100%;
  background: #ffffff;
  border-radius: 0 8rpx 8rpx 0;
  box-shadow: 0 0 8rpx rgba(255, 255, 255, 0.55);
  transition: width 0.2s linear;
}

.mini-body {
  position: relative;
  z-index: 1;
  display: flex;
  align-items: center;
  padding: 18rpx 20rpx 20rpx;
}

.mini-cover-wrap {
  position: relative;
  width: 76rpx;
  height: 76rpx;
  flex-shrink: 0;
}

.mini-cover {
  width: 76rpx;
  height: 76rpx;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.2);
  border: 3rpx solid rgba(255, 255, 255, 0.55);
  box-sizing: border-box;
}

.mini-cover-spin {
  animation: mini-spin 8s linear infinite;
}

.mini-cover-ring {
  position: absolute;
  inset: -6rpx;
  border-radius: 50%;
  border: 2rpx solid rgba(255, 255, 255, 0.35);
  animation: mini-ring 2s ease-in-out infinite;
}

@keyframes mini-spin {
  from { transform: rotate(0deg); }
  to { transform: rotate(360deg); }
}

@keyframes mini-ring {
  0%, 100% { transform: scale(1); opacity: 0.55; }
  50% { transform: scale(1.06); opacity: 1; }
}

.mini-info {
  flex: 1;
  min-width: 0;
  margin: 0 18rpx;
  display: flex;
  flex-direction: column;
}

.mini-title {
  font-size: 28rpx;
  font-weight: 700;
  color: #ffffff;
  line-height: 38rpx;
  overflow: hidden;
  white-space: nowrap;
  text-overflow: ellipsis;
}

.mini-sub-row {
  display: flex;
  align-items: center;
  margin-top: 4rpx;
}

.mini-sub {
  font-size: 20rpx;
  color: rgba(255, 255, 255, 0.82);
  line-height: 28rpx;
  flex-shrink: 0;
}

.mini-eq {
  display: flex;
  align-items: flex-end;
  gap: 4rpx;
  height: 22rpx;
  margin: 0 10rpx;
}

.mini-eq-bar {
  width: 4rpx;
  border-radius: 4rpx;
  background: #ffffff;
  animation: mini-eq 0.9s ease-in-out infinite;
}

.mini-eq-bar:nth-child(1) {
  height: 10rpx;
  animation-delay: 0s;
}

.mini-eq-bar:nth-child(2) {
  height: 18rpx;
  animation-delay: 0.15s;
}

.mini-eq-bar:nth-child(3) {
  height: 12rpx;
  animation-delay: 0.3s;
}

@keyframes mini-eq {
  0%, 100% { transform: scaleY(0.45); }
  50% { transform: scaleY(1); }
}

.mini-status {
  font-size: 20rpx;
  color: rgba(255, 255, 255, 0.72);
  line-height: 28rpx;
  flex-shrink: 0;
}

.mini-btn {
  width: 72rpx;
  height: 72rpx;
  flex-shrink: 0;
  display: flex;
  align-items: center;
  justify-content: center;
}

.mini-btn-icon {
  width: 72rpx;
  height: 72rpx;
  filter: drop-shadow(0 4rpx 10rpx rgba(21, 56, 120, 0.22));
}

.mini-close {
  width: 52rpx;
  height: 52rpx;
  flex-shrink: 0;
  margin-left: 6rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.18);
}

.mini-close:active {
  background: rgba(255, 255, 255, 0.32);
}

.mini-close-icon {
  width: 28rpx;
  height: 28rpx;
  opacity: 0.92;
}
