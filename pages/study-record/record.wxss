page {
  height: 100%;
  background: #fffdf8;
  color: #1a2430;
}

.study-record-page {
  height: 100%;
  overflow: hidden;
  background: linear-gradient(180deg, #e9fff3 0%, #f6fbff 270rpx, #fffdf8 100%);
  font-family: PingFang SC, PingFangSC-Regular, sans-serif;
}

.record-nav-title {
  position: absolute;
  left: 0;
  right: 0;
  top: 0;
  bottom: 0;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #1a2430;
  font-size: 32rpx;
  font-weight: 800;
  pointer-events: none;
}

.record-scroll {
  height: 100%;
  padding: 8rpx 31rpx 0;
  box-sizing: border-box;
}

.range-hero {
  padding: 30rpx;
  border-radius: 40rpx;
  background: #111318;
  color: #ffffff;
  box-shadow: 0 20rpx 38rpx rgba(17, 19, 24, 0.16);
}

.range-meta,
.range-main,
.panel-head,
.month-bar,
.trend-row,
.record-head {
  display: flex;
  align-items: center;
}

.range-meta {
  justify-content: space-between;
  gap: 20rpx;
  color: rgba(255, 255, 255, 0.68);
  font-size: 24rpx;
  line-height: 32rpx;
}

.range-meta-strong {
  color: #9df0bd;
  font-weight: 800;
}

.range-main {
  margin-top: 20rpx;
  justify-content: space-between;
  gap: 24rpx;
}

.range-title {
  color: #ffffff;
  font-size: 40rpx;
  line-height: 52rpx;
  font-weight: 900;
}

.range-minutes {
  flex: none;
  font-size: 64rpx;
  line-height: 66rpx;
  font-weight: 900;
}

.range-minutes text {
  margin-left: 4rpx;
  color: rgba(255, 255, 255, 0.72);
  font-size: 24rpx;
  font-weight: 700;
}

.quick-row {
  margin-top: 24rpx;
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 14rpx;
}

.quick-button {
  height: 62rpx;
  border-radius: 31rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  color: rgba(255, 255, 255, 0.76);
  background: rgba(255, 255, 255, 0.1);
  font-size: 24rpx;
  font-weight: 800;
  line-height: 62rpx;
}

.quick-button::after,
.panel-action::after,
.month-btn::after {
  border: 0;
}

.quick-button-active {
  color: #111318;
  background: #ffffff;
}

.panel {
  margin-top: 26rpx;
  padding: 26rpx;
  border: 1rpx solid rgba(224, 230, 236, 0.96);
  border-radius: 38rpx;
  background: rgba(255, 255, 255, 0.95);
  box-shadow: 0 8rpx 18rpx rgba(47, 96, 150, 0.045);
}

.panel-head {
  min-height: 56rpx;
  justify-content: space-between;
  gap: 20rpx;
  margin-bottom: 21rpx;
}

.panel-title {
  color: #1a2430;
  font-size: 30rpx;
  line-height: 38rpx;
  font-weight: 900;
}

.panel-action,
.panel-pill {
  min-width: 118rpx;
  height: 54rpx;
  padding: 0 20rpx;
  border-radius: 27rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #0f7a42;
  background: #f1fbf3;
  font-size: 24rpx;
  line-height: 54rpx;
  font-weight: 900;
}

.recent-strip,
.summary-grid,
.detail-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 14rpx;
}

.recent-strip {
  grid-template-columns: repeat(7, 1fr);
  gap: 11rpx;
}

.recent-day {
  height: 100rpx;
  border-radius: 30rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  color: #778293;
  background: #f3f6f8;
  font-weight: 900;
}

.recent-week {
  color: #9aa3af;
  font-size: 20rpx;
  line-height: 24rpx;
}

.recent-date {
  margin-top: 4rpx;
  font-size: 30rpx;
  line-height: 34rpx;
}

.recent-minutes {
  height: 18rpx;
  margin-top: 2rpx;
  color: #0f9b4e;
  font-size: 18rpx;
  line-height: 18rpx;
}

.recent-day-range {
  color: #0f7a42;
  background: #dff8ea;
}

.recent-day-edge {
  color: #ffffff;
  background: #111318;
  box-shadow: 0 7rpx 14rpx rgba(17, 19, 24, 0.2);
}

.recent-day-edge .recent-week,
.recent-day-edge .recent-minutes {
  color: rgba(255, 255, 255, 0.72);
}

.recent-day-empty {
  color: #a7afbc;
}

.month-picker {
  margin-top: 24rpx;
  padding-top: 24rpx;
  border-top: 1rpx solid #eef2f6;
}

.month-bar {
  justify-content: space-between;
  margin-bottom: 20rpx;
}

.month-title {
  font-size: 34rpx;
  line-height: 42rpx;
  font-weight: 900;
}

.month-btn {
  width: 58rpx;
  height: 58rpx;
  border-radius: 29rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #1a2430;
  background: #eef6f3;
  font-size: 42rpx;
  line-height: 58rpx;
  font-weight: 900;
}

.weekday-row,
.calendar-grid {
  display: grid;
  grid-template-columns: repeat(7, 1fr);
  gap: 10rpx;
}

.weekday {
  color: #9aa3af;
  font-size: 20rpx;
  line-height: 28rpx;
  text-align: center;
}

.calendar-day {
  height: 76rpx;
  border-radius: 24rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  color: #98a2b3;
  background: #f3f6f8;
  font-weight: 900;
}

.calendar-day-number {
  font-size: 26rpx;
  line-height: 28rpx;
}

.calendar-day-minutes {
  height: 18rpx;
  margin-top: 4rpx;
  color: #0f9b4e;
  font-size: 18rpx;
  line-height: 18rpx;
}

.calendar-day-blank {
  background: transparent;
}

.calendar-day-has {
  color: #0f7a42;
  background: #e8f8ef;
}

.calendar-day-range {
  color: #0f7a42;
  background: #c9f2d8;
}

.calendar-day-edge {
  color: #ffffff;
  background: #111318;
  box-shadow: 0 7rpx 14rpx rgba(17, 19, 24, 0.19);
}

.calendar-day-edge .calendar-day-minutes {
  color: rgba(255, 255, 255, 0.72);
}

.select-tip {
  margin-top: 20rpx;
  padding: 18rpx 20rpx;
  border-radius: 28rpx;
  color: #606b7b;
  background: #f7faf9;
  font-size: 24rpx;
  line-height: 36rpx;
}

.summary-item,
.detail-item {
  min-height: 118rpx;
  padding: 18rpx;
  border-radius: 30rpx;
  box-sizing: border-box;
  background: #f7faf9;
}

.summary-value,
.detail-value {
  color: #111318;
  font-size: 36rpx;
  line-height: 42rpx;
  font-weight: 900;
}

.summary-label,
.detail-label {
  margin-top: 8rpx;
  color: #8a94a6;
  font-size: 20rpx;
  line-height: 28rpx;
}

.trend-list {
  margin-top: 20rpx;
  display: grid;
  gap: 16rpx;
}

.trend-row {
  display: grid;
  grid-template-columns: 86rpx 1fr 82rpx;
  gap: 16rpx;
  color: #606b7b;
  font-size: 22rpx;
  line-height: 28rpx;
}

.trend-track {
  height: 18rpx;
  overflow: hidden;
  border-radius: 18rpx;
  background: #edf1f5;
}

.trend-fill {
  height: 100%;
  border-radius: 18rpx;
  background: #22c55e;
}

.trend-fill-read {
  background: #2f80ed;
}

.trend-fill-quiz {
  background: #ffb020;
}

.trend-fill-recite {
  background: #111318;
}

.trend-value {
  text-align: right;
  font-weight: 800;
}

.record-day {
  margin-top: 18rpx;
  overflow: hidden;
  border-radius: 30rpx;
  background: #f7faf9;
}

.record-day:first-of-type {
  margin-top: 0;
}

.record-head {
  min-height: 108rpx;
  padding: 20rpx;
  gap: 20rpx;
}

.record-date {
  flex: none;
  width: 86rpx;
  height: 86rpx;
  border-radius: 27rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  color: #ffffff;
  background: #111318;
  font-weight: 900;
}

.record-month {
  color: rgba(255, 255, 255, 0.7);
  font-size: 18rpx;
  line-height: 22rpx;
}

.record-day-num {
  font-size: 34rpx;
  line-height: 36rpx;
}

.record-copy {
  flex: 1;
  min-width: 0;
}

.record-title {
  color: #1a2430;
  font-size: 28rpx;
  line-height: 36rpx;
  font-weight: 900;
}

.record-sub {
  margin-top: 6rpx;
  color: #8a94a6;
  font-size: 22rpx;
  line-height: 30rpx;
}

.record-arrow {
  flex: none;
  color: #9aa3af;
  font-size: 42rpx;
  line-height: 42rpx;
  transition: transform 0.16s ease;
}

.record-day-open .record-arrow {
  transform: rotate(90deg);
}

.record-detail {
  padding: 0 20rpx 20rpx;
}

.detail-grid {
  gap: 12rpx;
}

.detail-item {
  min-height: 104rpx;
  padding: 16rpx;
  background: #ffffff;
}

.detail-value {
  font-size: 30rpx;
  line-height: 36rpx;
}

.empty-record {
  padding: 34rpx 20rpx;
  border-radius: 30rpx;
  color: #8a94a6;
  background: #f7faf9;
  text-align: center;
  font-size: 26rpx;
  line-height: 36rpx;
}

.scroll-spacer {
  width: 100%;
}
