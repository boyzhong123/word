page {
  height: 100%;
  background: #fffdf8;
  color: #1a2430;
}

.study-record-page {
  height: 100%;
  overflow: hidden;
  background: linear-gradient(180deg, #e8fbef 0%, #f4fbf6 320rpx, #fbfdfb 100%);
  font-family: PingFang SC, PingFangSC-Regular, sans-serif;
}

.record-nav-title {
  position: absolute;
  left: 0;
  right: 0;
  top: 0;
  bottom: 0;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #1a2430;
  font-size: 32rpx;
  font-weight: 800;
  pointer-events: none;
}

.record-scroll {
  height: 100%;
  padding: 8rpx 31rpx 0;
  box-sizing: border-box;
}

.range-hero {
  padding: 32rpx;
  border-radius: 36rpx;
  background: linear-gradient(150deg, #16361f 0%, #0c2417 100%);
  color: #ffffff;
  box-shadow: 0 18rpx 36rpx rgba(12, 36, 23, 0.22);
}

.range-hero-top {
  display: flex;
  align-items: flex-start;
  gap: 18rpx;
}

.range-hero-copy {
  flex: 1;
  min-width: 0;
}

.range-hero-art {
  flex: none;
  width: 136rpx;
  height: 136rpx;
  padding: 8rpx 10rpx 10rpx;
  border-radius: 32rpx;
  border: 2rpx solid rgba(120, 240, 170, 0.22);
  background: rgba(120, 240, 170, 0.1);
  box-sizing: border-box;
  overflow: visible;
}

.range-hero-mascot {
  width: 100%;
  height: 100%;
  display: block;
}

.range-main,
.panel-head,
.month-bar,
.trend-row,
.record-head {
  display: flex;
  align-items: center;
}

.range-main {
  justify-content: space-between;
  gap: 24rpx;
}

.range-title {
  color: #ffffff;
  font-size: 40rpx;
  line-height: 52rpx;
  font-weight: 900;
}

.range-minutes {
  flex: none;
  font-size: 64rpx;
  line-height: 66rpx;
  font-weight: 900;
}

.range-minutes {
  color: #7af0aa;
}

.range-minutes text {
  margin-left: 4rpx;
  color: rgba(255, 255, 255, 0.7);
  font-size: 24rpx;
  font-weight: 700;
}

.quick-row {
  margin-top: 20rpx;
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 10rpx;
}

.quick-button {
  height: 52rpx;
  border-radius: 26rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  color: rgba(255, 255, 255, 0.76);
  background: rgba(255, 255, 255, 0.1);
  font-size: 22rpx;
  font-weight: 800;
  line-height: 52rpx;
}

.quick-button::after,
.panel-action::after,
.month-btn::after {
  border: 0;
}

.quick-button-active {
  color: #0c2417;
  background: #7af0aa;
}

.panel {
  margin-top: 20rpx;
  padding: 24rpx;
  border: 1rpx solid #e6efe9;
  border-radius: 32rpx;
  background: #ffffff;
  box-shadow: 0 8rpx 20rpx rgba(16, 54, 31, 0.05);
}

.panel-head {
  min-height: 48rpx;
  justify-content: flex-start;
  gap: 16rpx;
  margin-bottom: 16rpx;
}

.panel-title {
  flex: 1;
  min-width: 0;
  color: #1a2430;
  font-size: 28rpx;
  line-height: 36rpx;
  font-weight: 900;
}

.panel-action,
.panel-pill {
  flex: none;
  margin-left: auto;
  min-width: 0;
  height: 44rpx;
  padding: 0 20rpx;
  border-radius: 22rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #0f7a42;
  background: #f1fbf3;
  border: 1rpx solid rgba(15, 122, 66, 0.1);
  font-size: 22rpx;
  line-height: 44rpx;
  font-weight: 900;
}

.recent-range-shell,
.summary-grid,
.detail-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 14rpx;
}

.recent-range-shell {
  display: block;
  padding: 8rpx 6rpx;
  border-radius: 28rpx;
  border: 2rpx solid #e6f4ec;
  background: #f8fcf9;
}

.recent-strip {
  display: grid;
  grid-template-columns: repeat(7, 1fr);
  gap: 0;
}

.recent-day {
  position: relative;
  min-height: 96rpx;
  padding: 4rpx 0;
  box-sizing: border-box;
}

.recent-cell-inner,
.calendar-cell-inner {
  position: relative;
  z-index: 1;
  min-height: 88rpx;
  padding: 2rpx 0;
  border-radius: 18rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  color: #778293;
  background: #f3f6f8;
  font-weight: 800;
  box-sizing: border-box;
}

.recent-week {
  color: #9aa3af;
  font-size: 18rpx;
  line-height: 22rpx;
}

.recent-date {
  margin-top: 2rpx;
  font-size: 24rpx;
  line-height: 28rpx;
}

.recent-minutes {
  min-height: 16rpx;
  margin-top: 2rpx;
  color: #0f9b4e;
  font-size: 16rpx;
  line-height: 16rpx;
}

.recent-day-empty .recent-cell-inner {
  color: #a7afbc;
  background: #f3f6f8;
}

.recent-cell-edge,
.calendar-cell-edge {
  min-height: 88rpx;
  padding: 4rpx 0;
  border-radius: 22rpx;
  color: #ffffff;
  background: #0f9b4e;
  box-shadow: 0 8rpx 16rpx rgba(15, 155, 78, 0.26);
}

.recent-cell-edge .recent-date,
.calendar-cell-edge .calendar-day-number {
  margin-top: 2rpx;
  color: #ffffff;
  font-size: 30rpx;
  line-height: 34rpx;
}

.recent-cell-edge .recent-week,
.calendar-cell-edge .recent-week {
  color: rgba(255, 255, 255, 0.82);
}

.recent-cell-edge .recent-minutes,
.calendar-cell-edge .calendar-day-minutes {
  color: rgba(255, 255, 255, 0.92);
}

.recent-cell-in-range,
.calendar-cell-in-range {
  background: transparent;
  color: #0f7a42;
}

.recent-range-band,
.calendar-range-band {
  position: absolute;
  top: 50%;
  transform: translateY(-50%);
  height: 68rpx;
  background: #d8f3e3;
  box-sizing: border-box;
  z-index: 0;
}

.recent-range-band-full,
.recent-range-band-from-center,
.recent-range-band-to-center,
.calendar-range-band-full,
.calendar-range-band-from-center,
.calendar-range-band-to-center {
  top: 50%;
  transform: translateY(-50%);
}

.recent-range-band-full,
.calendar-range-band-full {
  left: 0;
  right: 0;
}

.recent-range-band-from-center,
.calendar-range-band-from-center {
  left: 50%;
  right: 0;
}

.recent-range-band-to-center,
.calendar-range-band-to-center {
  left: 0;
  right: 50%;
}

.recent-range-band-round-left,
.calendar-range-band-round-left {
  border-top-left-radius: 34rpx;
  border-bottom-left-radius: 34rpx;
}

.recent-range-band-round-right,
.calendar-range-band-round-right {
  border-top-right-radius: 34rpx;
  border-bottom-right-radius: 34rpx;
}

.month-picker {
  padding: 12rpx 6rpx 4rpx;
  border-radius: 24rpx;
  background: #f8fcf9;
  border: 2rpx solid #e6f4ec;
}

.month-bar {
  justify-content: space-between;
  margin-bottom: 14rpx;
}

.month-title {
  flex: 1;
  text-align: center;
  white-space: nowrap;
  font-size: 24rpx;
  line-height: 32rpx;
  font-weight: 800;
}

.month-btn {
  flex: none;
  width: 56rpx;
  min-width: 56rpx;
  height: 44rpx;
  padding: 0;
  border-radius: 14rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #0f7a42;
  background: #eef6f3;
  border: none;
  font-size: 24rpx;
  line-height: 1;
  font-weight: 700;
}

.weekday-row,
.calendar-grid {
  display: grid;
  grid-template-columns: repeat(7, 1fr);
  gap: 0;
}

.weekday {
  color: #9aa3af;
  font-size: 18rpx;
  line-height: 24rpx;
  text-align: center;
  padding-bottom: 6rpx;
}

.calendar-day {
  position: relative;
  min-height: 108rpx;
  padding: 4rpx 0;
  box-sizing: border-box;
}

.calendar-day-number {
  font-size: 22rpx;
  line-height: 24rpx;
}

.calendar-day-minutes {
  min-height: 16rpx;
  margin-top: 2rpx;
  color: #0f9b4e;
  font-size: 16rpx;
  line-height: 16rpx;
}

.calendar-day-label {
  position: absolute;
  top: 8rpx;
  left: 0;
  right: 0;
  text-align: center;
  color: #0f9b4e;
  font-size: 16rpx;
  line-height: 18rpx;
  font-weight: 800;
  z-index: 2;
}

.calendar-day-label-edge {
  color: rgba(255, 255, 255, 0.92);
}

.calendar-day-label-today {
  color: #ef9f27;
}

.calendar-day-today .calendar-day-number,
.recent-day-today .recent-date {
  width: 48rpx;
  height: 48rpx;
  margin-left: auto;
  margin-right: auto;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #0f7a42;
  border: 2rpx solid #0f9b4e;
}

.calendar-day-blank {
  background: transparent;
}

.calendar-day-has .calendar-cell-inner {
  color: #0f7a42;
  background: #e8f8ef;
  border: 1rpx solid #c9f2d8;
}

.select-tip {
  margin-top: 16rpx;
  padding: 14rpx 16rpx;
  border-radius: 22rpx;
  color: #606b7b;
  background: #f7faf9;
  border: 1rpx solid #edf2ef;
  font-size: 22rpx;
  line-height: 32rpx;
}

.summary-item,
.detail-item {
  min-height: 148rpx;
  padding: 16rpx 14rpx 18rpx;
  border-radius: 30rpx;
  box-sizing: border-box;
  background: #f7faf9;
  border: 2rpx solid #edf2ef;
}

.summary-icon-box,
.detail-icon-box,
.trend-icon-box {
  width: 64rpx;
  height: 64rpx;
  margin: 0 auto 10rpx;
  padding: 6rpx;
  border-radius: 20rpx;
  border: 2rpx solid rgba(15, 122, 66, 0.1);
  background: #ffffff;
  box-sizing: border-box;
}

.summary-icon,
.detail-icon,
.trend-icon {
  width: 100%;
  height: 100%;
}

.summary-value,
.detail-value {
  color: #111318;
  font-size: 36rpx;
  line-height: 42rpx;
  font-weight: 900;
  text-align: center;
}

.summary-label,
.detail-label {
  margin-top: 8rpx;
  color: #8a94a6;
  font-size: 20rpx;
  line-height: 28rpx;
  text-align: center;
}

.trend-list {
  margin-top: 20rpx;
  display: grid;
  gap: 16rpx;
}

.trend-row {
  display: grid;
  grid-template-columns: 56rpx 72rpx 1fr 82rpx;
  gap: 12rpx;
  align-items: center;
  padding: 12rpx 14rpx;
  border-radius: 24rpx;
  border: 2rpx solid #edf2ef;
  background: #f7faf9;
  color: #606b7b;
  font-size: 22rpx;
  line-height: 28rpx;
  box-sizing: border-box;
}

.trend-row .trend-icon-box {
  width: 48rpx;
  height: 48rpx;
  margin: 0;
  padding: 6rpx;
  border-radius: 16rpx;
}

.trend-label {
  font-weight: 800;
  color: #1a2430;
}

.trend-track {
  height: 18rpx;
  overflow: hidden;
  border-radius: 18rpx;
  background: #edf1f5;
  border: 1rpx solid rgba(96, 107, 123, 0.12);
}

.trend-fill {
  height: 100%;
  border-radius: 18rpx;
  background: #22c55e;
}

.trend-fill-read {
  background: #2f80ed;
}

.trend-fill-quiz {
  background: #ffb020;
}

.trend-fill-recite {
  background: #14b8a6;
}

.trend-value {
  text-align: right;
  font-weight: 800;
}

.record-day {
  margin-top: 18rpx;
  overflow: hidden;
  border-radius: 30rpx;
  background: #f7faf9;
  border: 2rpx solid #edf2ef;
}

.record-day:first-of-type {
  margin-top: 0;
}

.record-head {
  min-height: 108rpx;
  padding: 20rpx;
  gap: 20rpx;
}

.record-date {
  flex: none;
  width: 86rpx;
  height: 86rpx;
  border-radius: 24rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  color: #ffffff;
  background: linear-gradient(150deg, #16361f 0%, #0c2417 100%);
  border: 2rpx solid rgba(120, 240, 170, 0.2);
  font-weight: 900;
}

.record-month {
  color: rgba(255, 255, 255, 0.7);
  font-size: 18rpx;
  line-height: 22rpx;
}

.record-day-num {
  font-size: 34rpx;
  line-height: 36rpx;
}

.record-copy-box {
  flex: 1;
  min-width: 0;
  padding: 16rpx 18rpx;
  border-radius: 24rpx;
  border: 2rpx solid #e6f0ea;
  background: #ffffff;
}

.record-title {
  color: #1a2430;
  font-size: 28rpx;
  line-height: 36rpx;
  font-weight: 900;
}

.record-sub {
  margin-top: 6rpx;
  color: #8a94a6;
  font-size: 22rpx;
  line-height: 30rpx;
}

.record-arrow {
  flex: none;
  width: 52rpx;
  height: 52rpx;
  border-radius: 26rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #9aa3af;
  background: #ffffff;
  border: 2rpx solid #edf2ef;
  font-size: 34rpx;
  line-height: 34rpx;
  transition: transform 0.16s ease;
}

.record-day-open .record-arrow {
  transform: rotate(90deg);
}

.record-detail {
  padding: 0 20rpx 20rpx;
}

.detail-grid {
  gap: 12rpx;
}

.detail-item {
  min-height: 132rpx;
  padding: 14rpx 12rpx 16rpx;
  background: #ffffff;
}

.detail-value {
  font-size: 30rpx;
  line-height: 36rpx;
}

.empty-record {
  padding: 34rpx 20rpx;
  border-radius: 30rpx;
  color: #8a94a6;
  background: #f7faf9;
  border: 2rpx dashed #dbe4df;
  text-align: center;
  font-size: 26rpx;
  line-height: 36rpx;
}

.scroll-spacer {
  width: 100%;
}
