<view class="study-record-page">
  <navigation background="transparent">
    <view class="record-nav-title">学习记录</view>
  </navigation>

  <scroll-view class="record-scroll" scroll-y enhanced show-scrollbar="{{false}}">
    <view class="range-hero">
      <view class="range-hero-top">
        <view class="range-hero-copy">
          <view class="range-title">这段时间累计学习</view>
          <view class="range-minutes">{{summary.minutes}}<text>分钟</text></view>
        </view>
        <view class="range-hero-art">
          <image class="range-hero-mascot" src="{{heroMascot}}" mode="aspectFit" />
        </view>
      </view>
      <view class="quick-row">
        <button
          class="quick-button {{item.active ? 'quick-button-active' : ''}}"
          data-id="{{item.id}}"
          bindtap="selectPreset"
          wx:for="{{quickRanges}}"
          wx:key="id"
        >{{item.label}}</button>
      </view>
    </view>

    <view class="panel">
      <view class="panel-head">
        <view class="panel-title">选择学习周期</view>
        <view class="panel-action" bindtap="toggleCalendar">{{calendarExpanded ? '收起' : '展开'}}</view>
      </view>

      <view class="recent-range-shell" wx:if="{{!calendarExpanded}}">
        <view class="recent-strip">
          <view
            class="{{item.className}}"
            data-date="{{item.date}}"
            bindtap="selectRecentDate"
            wx:for="{{recentDays}}"
            wx:key="date"
          >
            <view wx:if="{{item.showRangeBand}}" class="{{item.bandClassName}}"></view>
            <view class="{{item.cellClassName}}">
              <view class="recent-week">{{item.topLabel || item.weekday}}</view>
              <view class="recent-date">{{item.day}}</view>
              <view class="recent-minutes">{{item.minutes ? item.minutes + 'm' : ''}}</view>
            </view>
          </view>
        </view>
      </view>

      <view class="month-picker" wx:if="{{calendarExpanded}}">
        <view class="month-bar">
          <view class="month-btn" bindtap="prevMonth">‹</view>
          <view class="month-title">{{monthTitle}}</view>
          <view class="month-btn" bindtap="nextMonth">›</view>
        </view>
        <view class="weekday-row">
          <view class="weekday" wx:for="{{weekdays}}" wx:key="*this">{{item}}</view>
        </view>
        <view class="calendar-grid">
          <view
            class="{{item.className}}"
            data-date="{{item.date}}"
            data-in-month="{{item.inMonth}}"
            bindtap="selectCalendarDate"
            wx:for="{{calendarDays}}"
            wx:key="date"
          >
            <view wx:if="{{item.showRangeBand}}" class="{{item.bandClassName}}"></view>
            <block wx:if="{{item.inMonth}}">
              <view class="{{item.cellClassName}}">
                <view class="calendar-day-label {{item.labelClass}}" wx:if="{{item.topLabel}}">{{item.topLabel}}</view>
                <view class="calendar-day-number">{{item.day}}</view>
                <view class="calendar-day-minutes">{{item.minutes ? item.minutes + 'm' : ''}}</view>
              </view>
            </block>
          </view>
        </view>
      </view>

      <view class="select-tip">{{selectTip}}</view>
    </view>

    <view class="panel">
      <view class="panel-head">
        <view class="panel-title">周期汇总</view>
        <view class="panel-pill">{{rangeTag}}</view>
      </view>
      <view class="summary-grid">
        <view class="summary-item" wx:for="{{summaryItems}}" wx:key="key">
          <view class="summary-icon-box">
            <image class="summary-icon" src="{{item.icon}}" mode="aspectFit" />
          </view>
          <view class="summary-value">{{item.valueText}}</view>
          <view class="summary-label">{{item.label}}</view>
        </view>
      </view>
      <view class="trend-list">
        <view class="trend-row" wx:for="{{trendRows}}" wx:key="label">
          <view class="trend-icon-box">
            <image class="trend-icon" src="{{item.icon}}" mode="aspectFit" />
          </view>
          <view class="trend-label">{{item.label}}</view>
          <view class="trend-track">
            <view class="trend-fill {{item.fillClass}}" style="{{item.fillStyle}}"></view>
          </view>
          <view class="trend-value">{{item.valueText}}</view>
        </view>
      </view>
    </view>

    <view class="panel">
      <view class="panel-head">
        <view class="panel-title">每天记录</view>
        <view class="panel-pill">{{summary.studyDays}}天</view>
      </view>
      <block wx:if="{{hasRangeRecords}}">
        <view
          class="{{item.className}}"
          wx:for="{{rangeRecords}}"
          wx:key="date"
        >
          <view class="record-head" data-date="{{item.date}}" bindtap="toggleRecordDay">
            <view class="record-date">
              <view class="record-month">{{item.monthLabel}}</view>
              <view class="record-day-num">{{item.dayLabel}}</view>
            </view>
            <view class="record-copy-box">
              <view class="record-title">学习 {{item.minutes}} 分钟</view>
              <view class="record-sub">新学 {{item.newWords}} 词 · 随身听 {{item.audioMinutes}} 分钟</view>
            </view>
            <view class="record-arrow">›</view>
          </view>
          <view class="record-detail" wx:if="{{item.expanded}}">
            <view class="detail-grid">
              <view class="detail-item" wx:for="{{item.detailItems}}" wx:for-item="detail" wx:key="key">
                <view class="detail-icon-box">
                  <image class="detail-icon" src="{{detail.icon}}" mode="aspectFit" />
                </view>
                <view class="detail-value">{{detail.valueText}}</view>
                <view class="detail-label">{{detail.label}}</view>
              </view>
            </view>
          </view>
        </view>
      </block>
      <view wx:else class="empty-record">这个周期暂无学习记录</view>
    </view>

    <view class="scroll-spacer" style="height: {{110 + safeAreaBottom}}rpx;"></view>
  </scroll-view>
</view>
