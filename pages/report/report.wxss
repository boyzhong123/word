/* pages/report/report.wxss
   复用首页「今日要学」薄荷绿胶冻视觉：渐变 #e9fff3→#f3fff9→#fff，描边 #aee9c2，
   绿 #0f9b4e/#22c55e，橙 #ff7a1a，黑 #111318，墨 #1a2430，灰 #8a94a6。 */
page {
  height: 100%;
  background: #f4f7fb;
  color: #1a2430;
}

.report-page {
  position: relative;
  height: 100%;
  overflow: hidden;
  display: flex;
  flex-direction: column;
  background: linear-gradient(180deg, #e9fff3 0%, #f3fff9 14%, #f4f7fb 34%, #f4f7fb 100%);
  font-family: PingFang SC, PingFangSC-Regular, sans-serif;
}

.report-nav-title-wrap {
  position: absolute;
  left: 0;
  right: 0;
  top: 0;
  bottom: 0;
  display: flex;
  align-items: center;
  justify-content: center;
  pointer-events: none;
}

.report-nav-title {
  font-size: 32rpx;
  font-weight: 700;
  color: #1a2430;
}

/* ===== 滚动区 ===== */
.report-scroll {
  flex: 1;
  min-height: 0;
  box-sizing: border-box;
  padding: 4rpx 24rpx 0;
}

/* ===== 顶部薄荷绿大框 ===== */
.hero {
  padding: 22rpx 22rpx 18rpx;
  background: linear-gradient(160deg, #e9fff3 0%, #f3fff9 55%, #ffffff 100%);
  border: 2rpx solid #aee9c2;
  border-radius: 30rpx;
  box-shadow: 0 10rpx 24rpx rgba(18, 160, 80, 0.1);
}

.hero-head {
  display: flex;
  align-items: center;
  gap: 8rpx;
  color: #0f9b4e;
  font-size: 25rpx;
  font-weight: 700;
}

.hero-flag {
  flex: none;
  width: 38rpx;
  height: 38rpx;
}

.hero-body {
  position: relative;
  margin-top: 16rpx;
  min-height: 188rpx;
  padding-right: 280rpx;
}

.hero-copy {
  min-width: 0;
}

.hero-title-row {
  display: flex;
  align-items: center;
  gap: 14rpx;
  flex-wrap: wrap;
}

.hero-title {
  font-size: 36rpx;
  line-height: 48rpx;
  font-weight: 800;
  color: #1a2430;
}

.hero-stars {
  display: flex;
  gap: 4rpx;
}

.hero-star {
  width: 34rpx;
  height: 34rpx;
}

.hero-saying {
  margin-top: 10rpx;
}

.hero-saying-en {
  display: block;
  font-size: 24rpx;
  line-height: 34rpx;
  color: #111318;
}

.hero-saying-zh {
  display: block;
  margin-top: 2rpx;
  font-size: 22rpx;
  line-height: 32rpx;
  color: #8a94a6;
}

.hero-mascot {
  position: absolute;
  top: -28rpx;
  right: -16rpx;
  width: 320rpx;
  height: 188rpx;
  pointer-events: none;
}

/* ===== 四个关键指标 ===== */
.metrics {
  margin-top: 18rpx;
  padding: 14rpx 8rpx;
  box-sizing: border-box;
  display: flex;
  align-items: center;
  background: rgba(255, 255, 255, 0.78);
  border: 1rpx solid rgba(196, 238, 209, 0.9);
  border-radius: 20rpx;
}

.metric {
  position: relative;
  flex: 1;
  min-width: 0;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 6rpx;
}

.metric + .metric::before {
  content: "";
  position: absolute;
  left: 0;
  top: 50%;
  transform: translateY(-50%);
  width: 1rpx;
  height: 52rpx;
  background: rgba(174, 233, 194, 0.7);
}

.metric-number {
  font-size: 40rpx;
  line-height: 44rpx;
  font-weight: 800;
  color: #111827;
}

.metric-number text {
  margin-left: 2rpx;
  font-size: 20rpx;
  font-weight: 600;
}

.metric-label {
  font-size: 21rpx;
  line-height: 28rpx;
  color: #8a94a6;
}

.metric-acc .metric-number {
  color: #0f9b4e;
}

.metric-wrong .metric-number {
  color: #ff7a1a;
}

.metric-time .metric-number {
  color: #111318;
}

/* ===== 区块通用 ===== */
.section {
  margin-top: 26rpx;
}

.section-title {
  display: flex;
  align-items: center;
  gap: 12rpx;
  padding: 0 6rpx 14rpx;
}

.section-title-main {
  font-size: 28rpx;
  font-weight: 800;
  color: #1a2430;
}

.section-title-sub {
  flex: 1;
  min-width: 0;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  font-size: 21rpx;
  color: #8a94a6;
}

.section-title-tag {
  flex: none;
  padding: 2rpx 14rpx;
  border-radius: 16rpx;
  font-size: 20rpx;
  font-weight: 700;
  line-height: 30rpx;
}

.tag-ok {
  color: #0f9b4e;
  background: #e8f7ef;
}

.tag-warn {
  color: #e0483b;
  background: #fdeceb;
}

/* ===== 三个环节得分（对齐首页 active task-card 视觉） ===== */
.task-grid {
  height: 108rpx;
  display: flex;
  gap: 16rpx;
}

.task-card {
  position: relative;
  flex: 1;
  min-width: 0;
  height: 108rpx;
  padding: 14rpx 13rpx 13rpx 16rpx;
  box-sizing: border-box;
  display: flex;
  align-items: flex-start;
  color: #1a2430;
  background: #ffffff;
  border: 1rpx solid rgba(237, 239, 242, 0.92);
  border-radius: 20rpx;
  box-shadow: 0 6rpx 14rpx rgba(115, 91, 45, 0.04);
}

.task-card-completed {
  color: #1a2430;
  background: #ffffff;
  border-color: rgba(237, 239, 242, 0.92);
}

.task-icon-wrap {
  flex: none;
  width: 56rpx;
  height: 56rpx;
  margin: 0 10rpx 0 0;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 14rpx;
  box-shadow: 0 4rpx 10rpx rgba(0, 0, 0, 0.06);
}

.task-icon {
  flex: none;
  width: 46rpx;
  height: 46rpx;
}

.task-copy {
  min-width: 0;
  white-space: nowrap;
}

.task-name {
  font-size: 18rpx;
  line-height: 25rpx;
  color: #687078;
}

.task-count {
  margin-top: 2rpx;
  font-size: 22rpx;
  line-height: 28rpx;
  font-weight: 800;
}

.task-track {
  position: absolute;
  left: 16rpx;
  right: 16rpx;
  bottom: 10rpx;
  height: 7rpx;
  overflow: hidden;
  background: #eeeeee;
  border-radius: 6rpx;
}

.task-fill {
  height: 100%;
  border-radius: 6rpx;
}

/* ===== 词表 ===== */
.word-list {
  padding: 4rpx 18rpx;
  background: rgba(255, 255, 255, 0.92);
  border: 1rpx solid rgba(235, 237, 240, 0.9);
  border-radius: 22rpx;
  box-shadow: 0 6rpx 14rpx rgba(115, 91, 45, 0.04);
}

.word-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 18rpx 0;
  border-top: 1rpx solid #f1f4f8;
}

.word-row:first-child {
  border-top: none;
}

.word-main {
  flex: 1;
  min-width: 0;
}

.word-spell-row {
  display: flex;
  align-items: baseline;
  gap: 12rpx;
}

.word-spell {
  font-size: 30rpx;
  font-weight: 700;
  color: #1a2430;
}

.word-phonetic {
  font-size: 21rpx;
  color: #9aa3b0;
}

.word-meaning {
  margin-top: 4rpx;
  font-size: 22rpx;
  color: #6a7686;
}

.word-status {
  flex: none;
  display: flex;
  align-items: center;
  justify-content: center;
}

/* 已掌握：SVG 圆形对勾徽章，避免 CSS 边框对勾发虚 */
.status-ok {
  width: 44rpx;
  height: 44rpx;
}

.status-review {
  padding: 4rpx 14rpx;
  border-radius: 16rpx;
  font-size: 21rpx;
  font-weight: 700;
  color: #e0483b;
  background: #fdeceb;
}

.word-row-review .word-spell {
  color: #c43b2f;
}

.footer-space {
  height: calc(env(safe-area-inset-bottom) + 200rpx);
}

/* ===== 底部操作条 ===== */
.action-bar {
  position: absolute;
  left: 0;
  right: 0;
  bottom: 0;
  display: flex;
  gap: 20rpx;
  padding: 16rpx 28rpx calc(env(safe-area-inset-bottom) + 20rpx);
  background: linear-gradient(180deg, rgba(244, 247, 251, 0) 0%, #f4f7fb 32%);
}

.action-btn {
  flex: 1;
  height: 92rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 999rpx;
  font-size: 28rpx;
  font-weight: 700;
}

.action-btn-primary {
  color: #ffffff;
  background: #111318;
  box-shadow: 0 8rpx 18rpx rgba(17, 19, 24, 0.18);
}

.action-btn-ghost {
  color: #111318;
  background: #dbe4f5;
  box-shadow: 0 4rpx 12rpx rgba(17, 19, 24, 0.06);
}

.action-btn:active {
  opacity: 0.88;
}
