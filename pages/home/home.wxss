page {
  height: 100%;
  background: #fffdf8;
  color: #101010;
}

.home-page {
  position: relative;
  height: 100%;
  overflow: hidden;
  background: #fffdf8;
  font-family: PingFang SC, PingFangSC-Regular, sans-serif;
}

.home-scroll {
  height: 100%;
}

.hero-section {
  position: relative;
  width: 100%;
  /* 不裁切：白卡片底部刻意比 hero-section 多出 20rpx 以盖住下方区域，
     裁切会切掉卡片底边（含边框），背景图已由 .hero-image-clip 单独裁切 */
}

/* 背景图与渐隐裁切到卡片上方（高度随 bookCardTop 动态计算），白卡片不受裁切 */
.hero-image-clip {
  position: absolute;
  z-index: 0;
  top: 0;
  left: 0;
  width: 100%;
  overflow: hidden;
}

.hero-image {
  display: block;
  width: 100%;
  max-width: 100%;
}

.hero-fade {
  position: absolute;
  z-index: 1;
  left: 0;
  bottom: 0;
  width: 100%;
  height: 160rpx;
  background: linear-gradient(180deg, rgba(255, 253, 248, 0) 0%, rgba(255, 253, 248, 0.55) 64%, #fffdf8 100%);
  pointer-events: none;
}

.hero-copy {
  position: absolute;
  z-index: 3;
  left: 40rpx;
  max-width: 430rpx;
}

.hero-title {
  color: #0f3559;
  font-size: 42rpx;
  line-height: 54rpx;
  font-weight: 700;
  letter-spacing: 1rpx;
  -webkit-text-stroke: 1rpx rgba(255, 255, 255, 0.9);
  text-shadow:
    1rpx 0 0 rgba(255, 255, 255, 0.95),
    -1rpx 0 0 rgba(255, 255, 255, 0.95),
    0 1rpx 0 rgba(255, 255, 255, 0.95),
    0 -1rpx 0 rgba(255, 255, 255, 0.95),
    1rpx 1rpx 0 rgba(255, 255, 255, 0.95),
    -1rpx 1rpx 0 rgba(255, 255, 255, 0.95),
    1rpx -1rpx 0 rgba(255, 255, 255, 0.95),
    -1rpx -1rpx 0 rgba(255, 255, 255, 0.95),
    0 2rpx 8rpx rgba(255, 253, 248, 0.85);
}

.hero-name-placeholder {
  color: rgba(15, 53, 89, 0.78);
}

.hero-name-tap {
  text-decoration: none;
}

.hero-name-input {
  display: inline-block;
  width: 220rpx;
  height: 64rpx;
  min-height: 64rpx;
  color: #0f3559;
  font-size: 42rpx;
  line-height: 54rpx;
  font-weight: 700;
  vertical-align: top;
}

.hero-subtitle {
  margin-top: 8rpx;
  color: #17406f;
  font-size: 25rpx;
  line-height: 36rpx;
  font-weight: 600;
  letter-spacing: 0.5rpx;
  text-shadow:
    1rpx 0 0 rgba(255, 255, 255, 0.95),
    -1rpx 0 0 rgba(255, 255, 255, 0.95),
    0 1rpx 0 rgba(255, 255, 255, 0.95),
    0 -1rpx 0 rgba(255, 255, 255, 0.95),
    1rpx 1rpx 1rpx rgba(255, 255, 255, 0.9);
}

.book-card {
  position: absolute;
  z-index: 3;
  left: 29rpx;
  width: 692rpx;
  height: 275rpx;
  padding: 19rpx 25rpx 20rpx 26rpx;
  box-sizing: border-box;
  display: flex;
  background: rgba(255, 255, 255, 0.985);
  border-radius: 29rpx;
  border: 1rpx solid rgba(17, 19, 24, 0.2);
}

.book-cover-column {
  position: relative;
  flex: none;
  width: 154rpx;
  height: 228rpx;
  overflow: hidden;
  border-radius: 12rpx;
  box-shadow: 0 7rpx 8rpx rgba(169, 118, 14, 0.18);
}

.book-cover {
  flex: none;
  width: 154rpx;
  height: 228rpx;
  border-radius: 12rpx;
}

.book-summary {
  flex: 1;
  min-width: 0;
  margin-left: 31rpx;
}

.book-title-row {
  height: 51rpx;
  display: flex;
  align-items: center;
}

.book-title {
  flex: 1;
  min-width: 0;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  font-size: 25rpx;
  line-height: 36rpx;
  font-weight: 700;
  letter-spacing: -1rpx;
}

.switch-book {
  flex: none;
  box-sizing: border-box;
  display: flex;
  align-items: flex-end;
  justify-content: center;
  gap: 5rpx;
  padding: 20rpx 10rpx 11rpx;
  border: none;
  border-radius: 0;
  background: linear-gradient(
    180deg,
    rgba(18, 38, 63, 0) 0%,
    rgba(18, 38, 63, 0.58) 52%,
    rgba(18, 38, 63, 0.78) 100%
  );
  color: #ffffff;
  font-size: 17rpx;
  font-weight: 600;
  line-height: 1;
  letter-spacing: 0.5rpx;
  box-shadow: none;
}

.switch-book-cover {
  position: absolute;
  left: 0;
  right: 0;
  bottom: 0;
}

.switch-book:active {
  background: linear-gradient(
    180deg,
    rgba(18, 38, 63, 0) 0%,
    rgba(18, 38, 63, 0.68) 52%,
    rgba(18, 38, 63, 0.88) 100%
  );
}

.switch-icon {
  flex: none;
  width: 20rpx;
  height: 20rpx;
  opacity: 0.96;
}

.checkin-calendar-button {
  flex: none;
  min-width: 162rpx;
  height: 47rpx;
  padding: 0 15rpx 0 12rpx;
  box-sizing: border-box;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 7rpx;
  color: #25784a;
  font-size: 21rpx;
  line-height: 1;
  font-weight: 600;
  white-space: nowrap;
  background: linear-gradient(180deg, #ffffff 0%, #f0fbf4 100%);
  border: 1rpx solid #b9edc3;
  border-radius: 24rpx;
  box-shadow: 0 0 18rpx rgba(22, 143, 58, 0.22), 0 6rpx 14rpx rgba(22, 143, 58, 0.1);
}

.checkin-calendar-button image {
  flex: none;
  width: 32rpx;
  height: 32rpx;
}

.checkin-calendar-button:active {
  background: #eaf8ee;
}

.book-progress-copy {
  margin-top: 12rpx;
  color: #101010;
  font-size: 22rpx;
  line-height: 28rpx;
}

.book-progress-label {
  color: #101010;
}

.book-progress-track {
  width: 100%;
  height: 10rpx;
  margin-top: 10rpx;
  overflow: hidden;
  background: #eeeeee;
  border-radius: 8rpx;
}

.book-progress-fill {
  height: 100%;
  min-width: 8rpx;
  background: #101010;
  border-radius: 8rpx;
}

.book-metrics {
  margin-top: 18rpx;
  height: 92rpx;
  padding: 6rpx 8rpx;
  box-sizing: border-box;
  display: flex;
  align-items: center;
  overflow: hidden;
  background: rgba(255, 255, 255, 0.72);
  border: 1rpx solid rgba(222, 230, 224, 0.9);
  border-radius: 17rpx;
}

.book-metric {
  position: relative;
  flex: 1;
  min-width: 0;
  height: 100%;
  padding: 0 6rpx;
  box-sizing: border-box;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 4rpx;
  border-radius: 14rpx;
  overflow: hidden;
}

.book-metric + .book-metric::before {
  content: "";
  position: absolute;
  left: 0;
  top: 50%;
  transform: translateY(-50%);
  width: 1rpx;
  height: 46rpx;
  background: rgba(207, 222, 238, 0.78);
}

.book-metric:active {
  background: rgba(234, 244, 255, 0.72);
}

.metric-icon {
  flex: none;
  width: 52rpx;
  height: 52rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 50%;
  background: transparent;
  box-shadow: none;
}

.metric-icon image {
  width: 52rpx;
  height: 52rpx;
}

.metric-copy {
  flex: 1;
  min-width: 0;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 2rpx;
  overflow: hidden;
  text-align: center;
}

.metric-streak {
  color: #111318;
}

.metric-streak .metric-icon {
  background: transparent;
  box-shadow: none;
}

.metric-streak .metric-number {
  color: #111318;
}

.metric-today {
  color: #ff8200;
}

.metric-today .metric-icon {
  background: transparent;
  box-shadow: none;
}

.metric-today .metric-number {
  color: #ff8200;
}

.metric-today-done {
  color: #111318;
}

.metric-today-done .metric-icon {
  background: transparent;
  box-shadow: none;
}

.metric-today-done .metric-number {
  color: #111318;
}

.metric-number {
  width: 100%;
  overflow: hidden;
  text-overflow: ellipsis;
  color: #111827;
  font-size: 24rpx;
  line-height: 28rpx;
  font-weight: 700;
  white-space: nowrap;
  text-align: center;
}

.metric-number text {
  margin-left: 2rpx;
  font-size: 15rpx;
  font-weight: 500;
}

.metric-label {
  width: 100%;
  overflow: hidden;
  text-overflow: ellipsis;
  font-size: 16rpx;
  line-height: 18rpx;
  color: #6b7280;
  white-space: nowrap;
  text-align: center;
}

.learning-section {
  margin-top: 12rpx;
  padding: 0 29rpx;
  background: transparent;
}

.section-heading {
  padding: 20rpx 0;
  min-height: 52rpx;
  box-sizing: border-box;
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.section-heading-title {
  display: flex;
  align-items: center;
  font-size: 30rpx;
  font-weight: 700;
}

.target-icon {
  flex: none;
  width: 42rpx;
  height: 42rpx;
  margin-right: 10rpx;
}

.study-plan {
  min-width: 162rpx;
  height: 47rpx;
  padding: 0 15rpx 0 12rpx;
  box-sizing: border-box;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 7rpx;
  color: #168f3a;
  font-size: 21rpx;
  font-weight: 600;
  background: linear-gradient(180deg, #ffffff 0%, #f0fbf4 100%);
  border: 1rpx solid #b9edc3;
  border-radius: 24rpx;
  box-shadow: 0 0 18rpx rgba(22, 143, 58, 0.22), 0 6rpx 14rpx rgba(22, 143, 58, 0.1);
}

.study-plan:active {
  background: #eaf8ee;
}

.plan-icon {
  flex: none;
  width: 32rpx;
  height: 32rpx;
}

.view-mode-fab {
  position: fixed;
  right: 24rpx;
  bottom: calc(120rpx + env(safe-area-inset-bottom));
  z-index: 90;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  width: 104rpx;
  height: 104rpx;
  border-radius: 50%;
  border: 1rpx solid rgba(255, 255, 255, 0.36);
  transition: transform 0.15s ease, box-shadow 0.15s ease;
}

.view-mode-fab-map {
  background: linear-gradient(180deg, #19cfa7 0%, #0faa8c 100%);
  box-shadow: 0 9rpx 18rpx rgba(15, 166, 138, 0.24);
}

.view-mode-fab-list {
  background: linear-gradient(180deg, #ffc747 0%, #ffa11c 100%);
  box-shadow: 0 9rpx 18rpx rgba(238, 154, 16, 0.24);
}

.view-mode-fab-icon {
  width: 40rpx;
  height: 40rpx;
}

.view-mode-fab-label {
  margin-top: 4rpx;
  color: #fff7dc;
  font-size: 20rpx;
  line-height: 1;
  font-weight: 600;
}

.view-mode-fab:active {
  transform: scale(0.92);
  box-shadow: 0 4rpx 12rpx rgba(83, 89, 71, 0.2);
}

.today-locate-fab {
  position: fixed;
  right: 24rpx;
  bottom: calc(102rpx + 24rpx + env(safe-area-inset-bottom));
  z-index: 90;
  width: 106rpx;
  height: 106rpx;
  background: transparent;
  transition: transform 0.15s ease, opacity 0.15s ease, bottom 0.2s ease;
}

/* 随身听迷你播放器悬浮时，把定位按钮抬高到播放条之上，避免遮挡 */
.today-locate-fab-lifted {
  bottom: calc(258rpx + env(safe-area-inset-bottom));
}

.today-locate-fab-image {
  display: block;
  width: 106rpx;
  height: 106rpx;
}

.today-locate-fab:active {
  transform: scale(0.92);
  opacity: 0.92;
}

.unit-card {
  height: 246rpx;
  margin-top: 14rpx;
  padding: 20rpx 19rpx;
  box-sizing: border-box;
  overflow: hidden;
  color: #3f4852;
  background: #ffffff;
  border: 1rpx solid #dde2e8;
  border-radius: 27rpx;
  box-shadow: 0 6rpx 14rpx rgba(40, 48, 60, 0.06);
}

.unit-card:first-of-type {
  margin-top: 0;
}

.unit-card-review {
  background: #ffffff;
  border-color: #dde2e8;
}

.unit-card-completed,
.unit-card-upcoming {
  color: #3f4852;
  background: #ffffff;
  border-color: #d5dbe3;
  box-shadow: 0 5rpx 12rpx rgba(40, 48, 60, 0.05);
}

.unit-card-active {
  color: #1a2430;
  overflow: visible;
  background: linear-gradient(155deg, #dcffec 0%, #ffffff 46%, #e8f4ff 100%);
  border: 2rpx solid #22c55e;
  box-shadow: 0 12rpx 28rpx rgba(34, 197, 94, 0.2);
}

.unit-card-locked {
  color: #525a63;
  background: #f5f6f8;
  border-color: #ccd2da;
  box-shadow: none;
}

.unit-card-completed .unit-card-monster,
.unit-card-upcoming .unit-card-monster {
  opacity: 0.9;
  filter: saturate(0.82);
}

.unit-card-active .unit-card-monster {
  opacity: 1;
  filter: saturate(1.08);
}

.unit-review-badge {
  flex: none;
  padding: 2rpx 12rpx;
  border-radius: 14rpx;
  background: #ff7a1a;
  color: #fff;
  font-size: 18rpx;
  line-height: 27rpx;
  font-weight: 600;
}

/* 今日要学：一个大框把当天的关卡装在一起。清新薄荷绿，区别于复习卡的橙色 */
.today-group {
  margin-top: 18rpx;
  margin-bottom: 14rpx;
  padding: 18rpx 14rpx 20rpx;
  display: flex;
  flex-direction: column;
  gap: 14rpx;
  background: linear-gradient(160deg, #e9fff3 0%, #f3fff9 55%, #ffffff 100%);
  border: 2rpx solid #aee9c2;
  border-radius: 30rpx;
  box-shadow: 0 10rpx 24rpx rgba(18, 160, 80, 0.1);
}

.today-group .unit-card {
  margin-top: 0;
}

.today-group-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 2rpx 6rpx 0;
}

.today-group-title {
  display: flex;
  align-items: center;
  gap: 8rpx;
  color: #0f9b4e;
  font-size: 25rpx;
  font-weight: 700;
}

.today-group-flag {
  flex: none;
  width: 31rpx;
  height: 31rpx;
}

.today-group-count {
  flex: none;
  padding: 3rpx 14rpx;
  background: rgba(255, 255, 255, 0.78);
  border: 1rpx solid #c4eed1;
  border-radius: 18rpx;
  color: #1aa85a;
  font-size: 20rpx;
  font-weight: 600;
  line-height: 28rpx;
}

.unit-top {
  position: relative;
  z-index: 2;
  height: 104rpx;
  box-sizing: border-box;
  overflow: hidden;
}

.unit-card-active .unit-top {
  overflow: visible;
  /* 高于 .task-grid(z-index:4)，避免 PK 角色的脚被任务卡挡住 */
  z-index: 5;
}

.unit-copy {
  position: relative;
  z-index: 2;
  width: 450rpx;
  text-align: left;
}

.unit-heading-row {
  display: flex;
  align-items: center;
  gap: 10rpx;
}

.unit-title {
  flex: none;
  font-size: 27rpx;
  line-height: 35rpx;
  font-weight: 700;
}

.unit-subtitle-row {
  margin-top: 7rpx;
  display: flex;
  align-items: center;
  gap: 8rpx;
}

.unit-subtitle {
  flex: 0 1 auto;
  min-width: 0;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  font-size: 20rpx;
  line-height: 27rpx;
}

.subtitle-language-toggle {
  flex: none;
  min-width: 42rpx;
  height: 29rpx;
  padding: 0 8rpx;
  box-sizing: border-box;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #9c6a00;
  font-size: 16rpx;
  line-height: 1;
  font-weight: 600;
  background: #fff8df;
  border: 1rpx solid #ffd77a;
  border-radius: 15rpx;
}

.subtitle-language-toggle:active {
  background: #ffefb8;
}

.unit-stage-stars {
  flex: none;
  display: flex;
  gap: 3rpx;
}

.unit-stage-star {
  width: 30rpx;
  height: 30rpx;
}

.unit-report-pill {
  flex: none;
  display: inline-flex;
  align-items: center;
  gap: 5rpx;
  height: 36rpx;
  padding: 0 14rpx 0 9rpx;
  box-sizing: border-box;
  color: #a15b00;
  font-size: 21rpx;
  line-height: 1;
  font-weight: 800;
  background: linear-gradient(135deg, #fff3d0 0%, #ffe6a8 100%);
  border: 1rpx solid #ffd27a;
  border-radius: 22rpx;
}

.unit-report-pill:active {
  background: linear-gradient(135deg, #ffeab8 0%, #ffd98a 100%);
}

.unit-report-icon {
  flex: none;
  width: 28rpx;
  height: 28rpx;
}

.unit-card-monster {
  position: absolute;
  z-index: 1;
  top: -24rpx;
  right: -6rpx;
  width: 166rpx;
  height: 166rpx;
  transform: scale(0.84);
  transform-origin: top right;
  pointer-events: none;
}

.unit-card-monster-fighting {
  top: -30rpx;
  right: -20rpx;
  z-index: 5;
  width: 148rpx;
  height: 84rpx;
  transform: scale(1.78);
  transform-origin: top right;
}

.unit-card-monster-defeated {
  filter: saturate(0.9);
}

.unit-card-monster-locked {
  top: -14rpx;
  opacity: 0.88;
  filter: grayscale(0.08) saturate(0.78);
  transform: scale(0.8);
}

.task-grid {
  position: relative;
  z-index: 4;
  height: 100rpx;
  display: flex;
  gap: 18rpx;
}

.task-card {
  position: relative;
  flex: 1;
  min-width: 0;
  height: 100rpx;
  padding: 15rpx 13rpx 13rpx 18rpx;
  box-sizing: border-box;
  display: flex;
  align-items: flex-start;
  color: #434b55;
  background: #ffffff;
  border: 1rpx solid #d5dbe3;
  border-radius: 20rpx;
}

.task-card-completed,
.task-card-upcoming {
  color: #434b55;
  background: #fafbfc;
  border-color: #cfd6de;
}

.task-card-locked {
  color: #66707a;
  background: #f1f3f5;
  border-color: #c5ccd5;
}

.task-card-active {
  color: #1a2430;
  background: linear-gradient(150deg, #ffffff 0%, #e8fff1 100%);
  border: 2rpx solid #22c55e;
  box-shadow: 0 6rpx 16rpx rgba(34, 197, 94, 0.22);
}

.task-icon-wrap {
  flex: none;
  width: 50rpx;
  height: 50rpx;
  margin: 0 12rpx 0 2rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 14rpx;
}

.task-icon-wrap-active {
  box-shadow: 0 4rpx 10rpx rgba(0, 0, 0, 0.08);
}

.task-icon {
  flex: none;
  width: 46rpx;
  height: 46rpx;
  margin: 2rpx 14rpx 0 2rpx;
}

.task-icon-wrap .task-icon {
  width: 40rpx;
  height: 40rpx;
  margin: 0;
}

.task-lock-icon {
  flex: none;
  width: 32rpx;
  height: 44rpx;
  margin: 3rpx 19rpx 0 4rpx;
  opacity: 0.84;
}

.task-copy {
  min-width: 0;
  white-space: nowrap;
}

.task-name {
  font-size: 18rpx;
  line-height: 25rpx;
  font-weight: 600;
}

.task-count {
  margin-top: 1rpx;
  font-size: 21rpx;
  line-height: 27rpx;
  font-weight: 600;
}

.task-track {
  position: absolute;
  left: 18rpx;
  right: 18rpx;
  bottom: 10rpx;
  height: 7rpx;
  overflow: hidden;
  background: #cfd6de;
  border-radius: 6rpx;
}

.task-fill {
  height: 100%;
  border-radius: 6rpx;
}

.task-card-completed .task-fill {
  opacity: 0.62;
}

.task-card-upcoming .task-fill,
.task-card-locked .task-fill {
  opacity: 0.88;
}

.task-card-active .task-fill {
  opacity: 1;
}

/* ===== 闯关地图：从上到下的关卡轨道 ===== */
.map-trail {
  position: relative;
  width: 692rpx;
  margin: 6rpx auto 0;
  padding-bottom: 30rpx;
}

.trail-stop {
  position: relative;
  width: 692rpx;
  height: 200rpx;
}

.trail-stop-monster {
  height: 220rpx;
}

/* 关卡之间的虚线连线（由 JS 计算长度与角度） */
.trail-connector {
  position: absolute;
  z-index: 1;
  top: 100rpx;
  height: 0;
  border-top: 8rpx dotted #d8e2ec;
  border-radius: 8rpx;
  transform-origin: left center;
}

.trail-connector-completed {
  border-top-color: #7fd79a;
}

.trail-connector-active {
  border-top-color: #e3e5e9;
}

.trail-connector-upcoming {
  border-top-color: #e2e2dc;
}

/* 关卡路牌 */
.trail-sign {
  position: absolute;
  z-index: 3;
  top: 50rpx;
  left: 50%;
  transform: translateX(-50%);
  min-width: 250rpx;
  height: 100rpx;
  padding: 0 34rpx 0 26rpx;
  box-sizing: border-box;
  display: flex;
  align-items: center;
  gap: 14rpx;
  background: linear-gradient(180deg, #ffb84d 0%, #ff9a1f 100%);
  border: 4rpx solid #ffffff;
  border-radius: 22rpx;
  box-shadow: 0 8rpx 0 #e07e12, 0 12rpx 20rpx rgba(224, 126, 18, 0.24);
}

.trail-sign-flag {
  font-size: 38rpx;
  line-height: 1;
}

.trail-sign-copy {
  display: flex;
  align-items: baseline;
  gap: 12rpx;
}

.trail-sign-level {
  color: #ffffff;
  font-size: 34rpx;
  line-height: 1;
  font-weight: 800;
  text-shadow: 0 2rpx 0 rgba(176, 96, 8, 0.4);
}

.trail-sign-words {
  color: #fff6e6;
  font-size: 24rpx;
  line-height: 1;
  font-weight: 600;
}

.trail-sign-locked {
  background: linear-gradient(180deg, #c4c8cc 0%, #a9adb1 100%);
  box-shadow: 0 8rpx 0 #8d9195, 0 12rpx 20rpx rgba(120, 124, 128, 0.22);
}

.trail-sign-completed {
  background: linear-gradient(180deg, #58d27a 0%, #2fb557 100%);
  box-shadow: 0 8rpx 0 #1f9445, 0 12rpx 20rpx rgba(31, 148, 69, 0.24);
}

/* 任务关卡节点 */
.trail-node {
  position: absolute;
  z-index: 3;
  top: 22rpx;
  width: 150rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.trail-node-coin-wrap {
  position: relative;
  width: 150rpx;
  height: 150rpx;
  transition: transform 0.15s ease;
}

.trail-node:active .trail-node-coin-wrap {
  transform: translateY(7rpx) scale(0.97);
}

.trail-node-coin {
  position: absolute;
  top: 0;
  left: 0;
  width: 150rpx;
  height: 150rpx;
}

.trail-node-glyph {
  position: absolute;
  top: 38rpx;
  left: 42rpx;
  width: 66rpx;
  height: 66rpx;
}

.trail-node-lock {
  width: 52rpx;
  height: 52rpx;
  top: 44rpx;
  left: 49rpx;
  opacity: 0.85;
}

.trail-node-label {
  margin-top: 4rpx;
  color: #4a4f55;
  font-size: 22rpx;
  line-height: 30rpx;
  font-weight: 600;
}

.trail-node-label-locked {
  color: #a8acb0;
}

.trail-node-label-upcoming {
  color: #9097a0;
}

.trail-node-current {
  position: absolute;
  top: -28rpx;
  left: 50%;
  transform: translateX(-50%);
  min-width: 70rpx;
  height: 34rpx;
  padding: 0 14rpx;
  box-sizing: border-box;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #111318;
  font-size: 18rpx;
  line-height: 1;
  font-weight: 600;
  white-space: nowrap;
  background: #ffffff;
  border: 3rpx solid #e3e5e9;
  border-radius: 18rpx;
  box-shadow: 0 5rpx 10rpx rgba(17, 19, 24, 0.12);
  animation: trail-bounce 1.1s ease-in-out infinite;
}

@keyframes trail-bounce {
  0%, 100% {
    transform: translateX(-50%) translateY(0);
  }
  50% {
    transform: translateX(-50%) translateY(-6rpx);
  }
}

/* 小怪兽 BOSS */
.trail-monster {
  position: absolute;
  z-index: 2;
  top: 20rpx;
  width: 166rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.trail-monster-locked {
  opacity: 0.62;
}

.trail-monster-defeated {
  opacity: 0.88;
}

.trail-monster-tag {
  margin-top: -8rpx;
  min-width: 64rpx;
  height: 30rpx;
  padding: 0 14rpx;
  box-sizing: border-box;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #ffffff;
  font-size: 18rpx;
  line-height: 1;
  font-weight: 600;
  letter-spacing: 1rpx;
  background: linear-gradient(180deg, #ff6a6a 0%, #ec4040 100%);
  border-radius: 16rpx;
  box-shadow: 0 4rpx 8rpx rgba(214, 50, 50, 0.26);
}

.trail-monster-tag-locked {
  background: linear-gradient(180deg, #b9bdc1 0%, #9ca0a4 100%);
  box-shadow: none;
}

.trail-monster-tag-defeated {
  background: linear-gradient(180deg, #9bd1a8 0%, #6fbe83 100%);
  box-shadow: none;
}


.scroll-spacer {
  flex: none;
}

/* 加载骨架屏 */
.sk-block,
.sk-line {
  background-color: #e9ebee;
  background-image: linear-gradient(90deg, rgba(255, 255, 255, 0) 0, rgba(255, 255, 255, 0.65) 50%, rgba(255, 255, 255, 0) 100%);
  background-size: 300rpx 100%;
  background-repeat: no-repeat;
  background-position: -300rpx 0;
  border: none;
  box-shadow: none;
  animation: sk-shimmer 1.4s ease-in-out infinite;
}

.sk-line {
  height: 24rpx;
  border-radius: 8rpx;
}

@keyframes sk-shimmer {
  0% {
    background-position: -300rpx 0;
  }
  100% {
    background-position: 750rpx 0;
  }
}

/* 切换教材弹窗 */
.book-picker-mask {
  position: fixed;
  left: 0;
  right: 0;
  top: 0;
  bottom: 0;
  z-index: 200;
  background: rgba(16, 24, 40, 0.52);
  display: flex;
  align-items: flex-end;
  justify-content: center;
  backdrop-filter: blur(2px);
}

.book-picker {
  width: 100%;
  max-height: 78vh;
  background: linear-gradient(180deg, #fffdf8 0%, #ffffff 18%, #ffffff 100%);
  border-radius: 36rpx 36rpx 0 0;
  overflow: hidden;
  padding-bottom: env(safe-area-inset-bottom);
  box-shadow: 0 -16rpx 48rpx rgba(23, 64, 111, 0.14);
  animation: book-picker-slide-up 0.28s cubic-bezier(0.22, 1, 0.36, 1);
}

@keyframes book-picker-slide-up {
  0% {
    transform: translateY(100%);
    opacity: 0.92;
  }
  100% {
    transform: translateY(0);
    opacity: 1;
  }
}

.book-picker-handle {
  width: 72rpx;
  height: 8rpx;
  margin: 16rpx auto 0;
  border-radius: 999rpx;
  background: rgba(23, 64, 111, 0.12);
}

.book-picker-header {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 20rpx;
  padding: 24rpx 32rpx 20rpx;
}

.book-picker-head-copy {
  flex: 1;
  min-width: 0;
}

.book-picker-head-row {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.book-picker-title {
  font-size: 34rpx;
  line-height: 48rpx;
  font-weight: 700;
  color: #17406f;
  letter-spacing: 0.5rpx;
}

.book-picker-subtitle {
  display: block;
  margin-top: 6rpx;
  font-size: 22rpx;
  line-height: 32rpx;
  color: #7a8798;
}

.book-picker-close {
  flex: none;
  width: 56rpx;
  height: 56rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 50%;
  background: rgba(23, 64, 111, 0.06);
}

.book-picker-close:active {
  background: rgba(23, 64, 111, 0.12);
}

.book-picker-close-icon {
  width: 28rpx;
  height: 28rpx;
}

/* 学段切换：整个 tab 可点，底部分割线与左栏衔接 */
.book-picker-stages {
  display: flex;
  align-items: center;
  justify-content: space-around;
  padding: 0 48rpx 16rpx;
  border-bottom: 2rpx solid rgba(17, 19, 24, 0.08);
}

.book-picker-stage {
  position: relative;
  padding: 12rpx 24rpx 20rpx;
}

.book-picker-stage-name {
  font-size: 30rpx;
  line-height: 42rpx;
  color: #5d6470;
}

.book-picker-stage-active .book-picker-stage-name {
  color: #111318;
  font-weight: 700;
}

.book-picker-stage-active::after {
  content: '';
  position: absolute;
  left: 50%;
  bottom: 6rpx;
  transform: translateX(-50%);
  width: 48rpx;
  height: 8rpx;
  border-radius: 999rpx;
  background: linear-gradient(90deg, #ffa11c 0%, #ff8200 100%);
}

.book-picker-body {
  display: flex;
  align-items: stretch;
  height: calc(78vh - 240rpx);
}

/* 左侧版本分类栏：整行可点 */
.book-picker-side {
  flex: none;
  width: 200rpx;
  height: 100%;
  background: #f4f5f7;
}

.book-picker-side-item {
  position: relative;
  display: flex;
  align-items: center;
  min-height: 96rpx;
  padding: 16rpx 12rpx 16rpx 24rpx;
  box-sizing: border-box;
}

.book-picker-side-item:active {
  background: rgba(17, 19, 24, 0.04);
}

.book-picker-side-name {
  font-size: 26rpx;
  line-height: 36rpx;
  color: #5d6470;
}

.book-picker-side-item-active {
  background: #ffffff;
}

.book-picker-side-item-active .book-picker-side-name {
  color: #111318;
  font-weight: 700;
}

.book-picker-side-item-active::before {
  content: '';
  position: absolute;
  left: 0;
  top: 50%;
  transform: translateY(-50%);
  width: 8rpx;
  height: 40rpx;
  border-radius: 0 999rpx 999rpx 0;
  background: linear-gradient(180deg, #ffa11c 0%, #ff8200 100%);
}

/* 右侧封面网格 */
.book-picker-list {
  flex: 1;
  min-width: 0;
  height: 100%;
}

.book-picker-empty {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 10rpx;
  padding: 120rpx 32rpx;
}

.book-picker-empty-title {
  font-size: 26rpx;
  line-height: 38rpx;
  font-weight: 600;
  color: #5d6470;
}

.book-picker-empty-tip {
  font-size: 22rpx;
  line-height: 32rpx;
  color: #9aa3b0;
}

.book-picker-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 28rpx 16rpx;
  padding: 24rpx 24rpx 40rpx;
}

.book-picker-cell {
  width: calc((100% - 32rpx) / 3);
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 10rpx;
  transition: transform 0.15s ease;
}

.book-picker-cell:active {
  transform: scale(0.97);
}

.book-picker-cover-wrap {
  position: relative;
  width: 100%;
  padding-top: 133%;
  border-radius: 16rpx;
  overflow: hidden;
  box-sizing: border-box;
  border: 2rpx solid rgba(17, 19, 24, 0.12);
  background: linear-gradient(180deg, #eef4ff 0%, #f7f2ea 100%);
  box-shadow: 0 8rpx 20rpx rgba(17, 19, 24, 0.08);
}

.book-picker-cell-active .book-picker-cover-wrap {
  border: 3rpx solid #111318;
  box-shadow: 0 10rpx 24rpx rgba(17, 19, 24, 0.16);
}

.book-picker-cover {
  position: absolute;
  left: 0;
  top: 0;
  width: 100%;
  height: 100%;
}

.book-picker-cover-mask {
  position: absolute;
  inset: 0;
  display: flex;
  align-items: center;
  justify-content: center;
  background: rgba(23, 38, 63, 0.42);
}

.book-picker-cover-lock {
  width: 40rpx;
  height: 40rpx;
}

/* 新课标角标：盖在封面左上角 */
.book-picker-tag-new {
  position: absolute;
  top: 0;
  left: 0;
  height: 34rpx;
  padding: 0 12rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 16rpx 0 16rpx 0;
  background: linear-gradient(180deg, #ff5a4e 0%, #f03b30 100%);
  color: #ffffff;
  font-size: 18rpx;
  line-height: 1;
  font-weight: 700;
  box-shadow: 0 4rpx 10rpx rgba(240, 59, 48, 0.28);
}

.book-picker-current {
  position: absolute;
  top: 8rpx;
  right: 8rpx;
  height: 32rpx;
  padding: 0 12rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 999rpx;
  background: #111318;
  color: #ffffff;
  font-size: 18rpx;
  line-height: 1;
  font-weight: 700;
  box-shadow: 0 4rpx 10rpx rgba(17, 19, 24, 0.24);
}

.book-picker-buy {
  position: absolute;
  right: 8rpx;
  bottom: 8rpx;
  height: 40rpx;
  padding: 0 16rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 999rpx;
  background: linear-gradient(180deg, #ffa11c 0%, #ff8200 100%);
  color: #ffffff;
  font-size: 22rpx;
  line-height: 1;
  font-weight: 700;
  box-shadow: 0 6rpx 14rpx rgba(255, 130, 0, 0.32);
}

.book-picker-name {
  display: -webkit-box;
  -webkit-box-orient: vertical;
  -webkit-line-clamp: 2;
  overflow: hidden;
  width: 100%;
  font-size: 22rpx;
  line-height: 30rpx;
  font-weight: 400;
  color: #1a2f45;
  text-align: center;
}

.book-picker-cell-active .book-picker-name {
  color: #111318;
}

.book-picker-meta {
  display: flex;
  align-items: center;
  justify-content: center;
  flex-wrap: wrap;
  gap: 6rpx 10rpx;
}

.book-picker-words {
  font-size: 20rpx;
  line-height: 28rpx;
  color: #7a8798;
}

/* 已购买徽标：盖在封面右下角 */
.book-picker-status-owned {
  position: absolute;
  right: 8rpx;
  bottom: 8rpx;
  height: 36rpx;
  padding: 0 14rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 999rpx;
  background: rgba(31, 148, 69, 0.92);
  color: #ffffff;
  font-size: 18rpx;
  line-height: 1;
  font-weight: 600;
  box-shadow: 0 4rpx 10rpx rgba(31, 148, 69, 0.28);
}
