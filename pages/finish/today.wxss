/* pages/finish/today.wxss */
.content {
  text-align: center;
  font-size: 80rpx;
  font-family: OPPOSans;
  font-weight: bold;
  color: #111318;
}

.periodical {
  font-size: 34rpx;
  font-family: PingFang SC;
  font-weight: 600;
  color: #343434;
  text-align: center;
  line-height: 60rpx;
}

.checkin-progress-line {
  margin-top: 34rpx;
  color: #62626b;
  font-size: 28rpx;
  line-height: 40rpx;
  font-weight: 600;
  text-align: center;
}

.checkin-success-card {
  margin: 30rpx 66rpx 0;
  padding: 24rpx 24rpx 26rpx;
  display: flex;
  align-items: center;
  border-radius: 28rpx;
  background: #f5f3ff;
  box-shadow: 0 8rpx 18rpx rgba(124, 99, 255, 0.12);
}

.checkin-success-card-bright {
  background: linear-gradient(135deg, #ffffff, #f5f3ff);
}

.checkin-success-icon {
  flex: none;
  width: 78rpx;
  height: 78rpx;
}

.checkin-success-copy {
  flex: 1;
  min-width: 0;
  margin-left: 18rpx;
}

.checkin-success-title {
  color: #1d1d22;
  font-size: 30rpx;
  line-height: 38rpx;
  font-weight: 800;
}

.checkin-success-subtitle {
  margin-top: 6rpx;
  color: #62626b;
  font-size: 22rpx;
  line-height: 32rpx;
}

.checkin-calendar-btn {
  flex: none;
  margin-left: 16rpx;
  padding: 13rpx 18rpx;
  color: #ffffff;
  background: #111318;
  border-radius: 999rpx;
  font-size: 22rpx;
  line-height: 28rpx;
  font-weight: 700;
}

.btn {
  background: #111318;
  height: 100rpx;
  border-radius: 999rpx;
  color: #ffffff;
  font-size: 36rpx;
  font-weight: bold;
  line-height: 100rpx;
  text-align: center;
  margin: 0 66rpx;
  box-shadow: 0 8rpx 18rpx rgba(17, 19, 24, 0.18);
}

.btn-secondary {
  background: rgba(255, 255, 255, 0.55);
  color: #111318;
  border: 1rpx solid rgba(255, 255, 255, 0.72);
  box-shadow: none;
}

.box {
  position: absolute;
  left: 0;
  right: 0;
  top: 0;
  bottom: 0;
  height: 100%;
  background-color: #2f80ed;
}

.pic {
  position: relative;
  width: calc(100% - 66rpx);
  margin: 180rpx 33rpx 0;
}

.head {
  position: fixed;
  width: 100%;
}

.info {
  border-radius: 30rpx;
  margin: -20rpx 40rpx 0;
  position: relative;
  background: white;
  padding: 93rpx 0 69rpx;
  box-shadow: 0 0 20rpx 0 rgba(0, 0, 0, 0.06);
  text-align: center;
  font-family: PingFang SC;
  font-weight: 500;
}

.column {
  display: inline-block;
  margin-top: 64rpx;
}

.num {
  font-size: 60rpx;
  color: #111318;
}

.num2 {
  font-size: 24rpx;
  color: #343434;
}

.type {
  margin: 30rpx 60rpx 0rpx;
  font-size: 36rpx;
  color: #343434;
}
