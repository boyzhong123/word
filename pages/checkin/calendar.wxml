<view class="calendar-page">
  <view
    class="nav"
    style="height: {{navBarHeightPx}}px; padding-top: {{statusBarHeight}}px;"
  >
    <view class="nav-btn" bindtap="back">
      <image class="nav-action-icon" src="../../images/icon_back_deep.svg" mode="aspectFit" />
    </view>
    <view class="nav-actions" style="right: {{navActionsRight}}px;">
      <image class="help-icon" src="../../images/checkin/help-jelly.png" mode="aspectFit" bindtap="openRulesDialog" />
      <image
        class="gift-icon {{giftUnlocked ? 'gift-icon-active' : 'gift-icon-locked'}}"
        src="../../images/checkin/gift-jelly.png"
        mode="aspectFit"
        bindtap="openGiftDialog"
      />
    </view>
  </view>

  <scroll-view
    class="calendar-scroll"
    style="height: calc(100% - {{navBarHeightPx}}px);"
    scroll-y
    enhanced
    show-scrollbar="{{false}}"
  >
    <view class="streak-hero">
      <view class="streak-left">
        <view class="avatar-shell">
          <image
            class="avatar-image"
            src="{{avatarSrc}}"
            mode="aspectFill"
          />
        </view>
        <view class="streak-copy">
          <view class="streak-line">
            <text class="streak-number">{{displayContinuousDays}}</text>
            <text class="streak-day">天</text>
            <image class="charge-icon" src="../../images/checkin/charge-jelly.png" mode="aspectFit" />
          </view>
          <view class="streak-title">连续不断电</view>
        </view>
      </view>
      <view class="bolt-wrap">
        <image class="bolt-main" src="../../images/checkin/bolt-jelly.png" mode="aspectFit" />
      </view>
    </view>

    <view class="power-card">
      <view class="power-copy">
        {{todayChecked ? '今天的电力已经续上。继续学习，让你的战绩持续常亮。' : '噫，今天的电力还没续上。花3分钟，保持你的战绩常亮。'}}
      </view>
      <view class="power-buttons">
        <button class="power-button" hover-class="power-button-hover" bindtap="startLearning">开始背单词</button>
        <button class="power-button power-button-share" hover-class="power-button-hover" bindtap="openShareDialog">分享打卡</button>
      </view>
    </view>

    <view class="calendar-card">
      <view class="calendar-head">
        <view class="calendar-title">{{yearMonth}}</view>
        <view class="month-actions">
          <view class="month-btn" bindtap="prevMonth">
            <image src="../../images/checkin/chevron-left.svg" mode="aspectFit" />
          </view>
          <view class="month-btn" bindtap="nextMonth">
            <image src="../../images/checkin/chevron-right.svg" mode="aspectFit" />
          </view>
        </view>
      </view>
      <view class="weekday-row">
        <view class="weekday" wx:for="{{weekdays}}" wx:key="*this">{{item}}</view>
      </view>
      <view class="day-grid">
        <view
          class="day-cell {{item.inMonth ? '' : 'day-cell-empty'}} {{item.inMonth && !item.checked && !item.isToday && item.day !== rewardDay ? 'day-cell-unchecked' : ''}} {{item.checked ? 'day-cell-checked' : ''}} {{item.isToday ? 'day-cell-today' : ''}} {{item.inMonth && item.day === rewardDay ? 'day-cell-reward' : ''}}"
          wx:for="{{calendarDays}}"
          wx:key="date"
        >
          <block wx:if="{{item.inMonth}}">
            <block wx:if="{{item.day === rewardDay}}">
              <view class="day-reward-badge">30天</view>
              <image class="day-reward-icon" src="../../images/checkin/gift-day-jelly.png" mode="aspectFit" />
            </block>
            <view wx:else class="day-number">{{item.day}}</view>
          </block>
        </view>
      </view>
    </view>

    <view class="scroll-spacer" style="height: {{120 + safeAreaBottom}}rpx;"></view>
  </scroll-view>

  <view class="rules-dialog-mask" wx:if="{{showRulesDialog}}" bindtap="closeRulesDialog">
    <view class="rules-dialog" catchtap="">
      <view class="rules-dialog-title">打卡规则</view>
      <view class="rules-dialog-list">
        <view class="rules-dialog-item">
          <image class="rules-dialog-icon" src="../../images/checkin/bolt-jelly.png" mode="aspectFit" />
          <view class="rules-dialog-copy">完成今日计划关卡，系统会自动点亮当天打卡。</view>
        </view>
        <view class="rules-dialog-item">
          <image class="rules-dialog-icon" src="../../images/checkin/charge-jelly.png" mode="aspectFit" />
          <view class="rules-dialog-copy">今日目标来自学习计划页，调整计划后会同步更新。</view>
        </view>
        <view class="rules-dialog-item">
          <image class="rules-dialog-icon" src="../../images/checkin/gift-jelly.png" mode="aspectFit" />
          <view class="rules-dialog-copy">连续30天不断电，即可领取听说在线 VIP 礼品。</view>
        </view>
      </view>
      <button class="rules-dialog-button" hover-class="power-button-hover" bindtap="closeRulesDialog">知道了</button>
    </view>
  </view>

  <view class="gift-dialog-mask" wx:if="{{showGiftDialog}}" bindtap="closeGiftDialog">
    <view class="gift-dialog" catchtap="">
      <view class="gift-dialog-title">30天连续打卡奖励</view>
      <block wx:if="{{giftUnlocked}}">
        <view class="gift-dialog-subtitle">5天听说在线 VIP 兑换码</view>
        <view class="gift-dialog-code">{{rewardCode}}</view>
        <button class="gift-dialog-copy {{giftCopied ? 'gift-dialog-copy-done' : ''}}" hover-class="power-button-hover" bindtap="copyRewardCode">{{giftCopied ? '已复制' : '复制兑换码'}}</button>
      </block>
      <block wx:else>
        <view class="gift-dialog-subtitle">连续不断电满 30 天，可领 5 天听说在线 VIP</view>
        <view class="gift-progress-track">
          <view class="gift-progress-fill" style="width: {{rewardProgressPercent}}%;"></view>
        </view>
        <view class="gift-progress-copy">已连续 {{displayContinuousDays}} 天，还差 {{rewardRemainingDays}} 天</view>
        <button class="gift-dialog-copy" hover-class="power-button-hover" bindtap="closeGiftDialog">继续打卡</button>
      </block>
      <view class="gift-dialog-close" bindtap="closeGiftDialog">关闭</view>
    </view>
  </view>

  <view class="share-dialog-mask" wx:if="{{showShareDialog}}">
    <view class="share-dialog">
      <view class="share-close" bindtap="closeShareDialog">
        <image src="../../images/icon_close_deep.svg" mode="aspectFit" />
      </view>
      <view class="share-tabs">
        <view
          class="share-tab {{shareMode === 'today' ? 'share-tab-active' : ''}}"
          data-mode="today"
          bindtap="switchShareMode"
        >今日打卡</view>
        <view
          class="share-tab {{shareMode === 'streak' ? 'share-tab-active' : ''}}"
          data-mode="streak"
          bindtap="switchShareMode"
        >累计打卡</view>
      </view>
      <swiper
        class="share-poster-swiper"
        current="{{shareThemeIndex}}"
        bindchange="onShareThemeSwipe"
        previous-margin="36rpx"
        next-margin="36rpx"
        duration="280"
      >
        <swiper-item wx:for="{{shareThemes}}" wx:key="id">
          <view class="share-poster-frame">
            <image
              wx:if="{{sharePosterPaths[item.id]}}"
              class="share-poster-image"
              src="{{sharePosterPaths[item.id]}}"
              mode="widthFix"
            />
            <view wx:else class="share-poster-loading">海报生成中…</view>
          </view>
        </swiper-item>
      </swiper>
      <view class="share-theme-dots">
        <view
          wx:for="{{shareThemes}}"
          wx:key="id"
          class="share-theme-dot {{shareThemeIndex === index ? 'share-theme-dot-active' : ''}}"
        />
      </view>
      <view class="share-actions">
        <button class="share-action share-action-save" hover-class="power-button-hover" bindtap="saveShareImage">保存图片</button>
        <button class="share-action share-action-send" hover-class="power-button-hover" bindtap="sendShareImage">分享到微信</button>
      </view>
    </view>
  </view>

  <canvas id="share-poster" type="2d" class="share-poster-canvas"></canvas>
</view>
