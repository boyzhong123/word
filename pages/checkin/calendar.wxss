page {
  height: 100%;
  background: #f5f0ff;
  color: #202126;
}

.calendar-page {
  position: relative;
  height: 100%;
  overflow: hidden;
  background: linear-gradient(180deg, #ddd6fe 0%, #ede9fe 18%, #f5f3ff 42%, #faf8ff 100%);
  font-family: PingFang SC, PingFangSC-Regular, sans-serif;
}

.nav {
  position: relative;
  z-index: 10;
  height: 116rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  box-sizing: content-box;
  background: transparent;
}

.nav-btn {
  position: absolute;
  left: 35rpx;
  bottom: 17rpx;
  width: 56rpx;
  height: 70rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.nav-action-icon,
.nav-icon {
  height: 32rpx;
}

.nav-actions {
  position: absolute;
  right: 43rpx;
  bottom: 22rpx;
  display: flex;
  align-items: center;
  gap: 36rpx;
}

.help-icon,
.gift-icon {
  width: 52rpx;
  height: 52rpx;
}

.calendar-scroll {
  height: calc(100% - 116rpx);
  padding: 0 31rpx;
  box-sizing: border-box;
}

.streak-hero {
  min-height: 277rpx;
  padding: 74rpx 10rpx 38rpx 3rpx;
  box-sizing: border-box;
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.streak-left {
  flex: 1;
  min-width: 0;
  display: flex;
  align-items: center;
  gap: 31rpx;
}

.avatar-shell {
  flex: none;
  width: 122rpx;
  height: 122rpx;
  padding: 7rpx;
  box-sizing: border-box;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.86);
  box-shadow: 0 8rpx 18rpx rgba(124, 99, 255, 0.14);
}

.avatar-image {
  width: 100%;
  height: 100%;
  border-radius: 50%;
  background: #ffffff;
}

.streak-copy {
  min-width: 0;
}

.streak-line {
  display: flex;
  align-items: center;
}

.streak-number {
  color: #1d1d22;
  font-size: 86rpx;
  line-height: 90rpx;
  font-weight: 900;
  letter-spacing: 0;
}

.streak-day {
  margin-left: 12rpx;
  color: #27272d;
  font-size: 36rpx;
  line-height: 44rpx;
}

.charge-icon {
  width: 48rpx;
  height: 48rpx;
  margin-left: 13rpx;
}

.streak-title {
  margin-top: 9rpx;
  color: #34343b;
  font-size: 34rpx;
  line-height: 45rpx;
  font-weight: 500;
}

.bolt-wrap {
  position: relative;
  flex: none;
  width: 234rpx;
  height: 174rpx;
}

.bolt-main {
  position: absolute;
  right: 18rpx;
  top: 0;
  width: 150rpx;
  height: 170rpx;
}

.spark {
  position: absolute;
  width: 32rpx;
  height: 34rpx;
  opacity: 0.95;
}

.spark::before,
.spark::after {
  content: "";
  position: absolute;
  background: rgba(255, 255, 255, 0.92);
  border-radius: 20rpx;
  transform: rotate(45deg);
}

.spark::before {
  left: 13rpx;
  top: 0;
  width: 8rpx;
  height: 34rpx;
}

.spark::after {
  left: 0;
  top: 13rpx;
  width: 34rpx;
  height: 8rpx;
}

.spark-a {
  left: 35rpx;
  top: 48rpx;
}

.spark-b {
  left: 82rpx;
  top: 91rpx;
  transform: scale(0.7) rotate(-12deg);
  opacity: 0.65;
}

.power-card,
.calendar-card {
  background: #ffffff;
  border: 1rpx solid rgba(238, 238, 242, 0.68);
  border-radius: 24rpx;
  box-sizing: border-box;
  box-shadow: 0 8rpx 18rpx rgba(124, 99, 255, 0.06);
}

.power-card {
  margin-top: 2rpx;
  padding: 35rpx 32rpx 33rpx;
}

.power-copy {
  color: #62626b;
  font-size: 31rpx;
  line-height: 48rpx;
  font-weight: 600;
}

.power-button {
  width: 100%;
  height: 93rpx;
  margin-top: 43rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #ffffff;
  background: #111318;
  border-radius: 999rpx;
  font-size: 31rpx;
  line-height: 93rpx;
  font-weight: 700;
  box-shadow: 0 8rpx 18rpx rgba(17, 19, 24, 0.18);
}

.power-button::after {
  border: 0;
}

.power-button-hover {
  opacity: 0.88;
}

.calendar-card {
  margin-top: 80rpx;
  padding: 38rpx 34rpx 42rpx;
}

.calendar-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.calendar-title {
  color: #5f5f67;
  font-size: 37rpx;
  line-height: 48rpx;
  font-weight: 800;
}

.month-actions {
  display: flex;
  align-items: center;
  gap: 36rpx;
  padding-right: 18rpx;
}

.month-btn {
  width: 58rpx;
  height: 58rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 50%;
  background: #eeeef1;
}

.month-btn image {
  width: 28rpx;
  height: 28rpx;
}

.weekday-row,
.day-grid {
  display: grid;
  grid-template-columns: repeat(7, 1fr);
}

.weekday-row {
  margin-top: 47rpx;
}

.weekday {
  height: 44rpx;
  color: #96969d;
  font-size: 34rpx;
  line-height: 44rpx;
  text-align: center;
  font-weight: 500;
}

.weekday:nth-child(6) {
  color: #8b6cff;
}

.day-grid {
  row-gap: 39rpx;
  margin-top: 54rpx;
}

.day-cell {
  position: relative;
  width: 72rpx;
  height: 72rpx;
  margin: 0 auto;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #9a9ca2;
  background: transparent;
  border-radius: 50%;
  box-sizing: border-box;
}

.day-cell-empty {
  opacity: 0;
}

.day-cell-checked {
  color: #ffffff;
  background: #8b6cff;
  box-shadow: 0 8rpx 16rpx rgba(139, 108, 255, 0.22);
}

.day-cell-today {
  color: #60636a;
  background: #eeeeef;
}

.day-cell-checked.day-cell-today {
  color: #ffffff;
  background: #8b6cff;
}

.day-cell-reward,
.day-cell-reward.day-cell-today {
  color: #ffffff;
  background: transparent;
  box-shadow: none;
}

.day-number {
  position: relative;
  z-index: 1;
  font-size: 31rpx;
  line-height: 38rpx;
  font-weight: 700;
}

.day-reward-icon {
  position: absolute;
  left: 0;
  top: -11rpx;
  width: 72rpx;
  height: 78rpx;
}

.day-number-reward {
  margin-top: 16rpx;
}
