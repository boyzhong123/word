page {
  height: 100%;
  background: #f5f0ff;
  color: #202126;
}

.calendar-page {
  position: relative;
  height: 100%;
  overflow: hidden;
  background: linear-gradient(180deg, #ddd6fe 0%, #ede9fe 18%, #f5f3ff 42%, #faf8ff 100%);
  font-family: PingFang SC, PingFangSC-Regular, sans-serif;
}

.nav {
  position: relative;
  z-index: 10;
  display: flex;
  align-items: flex-end;
  justify-content: space-between;
  box-sizing: border-box;
  background: transparent;
}

.nav-btn {
  margin-left: 8rpx;
  margin-bottom: 10rpx;
  min-width: 64rpx;
  height: 64rpx;
  padding: 0 8rpx;
  box-sizing: border-box;
  display: flex;
  align-items: center;
  justify-content: center;
}

.nav-action-icon,
.nav-icon {
  width: 32rpx;
  height: 32rpx;
}

.nav-actions {
  position: absolute;
  bottom: 10rpx;
  display: flex;
  align-items: center;
  gap: 28rpx;
}

.help-icon,
.gift-icon {
  width: 52rpx;
  height: 52rpx;
}

.gift-icon-locked {
  opacity: 0.42;
}

.gift-icon-active {
  opacity: 1;
}

.calendar-scroll {
  padding: 0 31rpx;
  box-sizing: border-box;
}

.streak-hero {
  min-height: 220rpx;
  padding: 18rpx 10rpx 24rpx 3rpx;
  box-sizing: border-box;
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.streak-left {
  flex: 1;
  min-width: 0;
  display: flex;
  align-items: center;
  gap: 31rpx;
}

.avatar-shell {
  flex: none;
  width: 122rpx;
  height: 122rpx;
  padding: 7rpx;
  box-sizing: border-box;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.86);
  box-shadow: 0 8rpx 18rpx rgba(124, 99, 255, 0.14);
}

.avatar-image {
  width: 100%;
  height: 100%;
  border-radius: 50%;
  background: #ffffff;
}

.streak-copy {
  min-width: 0;
}

.streak-line {
  display: flex;
  align-items: center;
}

.streak-number {
  color: #1d1d22;
  font-size: 86rpx;
  line-height: 90rpx;
  font-weight: 900;
  letter-spacing: 0;
}

.streak-day {
  margin-left: 12rpx;
  color: #27272d;
  font-size: 36rpx;
  line-height: 44rpx;
}

.charge-icon {
  width: 48rpx;
  height: 48rpx;
  margin-left: 13rpx;
}

.streak-title {
  margin-top: 9rpx;
  color: #34343b;
  font-size: 34rpx;
  line-height: 45rpx;
  font-weight: 500;
}

.bolt-wrap {
  position: relative;
  flex: none;
  width: 210rpx;
  height: 210rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 50%;
  background: radial-gradient(circle, rgba(255, 255, 255, 0.72) 0%, rgba(255, 255, 255, 0.18) 72%, rgba(255, 255, 255, 0) 100%);
}

.bolt-main {
  width: 190rpx;
  height: 210rpx;
}

.power-card,
.calendar-card {
  background: #ffffff;
  border: 1rpx solid rgba(238, 238, 242, 0.68);
  border-radius: 24rpx;
  box-sizing: border-box;
  box-shadow: 0 8rpx 18rpx rgba(124, 99, 255, 0.06);
}

.power-card {
  margin-top: 8rpx;
  padding: 35rpx 32rpx 33rpx;
}

.power-copy {
  color: #62626b;
  font-size: 31rpx;
  line-height: 48rpx;
  font-weight: 600;
}

.power-buttons {
  display: flex;
  gap: 22rpx;
  margin-top: 43rpx;
}

.power-button {
  flex: 1;
  height: 93rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #ffffff;
  background: #111318;
  border-radius: 999rpx;
  font-size: 31rpx;
  line-height: 93rpx;
  font-weight: 700;
  box-shadow: 0 8rpx 18rpx rgba(17, 19, 24, 0.18);
}

.power-button::after {
  border: 0;
}

.power-button-hover {
  opacity: 0.88;
}

.power-button-share {
  color: #4c1d95;
  background: #ede9fe;
  box-shadow: none;
}

.calendar-card {
  margin-top: 40rpx;
  padding: 38rpx 34rpx 42rpx;
}

.calendar-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.calendar-title {
  color: #5f5f67;
  font-size: 37rpx;
  line-height: 48rpx;
  font-weight: 800;
}

.month-actions {
  display: flex;
  align-items: center;
  gap: 36rpx;
  padding-right: 18rpx;
}

.month-btn {
  width: 58rpx;
  height: 58rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 50%;
  background: #ece8ff;
  border: 1rpx solid rgba(139, 108, 255, 0.22);
  box-shadow: inset 0 2rpx 0 rgba(255, 255, 255, 0.92);
}

.month-btn image {
  width: 28rpx;
  height: 28rpx;
}

.weekday-row,
.day-grid {
  display: grid;
  grid-template-columns: repeat(7, 1fr);
}

.weekday-row {
  margin-top: 47rpx;
}

.weekday {
  height: 44rpx;
  color: #96969d;
  font-size: 34rpx;
  line-height: 44rpx;
  text-align: center;
  font-weight: 500;
}

.weekday:nth-child(6) {
  color: #8b6cff;
}

.day-grid {
  row-gap: 26rpx;
  margin-top: 44rpx;
}

.day-cell {
  position: relative;
  width: 78rpx;
  height: 78rpx;
  margin: 0 auto;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #9a9ca2;
  background: transparent;
  border-radius: 50%;
  box-sizing: border-box;
}

.day-cell::before {
  content: "";
  position: absolute;
  z-index: 0;
  left: 0;
  top: 0;
  width: 100%;
  height: 100%;
  border-radius: 50%;
  box-sizing: border-box;
}

.day-cell-empty {
  opacity: 0;
}

.day-cell-unchecked {
  color: #9a9ca2;
}

.day-cell-unchecked::before {
  background: linear-gradient(180deg, #fbfaff 0%, #f3f0fb 100%);
  border: 2rpx dashed rgba(159, 150, 177, 0.28);
  box-shadow: inset 0 2rpx 0 rgba(255, 255, 255, 0.86);
}

.day-cell-checked {
  color: #ffffff;
}

.day-cell-checked::before {
  background: linear-gradient(145deg, #9d7cff 0%, #7b5cf4 72%, #6844e8 100%);
  box-shadow: 0 10rpx 18rpx rgba(124, 92, 244, 0.28), inset 0 3rpx 0 rgba(255, 255, 255, 0.26);
}

.day-cell-checked::after {
  content: "";
  position: absolute;
  z-index: 1;
  top: 12rpx;
  left: 19rpx;
  width: 26rpx;
  height: 10rpx;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.24);
  transform: rotate(-18deg);
}

.day-cell-today {
  color: #5d46d8;
}

.day-cell-today::before {
  background: linear-gradient(180deg, #ffffff 0%, #f7f4ff 100%);
  border: 3rpx solid rgba(139, 108, 255, 0.72);
  box-shadow: 0 8rpx 16rpx rgba(139, 108, 255, 0.16), inset 0 0 0 6rpx #f0ebff;
}

.day-cell-checked.day-cell-today {
  color: #ffffff;
}

.day-cell-today .day-number {
  color: #5d46d8;
  font-weight: 900;
}

.day-number-today {
  color: #5d46d8;
  font-weight: 900;
}

.day-cell-reward,
.day-cell-reward.day-cell-today {
  flex-direction: column;
  width: 78rpx;
  height: 78rpx;
  color: #7c3aed;
  background: transparent;
  box-shadow: none;
}

.day-cell-reward::before,
.day-cell-reward.day-cell-today::before {
  background: linear-gradient(180deg, #fff8dc 0%, #ffe9a6 100%);
  border: 2rpx solid rgba(255, 195, 64, 0.82);
  box-shadow: 0 10rpx 18rpx rgba(255, 176, 32, 0.18), inset 0 3rpx 0 rgba(255, 255, 255, 0.86);
}

.day-cell-reward.day-cell-checked::before {
  background: linear-gradient(145deg, #a98aff 0%, #7b5cf4 56%, #ffc94a 100%);
  border-color: rgba(255, 218, 106, 0.92);
  box-shadow: 0 10rpx 20rpx rgba(124, 92, 244, 0.26), inset 0 3rpx 0 rgba(255, 255, 255, 0.3);
}

.day-cell-reward-unlocked::before,
.day-cell-reward-unlocked.day-cell-today::before {
  background: linear-gradient(180deg, #fff0a8 0%, #ffc94a 100%);
  border-color: rgba(255, 183, 30, 0.94);
  box-shadow: 0 10rpx 20rpx rgba(255, 176, 32, 0.24), inset 0 3rpx 0 rgba(255, 255, 255, 0.72);
}

.day-cell-reward-locked::before,
.day-cell-reward-locked.day-cell-today::before {
  background: linear-gradient(180deg, #fffdf4 0%, #fff2c6 100%);
  border-color: rgba(255, 197, 61, 0.72);
  box-shadow: 0 8rpx 16rpx rgba(255, 176, 32, 0.12), inset 0 3rpx 0 rgba(255, 255, 255, 0.88);
}

.day-cell-reward::after {
  display: none;
}

.day-number {
  position: relative;
  z-index: 2;
  font-size: 31rpx;
  line-height: 38rpx;
  font-weight: 700;
}

.day-reward-badge {
  position: absolute;
  z-index: 3;
  right: -8rpx;
  top: -11rpx;
  min-width: 44rpx;
  height: 25rpx;
  padding: 0 7rpx;
  box-sizing: border-box;
  border-radius: 999rpx;
  color: #7a3c00;
  background: #ffd65a;
  border: 2rpx solid #ffffff;
  font-size: 17rpx;
  line-height: 23rpx;
  font-weight: 900;
  text-align: center;
  box-shadow: 0 5rpx 10rpx rgba(255, 176, 32, 0.22);
}

.day-cell-reward-unlocked .day-reward-badge {
  color: #ffffff;
  background: #7b5cf4;
  box-shadow: 0 5rpx 12rpx rgba(123, 92, 244, 0.24);
}

.day-cell-reward-locked .day-reward-badge {
  color: #7a3c00;
  background: #ffe08a;
}

.day-reward-icon {
  position: absolute;
  z-index: 2;
  flex: none;
  left: 14rpx;
  top: 12rpx;
  width: 50rpx;
  height: 52rpx;
}

.day-cell-reward-locked .day-reward-icon {
  opacity: 0.78;
}

.rules-dialog-mask,
.gift-dialog-mask {
  position: fixed;
  z-index: 100;
  left: 0;
  top: 0;
  width: 100%;
  height: 100%;
  display: flex;
  align-items: center;
  justify-content: center;
  background: rgba(17, 19, 24, 0.42);
}

.rules-dialog,
.gift-dialog {
  width: 620rpx;
  padding: 48rpx 40rpx 36rpx;
  box-sizing: border-box;
  border-radius: 28rpx;
  background: #ffffff;
  box-shadow: 0 18rpx 40rpx rgba(124, 99, 255, 0.18);
}

.rules-dialog-title,
.gift-dialog-title {
  color: #1d1d22;
  font-size: 36rpx;
  line-height: 48rpx;
  font-weight: 800;
  text-align: center;
}

.rules-dialog-list {
  margin-top: 34rpx;
}

.rules-dialog-item {
  display: flex;
  align-items: center;
  padding: 22rpx 0;
  border-bottom: 1rpx solid #f0eef8;
}

.rules-dialog-item:last-child {
  border-bottom: 0;
}

.rules-dialog-icon {
  flex: none;
  width: 58rpx;
  height: 58rpx;
}

.rules-dialog-copy {
  flex: 1;
  margin-left: 22rpx;
  color: #62626b;
  font-size: 27rpx;
  line-height: 40rpx;
  font-weight: 600;
}

.rules-dialog-button {
  width: 100%;
  height: 88rpx;
  margin-top: 34rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #ffffff;
  background: #111318;
  border-radius: 999rpx;
  font-size: 30rpx;
  line-height: 88rpx;
  font-weight: 700;
}

.rules-dialog-button::after {
  border: 0;
}

.gift-dialog-subtitle {
  margin-top: 14rpx;
  color: #62626b;
  font-size: 28rpx;
  line-height: 40rpx;
  text-align: center;
}

.gift-dialog-code {
  margin-top: 34rpx;
  padding: 28rpx 24rpx;
  border-radius: 18rpx;
  background: #f5f3ff;
  color: #4c1d95;
  font-size: 40rpx;
  line-height: 48rpx;
  font-weight: 800;
  letter-spacing: 2rpx;
  text-align: center;
}

.gift-progress-track {
  height: 18rpx;
  margin-top: 36rpx;
  border-radius: 999rpx;
  background: #f0eef8;
  overflow: hidden;
}

.gift-progress-fill {
  height: 100%;
  border-radius: 999rpx;
  background: linear-gradient(90deg, #a78bfa 0%, #8b6cff 100%);
}

.gift-progress-copy {
  margin-top: 18rpx;
  color: #62626b;
  font-size: 26rpx;
  line-height: 36rpx;
  text-align: center;
  font-weight: 600;
}

.gift-dialog-copy {
  width: 100%;
  height: 88rpx;
  margin-top: 34rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #ffffff;
  background: #111318;
  border-radius: 999rpx;
  font-size: 30rpx;
  line-height: 88rpx;
  font-weight: 700;
}

.gift-dialog-copy::after {
  border: 0;
}

.gift-dialog-copy-done {
  background: #8b6cff;
}

.gift-dialog-close {
  margin-top: 24rpx;
  color: #8b6cff;
  font-size: 28rpx;
  line-height: 40rpx;
  text-align: center;
  font-weight: 600;
}

.share-dialog-mask {
  position: fixed;
  z-index: 110;
  left: 0;
  top: 0;
  width: 100%;
  height: 100%;
  display: flex;
  align-items: center;
  justify-content: center;
  background: rgba(17, 19, 24, 0.66);
}

.share-dialog {
  position: relative;
  width: 600rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.share-tabs {
  display: flex;
  gap: 8rpx;
  padding: 8rpx;
  margin-bottom: 24rpx;
  border-radius: 999rpx;
  background: #ffffff;
  box-shadow: 0 8rpx 18rpx rgba(0, 0, 0, 0.18);
}

.share-tab {
  padding: 12rpx 40rpx;
  border-radius: 999rpx;
  color: #62626b;
  font-size: 27rpx;
  font-weight: 600;
}

.share-tab-active {
  background: linear-gradient(145deg, #9d7cff 0%, #7b5cf4 72%, #6844e8 100%);
  color: #ffffff;
  font-weight: 700;
  box-shadow: 0 6rpx 14rpx rgba(124, 92, 244, 0.4);
}

/* 关闭按钮：弹层最下方居中的描边圆 */
.share-close {
  margin-top: 40rpx;
  width: 72rpx;
  height: 72rpx;
  border-radius: 50%;
  border: 2rpx solid rgba(255, 255, 255, 0.72);
  display: flex;
  align-items: center;
  justify-content: center;
}

.share-close image {
  width: 30rpx;
  height: 30rpx;
}

/* previous/next-margin 各 48rpx 露出邻图边缘，
   item(648rpx) 比海报(600rpx) 宽 48rpx，海报居中后图与图之间留出 48rpx 缝隙 */
/* 海报展示宽 560rpx（5:8 → 高 896rpx）；previous/next-margin 各 56rpx 露出邻图，
   item(616rpx) 比海报宽 56rpx，居中后图与图之间留出 56rpx 缝隙 */
.share-poster-swiper {
  width: 728rpx;
  height: 896rpx;
  margin-bottom: 16rpx;
}

.share-theme-dots {
  display: flex;
  justify-content: center;
  gap: 12rpx;
  margin-bottom: 8rpx;
}

.share-theme-dot {
  width: 12rpx;
  height: 12rpx;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.34);
}

.share-theme-dot-active {
  width: 28rpx;
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.92);
}

.share-poster-frame {
  width: 560rpx;
  height: 896rpx;
  margin: 0 auto;
  border-radius: 24rpx;
  overflow: hidden;
  background: #1e1b4b;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 24rpx 60rpx rgba(0, 0, 0, 0.35);
}

.share-poster-image {
  width: 560rpx;
  display: block;
}

.share-poster-loading {
  color: rgba(255, 255, 255, 0.72);
  font-size: 26rpx;
}

.share-actions {
  width: 600rpx;
  margin-top: 32rpx;
  display: flex;
  gap: 24rpx;
}

.share-action {
  flex: 1;
  height: 93rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 999rpx;
  font-size: 31rpx;
  font-weight: 700;
}

.share-action::after {
  border: 0;
}

.share-action-save {
  color: #111318;
  background: #ffffff;
}

.share-action-send {
  color: #ffffff;
  background: #111318;
  box-shadow: 0 8rpx 18rpx rgba(17, 19, 24, 0.28);
}

/* 海报绘制画布：保持渲染但移出屏幕 */
.share-poster-canvas {
  position: fixed;
  top: -9999px;
  left: -9999px;
  width: 600px;
  height: 960px;
}
