<view class="page">
  <navigation class="title-box" background="#fbfcff">
    <view class="ad-nav-title-wrap">
      <view class="ad-nav-title">{{name || '教材详情'}}</view>
    </view>
  </navigation>

  <scroll-view scroll-y class="content" style="height: {{scrollHeight}}px;" enhanced show-scrollbar="{{false}}">
    <view class="hero">
      <image class="hero-image" src="{{imageBaseUrl}}/images/home/ad/product-hero-clean.png" mode="aspectFill" />
      <view class="hero-fade"></view>
    </view>

    <view class="book-card">
      <view class="book-main">
        <view class="book-cover-frame">
          <image class="book-cover" src="{{bookCover}}" mode="aspectFill" />
        </view>
        <view class="book-meta">
          <view class="book-pills">
            <view wx:for="{{gradeTags}}" wx:key="*this" class="grade-pill">{{item}}</view>
            <view wx:if="{{press}}" class="press-pill">{{press}}</view>
          </view>
          <text class="book-name">{{name}}</text>
          <text class="book-summary">{{bookSummary}}</text>
        </view>
      </view>

      <view class="stat-grid">
        <view class="stat-item" wx:for="{{contentStats}}" wx:key="label">
          <text class="stat-value">{{item.value}}</text>
          <view class="stat-caption">
            <text class="stat-unit">{{item.unit}}</text>
            <text class="stat-label">{{item.label}}</text>
          </view>
        </view>
      </view>
    </view>

    <view class="section section-scope">
      <view class="section-head">
        <text class="section-title">这本书适合谁</text>
        <text class="section-note">不同教材共用模板，只替换书本数据</text>
      </view>
      <view class="scope-list">
        <view class="scope-row">
          <text class="scope-label">适用年级</text>
          <view class="scope-tags">
            <text wx:for="{{gradeTags}}" wx:key="*this" class="scope-tag">{{item}}</text>
          </view>
        </view>
        <view wx:if="{{press}}" class="scope-row">
          <text class="scope-label">出版社</text>
          <text class="scope-value">{{press}}</text>
        </view>
        <view class="scope-row">
          <text class="scope-label">内容范围</text>
          <text class="scope-value">{{wordCountText}} 个单词 / {{proverbCountText}} 条句子 / {{totalText}} 个单元</text>
        </view>
      </view>
    </view>

    <view class="section">
      <view class="section-head">
        <text class="section-title">购买后包含</text>
        <text class="section-note">词典内容和学习任务分开呈现</text>
      </view>
      <view class="feature-list">
        <view class="feature-item" wx:for="{{featureCards}}" wx:key="title">
          <view class="feature-mark">{{item.mark}}</view>
          <view class="feature-copy">
            <text class="feature-title">{{item.title}}</text>
            <text class="feature-desc">{{item.desc}}</text>
          </view>
        </view>
      </view>
    </view>

    <view class="section">
      <view class="section-head">
        <text class="section-title">学习方式</text>
        <text class="section-note">按教材单元推进，适合长期上新</text>
      </view>
      <view class="timeline">
        <view class="timeline-item" wx:for="{{methodSteps}}" wx:key="title">
          <view class="timeline-index">{{index + 1}}</view>
          <view class="timeline-copy">
            <text class="timeline-title">{{item.title}}</text>
            <text class="timeline-desc">{{item.desc}}</text>
          </view>
        </view>
      </view>
    </view>

    <view class="section">
      <view class="section-head">
        <text class="section-title">选择套餐</text>
        <text class="section-note">下单前还可以再次确认</text>
      </view>
      <view class="package-list">
        <view class="package-card {{item.id === selectedPackage ? 'package-card-active' : ''}}" wx:for="{{packages}}" wx:key="id">
          <view class="package-top">
            <text class="package-name">{{item.name}}</text>
            <text wx:if="{{item.tag}}" class="package-tag">{{item.tag}}</text>
          </view>
          <view class="package-price">
            <text class="package-currency">¥</text>
            <text class="package-amount">{{item.price}}</text>
          </view>
          <text class="package-summary">{{item.summary}}</text>
        </view>
      </view>
    </view>

    <view wx:if="{{intro}}" class="section">
      <view class="section-head">
        <text class="section-title">教材简介</text>
      </view>
      <text class="intro-text">{{intro}}</text>
    </view>

    <view style="height: {{actionHeight}}px;"></view>
  </scroll-view>

  <view class="purchase-bar" style="padding-bottom: {{safeAreaBottom}}px;">
    <view wx:if="{{unlocked}}" class="purchase-button purchase-button-owned">已购买</view>
    <block wx:else>
      <view class="purchase-price">
        <view class="purchase-price-row">
          <text class="purchase-currency">¥</text>
          <text class="purchase-amount">{{minPrice}}</text>
          <text class="purchase-from">起</text>
        </view>
        <text class="purchase-price-note">{{packages.length}} 种套餐可选</text>
      </view>
      <view class="purchase-button purchase-button-buy" bindtap="openSkuSheet">立即购买</view>
    </block>
  </view>

  <view wx:if="{{skuSheetVisible}}" class="sku-mask" bindtap="closeSkuSheet">
    <view class="sku-sheet" catchtap="noop">
      <view class="sku-handle"></view>

      <view class="sku-book">
        <image class="sku-cover" src="{{bookCover}}" mode="aspectFill" />
        <view class="sku-book-meta">
          <text class="sku-book-name">{{name}}</text>
          <text class="sku-book-stats">{{wordCountText}} 词 · {{proverbCountText}} 条句子 · {{totalText}} 个单元</text>
          <text wx:if="{{press}}" class="sku-book-press">{{press}}</text>
        </view>
      </view>

      <view class="sku-title">选择套餐</view>
      <view class="sku-options">
        <view
          wx:for="{{packages}}"
          wx:key="id"
          class="sku-option {{selectedPackage === item.id ? 'sku-option-active' : ''}}"
          data-id="{{item.id}}"
          bindtap="selectPackage"
        >
          <view wx:if="{{item.tag}}" class="sku-badge">{{item.tag}}</view>
          <text class="sku-option-name">{{item.name}}</text>
          <view class="sku-option-price-row">
            <text class="sku-option-currency">¥</text>
            <text class="sku-option-price">{{item.price}}</text>
          </view>
          <text class="sku-option-desc">{{item.summary}}</text>
        </view>
      </view>

      <view class="sku-includes">
        <view class="sku-includes-title">套餐包含</view>
        <view class="sku-includes-item" wx:for="{{currentPackageItems}}" wx:key="*this">
          <text class="sku-check">✓</text>
          <text class="sku-includes-text">{{item}}</text>
        </view>
      </view>

      <view class="sku-actions">
        <view class="sku-confirm" bindtap="confirmPurchase">¥{{currentPackage.price}} 确认购买</view>
      </view>
    </view>
  </view>
</view>
