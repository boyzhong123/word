<view class="page">
  <navigation class="title-box" background="#fffdf8">
    <view class="ad-nav-title-wrap">
      <view class="ad-nav-title">{{name || '教材详情'}}</view>
    </view>
  </navigation>

  <scroll-view scroll-y class="content" style="height: {{scrollHeight}}px;" enhanced show-scrollbar="{{false}}">
    <!-- 表头：书本信息 -->
    <view class="product-head">
      <view class="product-hero">
        <view class="hero-glow hero-glow-a"></view>
        <view class="hero-glow hero-glow-b"></view>
        <view class="product-cover-wrap">
          <image class="product-cover" src="{{bookCover}}" mode="aspectFill" />
        </view>
        <view class="product-meta">
          <text class="product-name">{{name}}</text>
          <view wx:if="{{press}}" class="product-press-pill">
            <view class="press-dot"></view>
            <text class="product-press">{{press}}</text>
          </view>
        </view>
      </view>

      <view class="product-stats-card">
        <view class="product-stat">
          <view class="stat-number-row">
            <text class="stat-value">{{wordCount}}</text>
            <text class="stat-unit">个</text>
          </view>
          <view class="stat-tick"></view>
          <text class="stat-label">单词</text>
        </view>
        <view class="product-stat">
          <view class="stat-number-row">
            <text class="stat-value">{{proverbCount}}</text>
            <text class="stat-unit">条</text>
          </view>
          <view class="stat-tick"></view>
          <text class="stat-label">句子</text>
        </view>
        <view class="product-stat">
          <view class="stat-number-row">
            <text class="stat-value">{{total}}</text>
            <text class="stat-unit">期</text>
          </view>
          <view class="stat-tick"></view>
          <text class="stat-label">学习单元</text>
        </view>
      </view>
    </view>

    <!-- 商品详情长图 -->
    <view wx:if="{{detailBanners.length}}" class="detail-section">
      <view class="detail-tab">
        <text class="detail-tab-text">商品详情</text>
      </view>
      <view class="detail-gallery">
        <image
          wx:for="{{detailBanners}}"
          wx:key="src"
          class="detail-banner"
          src="{{item.src}}"
          mode="widthFix"
          show-menu-by-longpress="{{false}}"
        />
      </view>
    </view>

    <!-- 教材简介 -->
    <view wx:if="{{intro}}" class="panel intro-panel">
      <view class="panel-title">教材简介</view>
      <text class="intro-text">{{intro}}</text>
    </view>

    <view wx:if="{{!detailBanners.length && !intro}}" class="detail-placeholder">
      <text class="detail-placeholder-text">商品详情图文即将上线</text>
    </view>

    <view style="height: {{actionHeight}}px;"></view>
  </scroll-view>

  <view class="purchase-bar" style="padding-bottom: {{safeAreaBottom}}px;">
    <view wx:if="{{unlocked}}" class="purchase-button purchase-button-owned">已购买</view>
    <view wx:else class="purchase-button purchase-button-full" bindtap="openSkuSheet">立即购买</view>
  </view>

  <!-- SKU 选择弹层：点击购买后出现 -->
  <view wx:if="{{skuSheetVisible}}" class="sku-mask" bindtap="closeSkuSheet">
    <view class="sku-sheet" catchtap="noop">
      <view class="sku-handle"></view>

      <view class="sku-book">
        <image class="sku-cover" src="{{bookCover}}" mode="aspectFill" />
        <view class="sku-book-meta">
          <text class="sku-book-name">{{name}}</text>
          <text class="sku-book-stats">{{wordCount}} 词 · {{proverbCount}} 条句子 · {{total}} 期单元</text>
          <text wx:if="{{press}}" class="sku-book-press">{{press}}</text>
        </view>
      </view>

      <view class="sku-title">选择套餐</view>
      <view class="sku-options">
        <view
          wx:for="{{packages}}"
          wx:key="id"
          class="sku-option {{selectedPackage === item.id ? 'sku-option-active' : ''}}"
          data-id="{{item.id}}"
          bindtap="selectPackage"
        >
          <view wx:if="{{item.tag}}" class="sku-badge">{{item.tag}}</view>
          <text class="sku-option-name">{{item.name}}</text>
          <view class="sku-option-price-row">
            <text class="sku-option-currency">¥</text>
            <text class="sku-option-price">{{item.price}}</text>
          </view>
          <text class="sku-option-desc">{{item.summary}}</text>
        </view>
      </view>

      <view class="sku-includes">
        <view class="sku-includes-title">套餐包含</view>
        <view class="sku-includes-item" wx:for="{{currentPackageItems}}" wx:key="*this">
          <text class="sku-check">✓</text>
          <text class="sku-includes-text">{{item}}</text>
        </view>
      </view>

      <view class="sku-actions">
        <view class="sku-confirm" bindtap="confirmPurchase">¥{{currentPackage.price}} 确认购买</view>
      </view>
    </view>
  </view>
</view>
