page {
  height: 100%;
  background: #fbfcff;
  color: #182331;
}

.page {
  height: 100%;
  display: flex;
  flex-direction: column;
  overflow: hidden;
  background: #fbfcff;
  font-family: PingFang SC, PingFangSC-Regular, sans-serif;
}

.title-box {
  position: relative;
  flex: none;
  background: #fbfcff;
  border-bottom: 1rpx solid rgba(24, 35, 49, 0.08);
}

.ad-nav-title-wrap {
  position: absolute;
  left: 0;
  right: 0;
  top: 0;
  bottom: 0;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 0 120rpx;
  box-sizing: border-box;
  pointer-events: none;
}

.ad-nav-title {
  max-width: 100%;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  color: #183655;
  font-size: 32rpx;
  font-weight: 700;
  line-height: 44rpx;
  text-align: center;
}

.content {
  flex: none;
  width: 100%;
}

.hero {
  position: relative;
  height: 310rpx;
  overflow: hidden;
  background: #eef7f6;
}

.hero-image {
  display: block;
  width: 100%;
  height: 100%;
}

.hero-fade {
  position: absolute;
  left: 0;
  right: 0;
  bottom: 0;
  height: 120rpx;
  background: linear-gradient(180deg, rgba(251, 252, 255, 0) 0%, #fbfcff 100%);
}

.book-card {
  position: relative;
  margin: -74rpx 28rpx 0;
  padding: 24rpx;
  border-radius: 24rpx;
  background: #ffffff;
  border: 1rpx solid rgba(24, 35, 49, 0.08);
  box-shadow: 0 18rpx 42rpx rgba(54, 92, 121, 0.13);
}

.book-main {
  display: flex;
  align-items: flex-start;
  gap: 22rpx;
}

.book-cover-frame {
  flex: none;
  width: 154rpx;
  height: 212rpx;
  padding: 8rpx;
  border-radius: 18rpx;
  background: #ffffff;
  box-shadow: 0 12rpx 28rpx rgba(24, 35, 49, 0.14);
  box-sizing: border-box;
}

.book-cover {
  display: block;
  width: 100%;
  height: 100%;
  border-radius: 12rpx;
}

.book-meta {
  flex: 1;
  min-width: 0;
  padding-top: 2rpx;
}

.book-pills {
  display: flex;
  flex-wrap: wrap;
  gap: 10rpx;
  margin-bottom: 12rpx;
}

.grade-pill,
.press-pill {
  max-width: 100%;
  height: 42rpx;
  padding: 0 16rpx;
  border-radius: 999rpx;
  box-sizing: border-box;
  color: #25605a;
  background: #e8f6f3;
  font-size: 21rpx;
  line-height: 42rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.press-pill {
  color: #5d5b20;
  background: #fff4c8;
}

.book-name {
  display: -webkit-box;
  overflow: hidden;
  -webkit-box-orient: vertical;
  -webkit-line-clamp: 2;
  color: #122f4b;
  font-size: 38rpx;
  font-weight: 800;
  line-height: 50rpx;
}

.book-summary {
  display: block;
  margin-top: 14rpx;
  color: #667587;
  font-size: 23rpx;
  line-height: 34rpx;
}

.stat-grid {
  display: flex;
  gap: 12rpx;
  margin-top: 24rpx;
}

.stat-item {
  flex: 1;
  min-width: 0;
  padding: 18rpx 10rpx;
  border-radius: 18rpx;
  background: #f5f8fb;
  text-align: center;
}

.stat-value {
  display: block;
  color: #123b63;
  font-size: 34rpx;
  font-weight: 800;
  line-height: 42rpx;
  font-variant-numeric: tabular-nums;
}

.stat-caption {
  display: flex;
  align-items: baseline;
  justify-content: center;
  gap: 4rpx;
  margin-top: 4rpx;
}

.stat-unit,
.stat-label {
  color: #7a8798;
  font-size: 20rpx;
  line-height: 30rpx;
}

.section {
  margin: 32rpx 28rpx 0;
}

.section-head {
  display: flex;
  align-items: flex-end;
  justify-content: space-between;
  gap: 20rpx;
  margin-bottom: 18rpx;
}

.section-title {
  flex: none;
  color: #122f4b;
  font-size: 32rpx;
  font-weight: 800;
  line-height: 44rpx;
}

.section-note {
  flex: 1;
  color: #8794a5;
  font-size: 21rpx;
  line-height: 30rpx;
  text-align: right;
}

.scope-list,
.feature-list,
.timeline,
.package-list {
  display: flex;
  flex-direction: column;
  gap: 14rpx;
}

.scope-row {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 20rpx;
  padding: 22rpx 24rpx;
  border-radius: 18rpx;
  background: #ffffff;
  border: 1rpx solid rgba(24, 35, 49, 0.07);
}

.scope-label {
  flex: none;
  color: #7a8798;
  font-size: 24rpx;
  line-height: 34rpx;
}

.scope-value {
  flex: 1;
  color: #24354a;
  font-size: 24rpx;
  line-height: 34rpx;
  text-align: right;
}

.scope-tags {
  flex: 1;
  display: flex;
  flex-wrap: wrap;
  justify-content: flex-end;
  gap: 8rpx;
}

.scope-tag {
  padding: 0 14rpx;
  border-radius: 999rpx;
  color: #25605a;
  background: #e8f6f3;
  font-size: 22rpx;
  line-height: 36rpx;
}

.feature-item {
  display: flex;
  align-items: flex-start;
  gap: 18rpx;
  padding: 22rpx 24rpx;
  border-radius: 18rpx;
  background: #ffffff;
  border: 1rpx solid rgba(24, 35, 49, 0.07);
}

.feature-mark {
  flex: none;
  width: 48rpx;
  height: 48rpx;
  border-radius: 14rpx;
  background: #dceeff;
  color: #1d5f95;
  font-size: 24rpx;
  font-weight: 800;
  line-height: 48rpx;
  text-align: center;
}

.feature-item:nth-child(2) .feature-mark {
  background: #e7f7e8;
  color: #2f7a39;
}

.feature-item:nth-child(3) .feature-mark {
  background: #fff0d5;
  color: #9d6414;
}

.feature-item:nth-child(4) .feature-mark {
  background: #ffe7e2;
  color: #a84b3b;
}

.feature-copy {
  flex: 1;
  min-width: 0;
}

.feature-title,
.timeline-title {
  display: block;
  color: #1f344d;
  font-size: 27rpx;
  font-weight: 700;
  line-height: 38rpx;
}

.feature-desc,
.timeline-desc {
  display: block;
  margin-top: 4rpx;
  color: #6f7e90;
  font-size: 23rpx;
  line-height: 34rpx;
}

.timeline {
  position: relative;
}

.timeline-item {
  display: flex;
  align-items: flex-start;
  gap: 18rpx;
  padding: 22rpx 24rpx;
  border-radius: 18rpx;
  background: #ffffff;
  border: 1rpx solid rgba(24, 35, 49, 0.07);
}

.timeline-index {
  flex: none;
  width: 46rpx;
  height: 46rpx;
  border-radius: 50%;
  background: #123b63;
  color: #ffffff;
  font-size: 23rpx;
  font-weight: 800;
  line-height: 46rpx;
  text-align: center;
}

.timeline-copy {
  flex: 1;
  min-width: 0;
}

.package-list {
  gap: 16rpx;
}

.package-card {
  padding: 24rpx;
  border-radius: 20rpx;
  background: #ffffff;
  border: 2rpx solid rgba(24, 35, 49, 0.08);
}

.package-card-active {
  border-color: #3fbf7f;
  background: #f1fbf6;
}

.package-top {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
}

.package-name {
  color: #1f344d;
  font-size: 28rpx;
  font-weight: 800;
  line-height: 40rpx;
}

.package-tag {
  flex: none;
  padding: 0 14rpx;
  border-radius: 999rpx;
  background: #ff7f50;
  color: #ffffff;
  font-size: 20rpx;
  font-weight: 700;
  line-height: 34rpx;
}

.package-price {
  display: flex;
  align-items: baseline;
  margin-top: 10rpx;
}

.package-currency {
  color: #ff7f50;
  font-size: 24rpx;
  font-weight: 800;
  line-height: 32rpx;
}

.package-amount {
  color: #ff7f50;
  font-size: 42rpx;
  font-weight: 800;
  line-height: 50rpx;
}

.package-summary {
  display: block;
  margin-top: 6rpx;
  color: #6f7e90;
  font-size: 23rpx;
  line-height: 34rpx;
}

.intro-text {
  display: block;
  padding: 24rpx;
  border-radius: 18rpx;
  background: #ffffff;
  border: 1rpx solid rgba(24, 35, 49, 0.07);
  color: #59677d;
  font-size: 26rpx;
  line-height: 42rpx;
}

.purchase-bar {
  flex: none;
  z-index: 10;
  box-sizing: border-box;
  display: flex;
  align-items: center;
  gap: 24rpx;
  padding: 18rpx 29rpx;
  border-top: 1rpx solid rgba(24, 35, 49, 0.1);
  background: rgba(251, 252, 255, 0.98);
  box-shadow: 0 -10rpx 30rpx rgba(24, 35, 49, 0.06);
}

.purchase-price {
  flex: none;
  display: flex;
  flex-direction: column;
  justify-content: center;
}

.purchase-price-row {
  display: flex;
  align-items: baseline;
}

.purchase-currency {
  color: #ff7f50;
  font-size: 26rpx;
  font-weight: 800;
  line-height: 34rpx;
}

.purchase-amount {
  margin-left: 2rpx;
  color: #ff7f50;
  font-size: 44rpx;
  font-weight: 800;
  line-height: 52rpx;
  font-variant-numeric: tabular-nums;
}

.purchase-from {
  margin-left: 6rpx;
  color: #9d6414;
  font-size: 22rpx;
  font-weight: 600;
  line-height: 30rpx;
}

.purchase-price-note {
  margin-top: 2rpx;
  color: #8794a5;
  font-size: 20rpx;
  line-height: 28rpx;
}

.purchase-button {
  height: 88rpx;
  border-radius: 999rpx;
  background: #111318;
  color: #ffffff;
  font-size: 32rpx;
  font-weight: 800;
  line-height: 88rpx;
  text-align: center;
  box-shadow: 0 8rpx 18rpx rgba(17, 19, 24, 0.18);
}

.purchase-button-buy {
  flex: 1;
  background: #123b63;
  box-shadow: 0 8rpx 18rpx rgba(18, 59, 99, 0.22);
}

.purchase-button-owned {
  flex: 1;
  background: rgba(63, 191, 127, 0.14);
  color: #248a58;
  box-shadow: none;
}

.purchase-button:active {
  opacity: 0.88;
}

.purchase-button-owned:active {
  opacity: 1;
}

.sku-mask {
  position: fixed;
  left: 0;
  right: 0;
  top: 0;
  bottom: 0;
  z-index: 200;
  display: flex;
  align-items: flex-end;
  justify-content: center;
  background: rgba(16, 24, 40, 0.52);
}

.sku-sheet {
  width: 100%;
  max-height: 82vh;
  padding-bottom: env(safe-area-inset-bottom);
  border-radius: 34rpx 34rpx 0 0;
  background: #ffffff;
  box-shadow: 0 -16rpx 48rpx rgba(23, 64, 111, 0.14);
  animation: sku-slide-up 0.26s cubic-bezier(0.22, 1, 0.36, 1);
}

@keyframes sku-slide-up {
  0% {
    transform: translateY(100%);
    opacity: 0.92;
  }
  100% {
    transform: translateY(0);
    opacity: 1;
  }
}

.sku-handle {
  width: 72rpx;
  height: 8rpx;
  margin: 16rpx auto 0;
  border-radius: 999rpx;
  background: rgba(24, 35, 49, 0.12);
}

.sku-book {
  display: flex;
  align-items: flex-start;
  gap: 22rpx;
  padding: 24rpx 32rpx 20rpx;
  border-bottom: 1rpx solid rgba(24, 35, 49, 0.08);
}

.sku-cover {
  width: 96rpx;
  height: 128rpx;
  border-radius: 12rpx;
  flex: none;
  box-shadow: 0 8rpx 18rpx rgba(24, 35, 49, 0.12);
}

.sku-book-meta {
  flex: 1;
  min-width: 0;
}

.sku-book-name {
  display: block;
  color: #122f4b;
  font-size: 28rpx;
  font-weight: 800;
  line-height: 40rpx;
}

.sku-book-stats {
  display: block;
  margin-top: 10rpx;
  color: #6f7e90;
  font-size: 22rpx;
  line-height: 32rpx;
}

.sku-book-press {
  display: block;
  margin-top: 8rpx;
  color: #8794a5;
  font-size: 20rpx;
  line-height: 30rpx;
}

.sku-title {
  padding: 24rpx 32rpx 16rpx;
  color: #122f4b;
  font-size: 28rpx;
  font-weight: 800;
  line-height: 40rpx;
}

.sku-options {
  display: flex;
  gap: 18rpx;
  padding: 0 32rpx;
}

.sku-option {
  position: relative;
  flex: 1;
  min-width: 0;
  padding: 22rpx 18rpx;
  border-radius: 20rpx;
  border: 2rpx solid rgba(24, 35, 49, 0.1);
  background: #ffffff;
}

.sku-option-active {
  border-color: #3fbf7f;
  background: #f1fbf6;
  box-shadow: 0 10rpx 28rpx rgba(63, 191, 127, 0.12);
}

.sku-badge {
  position: absolute;
  top: -2rpx;
  right: 14rpx;
  padding: 4rpx 12rpx;
  border-radius: 0 0 10rpx 10rpx;
  background: #ff7f50;
  color: #ffffff;
  font-size: 18rpx;
  font-weight: 700;
  line-height: 26rpx;
}

.sku-option-name {
  display: block;
  color: #1f344d;
  font-size: 26rpx;
  font-weight: 800;
  line-height: 38rpx;
}

.sku-option-price-row {
  display: flex;
  align-items: baseline;
  margin-top: 10rpx;
}

.sku-option-currency {
  color: #ff7f50;
  font-size: 22rpx;
  font-weight: 800;
  line-height: 30rpx;
}

.sku-option-price {
  margin-left: 2rpx;
  color: #ff7f50;
  font-size: 40rpx;
  font-weight: 800;
  line-height: 48rpx;
  font-variant-numeric: tabular-nums;
}

.sku-option-desc {
  display: block;
  margin-top: 8rpx;
  color: #6f7e90;
  font-size: 20rpx;
  line-height: 30rpx;
}

.sku-includes {
  margin: 24rpx 32rpx 0;
  padding: 20rpx 22rpx;
  border-radius: 20rpx;
  background: #f6f8fb;
  border: 1rpx solid rgba(24, 35, 49, 0.08);
}

.sku-includes-title {
  margin-bottom: 14rpx;
  color: #122f4b;
  font-size: 24rpx;
  font-weight: 700;
  line-height: 34rpx;
}

.sku-includes-item {
  display: flex;
  align-items: flex-start;
  gap: 10rpx;
  margin-top: 10rpx;
}

.sku-check {
  flex: none;
  width: 28rpx;
  color: #3fbf7f;
  font-size: 22rpx;
  font-weight: 800;
  line-height: 32rpx;
  text-align: center;
}

.sku-includes-text {
  flex: 1;
  color: #59677d;
  font-size: 22rpx;
  line-height: 32rpx;
}

.sku-actions {
  padding: 24rpx 32rpx 28rpx;
}

.sku-confirm {
  height: 88rpx;
  border-radius: 999rpx;
  background: #123b63;
  color: #ffffff;
  font-size: 32rpx;
  font-weight: 800;
  line-height: 88rpx;
  text-align: center;
  box-shadow: 0 8rpx 18rpx rgba(18, 59, 99, 0.22);
}

.sku-confirm:active {
  opacity: 0.9;
}
