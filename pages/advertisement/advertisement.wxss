.page {
  height: 100%;
  min-height: 100vh;
  background: #ffffff;
  color: #17324f;
  font-family: PingFangSC-Regular, PingFang SC;
}

.title-box {
  position: relative;
  background: #ffffff;
  border-bottom: 1rpx solid #edf1ee;
}

.nav-title {
  margin-right: 84rpx;
  color: #17324f;
  font-size: 36rpx;
  font-weight: 600;
  line-height: 56px;
  text-align: center;
  flex: 1;
}

.content {
  background: linear-gradient(180deg, #ffffff 0%, #fffdf8 100%);
}

.hero {
  display: flex;
  align-items: center;
  padding: 44rpx 48rpx 28rpx;
}

.book-cover {
  width: 164rpx;
  height: 230rpx;
  border-radius: 10rpx;
  flex: none;
  box-shadow: 0 18rpx 32rpx rgba(71, 110, 74, 0.12);
}

.book-detail {
  min-width: 0;
  margin-left: 42rpx;
  flex: 1;
}

.book-name {
  display: block;
  color: #17324f;
  font-size: 36rpx;
  font-weight: 600;
  line-height: 52rpx;
}

.press-row {
  display: flex;
  align-items: center;
  margin-top: 28rpx;
}

.press-icon {
  width: 28rpx;
  height: 28rpx;
  opacity: 0.68;
}

.press-name {
  margin-left: 12rpx;
  color: #68736b;
  font-size: 25rpx;
}

.stats {
  display: flex;
  margin: 0 48rpx;
  padding: 28rpx 0;
  border-top: 1rpx solid #e4edf7;
  border-bottom: 1rpx solid #e4edf7;
}

.stat {
  position: relative;
  display: flex;
  align-items: baseline;
  justify-content: center;
  flex-wrap: wrap;
  width: 33.333%;
}

.stat + .stat::before {
  position: absolute;
  top: 8rpx;
  bottom: 8rpx;
  left: 0;
  width: 1rpx;
  background: #e4edf7;
  content: "";
}

.stat-number {
  color: #2f80ed;
  font-size: 42rpx;
  font-weight: 500;
  line-height: 48rpx;
}

.stat-unit {
  margin-left: 5rpx;
  color: #2f80ed;
  font-size: 20rpx;
}

.stat-label {
  width: 100%;
  margin-top: 7rpx;
  color: #7d8799;
  font-size: 21rpx;
  text-align: center;
}

.intro-card {
  margin: 28rpx 48rpx 44rpx;
  padding: 25rpx 28rpx;
  border: 1rpx solid #d8e8fb;
  border-radius: 12rpx;
  background: linear-gradient(135deg, #fffdf8, #f3f8ff);
  color: #59677d;
  font-size: 24rpx;
  line-height: 39rpx;
}

.section {
  margin: 0 48rpx 46rpx;
}

.section-title {
  display: flex;
  align-items: center;
  margin-bottom: 25rpx;
  color: #17324f;
  font-size: 30rpx;
  font-weight: 600;
}

.title-mark {
  width: 7rpx;
  height: 34rpx;
  margin-right: 15rpx;
  border-radius: 8rpx;
  background: #2f80ed;
  flex: none;
}

.title-line {
  height: 1rpx;
  margin-left: 18rpx;
  background: #d8e8fb;
  flex: 1;
}

.learning-grid {
  display: flex;
  justify-content: space-between;
}

.learning-item {
  display: flex;
  align-items: center;
  width: 23%;
  text-align: center;
  flex-direction: column;
}

.learning-badge {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 68rpx;
  height: 68rpx;
  border: 2rpx solid #2f80ed;
  border-radius: 22rpx;
  color: #2f80ed;
  font-size: 22rpx;
  font-weight: 600;
  box-shadow: 0 8rpx 20rpx rgba(47, 128, 237, 0.08);
}

.learning-title {
  margin-top: 17rpx;
  color: #17324f;
  font-size: 21rpx;
  font-weight: 500;
  line-height: 31rpx;
}

.learning-copy {
  margin-top: 7rpx;
  color: #929bad;
  font-size: 18rpx;
  line-height: 28rpx;
}

.feature-list {
  padding: 0 25rpx;
  border: 1rpx solid #d8e8fb;
  border-radius: 14rpx;
  background: #ffffff;
  box-shadow: 0 10rpx 32rpx rgba(72, 102, 135, 0.04);
}

.feature-item {
  display: flex;
  align-items: center;
  padding: 27rpx 4rpx;
}

.feature-item + .feature-item {
  border-top: 1rpx solid #e4edf7;
}

.feature-number {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 68rpx;
  height: 68rpx;
  border-radius: 50%;
  background: #eaf4ff;
  color: #2f80ed;
  font-size: 20rpx;
  font-weight: 600;
  flex: none;
}

.feature-content {
  min-width: 0;
  margin-left: 25rpx;
  flex: 1;
}

.feature-title {
  display: block;
  color: #17324f;
  font-size: 27rpx;
  font-weight: 600;
  line-height: 38rpx;
}

.feature-copy {
  display: block;
  margin-top: 8rpx;
  color: #748096;
  font-size: 20rpx;
  line-height: 31rpx;
}

.steps {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
}

.step {
  display: flex;
  align-items: center;
  width: 21%;
  flex-direction: column;
}

.step-number {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 64rpx;
  height: 64rpx;
  border: 1rpx solid #cfe5ff;
  border-radius: 50%;
  background: #ffffff;
  color: #2f80ed;
  font-size: 26rpx;
  font-weight: 600;
  box-shadow: 0 8rpx 20rpx rgba(47, 128, 237, 0.07);
}

.step-title {
  margin-top: 14rpx;
  color: #17324f;
  font-size: 21rpx;
  font-weight: 600;
  text-align: center;
}

.step-copy {
  margin-top: 7rpx;
  color: #929bad;
  font-size: 18rpx;
  text-align: center;
}

.step-arrow {
  margin-top: 20rpx;
  color: #c7d9ec;
  font-size: 38rpx;
  line-height: 38rpx;
}

.goal-list,
.unlock-list {
  display: flex;
  justify-content: space-between;
}

.goal-item {
  box-sizing: border-box;
  width: 31.5%;
  padding: 24rpx 12rpx;
  border: 1rpx solid #d8e8fb;
  border-radius: 10rpx;
  background: #ffffff;
  color: #2f4938;
  font-size: 20rpx;
  line-height: 30rpx;
  text-align: center;
}

.unlock-section {
  margin-bottom: 20rpx;
}

.unlock-item {
  box-sizing: border-box;
  display: flex;
  justify-content: center;
  width: 31.5%;
  min-height: 104rpx;
  padding: 20rpx 10rpx;
  border: 1rpx solid #d8e8fb;
  border-radius: 10rpx;
  background: linear-gradient(180deg, #ffffff, #f8fbf6);
  text-align: center;
  flex-direction: column;
}

.unlock-value {
  color: #2f80ed;
  font-size: 22rpx;
  font-weight: 600;
}

.unlock-label {
  margin-top: 8rpx;
  color: #52617a;
  font-size: 19rpx;
  line-height: 27rpx;
}

.purchase-bar {
  position: fixed;
  right: 0;
  bottom: 0;
  left: 0;
  z-index: 10;
  box-sizing: border-box;
  padding: 18rpx 48rpx;
  border-top: 1rpx solid #e4edf7;
  background: rgba(255, 255, 255, 0.97);
  box-shadow: 0 -10rpx 30rpx rgba(72, 102, 135, 0.06);
}

.purchase-button {
  height: 88rpx;
  border-radius: 12rpx;
  background: linear-gradient(135deg, #5aa7ff, #2f80ed);
  color: #ffffff;
  font-size: 34rpx;
  font-weight: 600;
  line-height: 88rpx;
  text-align: center;
  box-shadow: 0 12rpx 24rpx rgba(47, 128, 237, 0.22);
}

.purchase-button:active {
  opacity: 0.88;
}
