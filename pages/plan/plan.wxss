page {
  height: 100%;
  background: #fffdf8;
  color: #101010;
}

.plan-page {
  position: relative;
  height: 100%;
  overflow: hidden;
  display: flex;
  flex-direction: column;
  background: #fffdf8;
  font-family: PingFang SC, PingFangSC-Regular, sans-serif;
}

.plan-nav-title-wrap {
  position: absolute;
  left: 0;
  right: 0;
  top: 0;
  bottom: 0;
  display: flex;
  align-items: center;
  justify-content: center;
  pointer-events: none;
}

.plan-nav-title {
  font-size: 32rpx;
  font-weight: 700;
  color: #101010;
}

/* 滚动区 */
.plan-scroll {
  flex: 1;
  min-height: 0;
  padding: 0 29rpx;
  box-sizing: border-box;
}

/* 教材概览 */
.book-card {
  margin-top: 16rpx;
  padding: 22rpx 25rpx;
  display: flex;
  align-items: center;
  background: #ffffff;
  border-radius: 27rpx;
  box-shadow: 0 8rpx 18rpx rgba(115, 91, 45, 0.06);
}

.book-cover {
  flex: none;
  width: 120rpx;
  height: 168rpx;
  border-radius: 12rpx;
  background: #f2f2f2;
  box-shadow: 0 6rpx 8rpx rgba(169, 118, 14, 0.16);
}

.book-info {
  flex: 1;
  min-width: 0;
  margin-left: 28rpx;
}

.book-name {
  font-size: 28rpx;
  line-height: 38rpx;
  font-weight: 700;
}

.book-total {
  margin-top: 16rpx;
  font-size: 23rpx;
  color: #555555;
}

.book-total .hl {
  color: #111318;
  font-weight: 700;
}

.book-tip {
  margin-top: 12rpx;
  font-size: 21rpx;
  color: #111318;
}

/* 通用区块 */
.section {
  margin-top: 24rpx;
  padding: 26rpx 25rpx 30rpx;
  background: #ffffff;
  border-radius: 27rpx;
  box-shadow: 0 8rpx 18rpx rgba(115, 91, 45, 0.055);
}

.section-title {
  font-size: 27rpx;
  font-weight: 700;
}

/* 每日数量 */
.daily-display {
  margin-top: 26rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.stepper {
  flex: none;
  width: 76rpx;
  height: 76rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 46rpx;
  font-weight: 600;
  color: #111318;
  background: #e8f1fe;
  border-radius: 50%;
}

.stepper-off {
  color: #cccccc;
  background: #f3f3f3;
}

.daily-num {
  flex: 1;
  text-align: center;
}

.daily-num .num {
  font-size: 76rpx;
  line-height: 80rpx;
  font-weight: 800;
  color: #101010;
}

.daily-num .unit {
  margin-left: 8rpx;
  font-size: 24rpx;
  color: #888888;
}

.daily-hint {
  margin-top: 16rpx;
  text-align: center;
  font-size: 24rpx;
  color: #888888;
}

.daily-hint .hl {
  color: #111318;
  font-weight: 600;
}

.daily-slider {
  margin: 28rpx 8rpx 0;
}

.slider-scale {
  display: flex;
  justify-content: space-between;
  padding: 0 8rpx;
  font-size: 20rpx;
  color: #aaaaaa;
}

/* 预设 */
.presets {
  margin-top: 26rpx;
  display: flex;
  gap: 16rpx;
}

.preset {
  flex: 1;
  padding: 14rpx 0;
  text-align: center;
  background: #fafafa;
  border: 1rpx solid #eeeeee;
  border-radius: 18rpx;
}

.preset-active {
  background: linear-gradient(180deg, #f2f3f5, #e6e8ec);
  border-color: #111318;
}

.preset-label {
  font-size: 23rpx;
  font-weight: 500;
  color: #333333;
}

.preset-active .preset-label {
  color: #111318;
}

.preset-value {
  margin-top: 6rpx;
  font-size: 20rpx;
  color: #999999;
}

.preset-active .preset-value {
  color: #111318;
}

/* 结果卡片 */
.result-card {
  margin-top: 24rpx;
  padding: 30rpx 0;
  display: flex;
  align-items: center;
  background: linear-gradient(135deg, #ffffff, #f4f5f7);
  border: 1rpx solid #e2e4e8;
  border-radius: 27rpx;
  box-shadow: 0 8rpx 18rpx rgba(17, 19, 24, 0.06);
}

.result-item {
  flex: 1;
  text-align: center;
}

.result-num {
  font-size: 50rpx;
  line-height: 56rpx;
  font-weight: 800;
  color: #111318;
}

.result-label {
  margin-top: 8rpx;
  font-size: 22rpx;
  color: #777777;
}

.result-divider {
  width: 1rpx;
  height: 56rpx;
  background: #dbe8fb;
}

/* 关卡预览 */
.level-list {
  margin-top: 20rpx;
}

.level-row {
  display: flex;
  align-items: center;
  padding: 18rpx 0;
  border-bottom: 1rpx solid #f3f3f3;
}

.level-badge {
  flex: none;
  width: 52rpx;
  height: 52rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 25rpx;
  font-weight: 600;
  color: #ffffff;
  background: #111318;
  border-radius: 50%;
}

.level-info {
  flex: 1;
  min-width: 0;
  margin-left: 22rpx;
}

.level-name {
  font-size: 25rpx;
  font-weight: 600;
}

.level-range {
  margin-top: 5rpx;
  font-size: 21rpx;
  color: #999999;
}

.level-count {
  flex: none;
  font-size: 23rpx;
  font-weight: 500;
  color: #111318;
}

.level-more {
  padding: 22rpx 0 4rpx;
  text-align: center;
  font-size: 22rpx;
  color: #aaaaaa;
}

.scroll-spacer {
  height: 180rpx;
}

/* 底部保存 */
.footer {
  flex-shrink: 0;
  padding: 16rpx 29rpx 16rpx;
  background: rgba(255, 253, 248, 0.96);
  box-shadow: 0 -6rpx 16rpx rgba(115, 91, 45, 0.06);
}

.save-btn {
  height: 92rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 30rpx;
  font-weight: 700;
  color: #ffffff;
  background: #111318;
  border-radius: 999rpx;
  box-shadow: 0 8rpx 18rpx rgba(17, 19, 24, 0.18);
}
