<view class="sub-page">
  <navigation background="#fffdf8">
    <view class="nav-title">我的教材</view>
  </navigation>

  <scroll-view class="sub-scroll" scroll-y enhanced show-scrollbar="{{false}}">
    <view wx:if="{{loading}}" class="state-card">正在读取教材...</view>
    <view wx:elif="{{empty}}" class="state-card">
      <view class="state-title">还没有教材</view>
      <view class="state-copy">购买后的教材会在这里显示。</view>
    </view>

    <block wx:else>
      <view class="library-summary">
        <view class="summary-copy">
          <view class="summary-kicker">教材库</view>
          <view class="summary-title">我的教材</view>
          <view class="summary-label">
            <text class="book-count">{{summary.bookCount}}</text>
            <text> 本已购买教材</text>
          </view>
        </view>
        <view class="summary-action" bindtap="continueStudy">继续学习</view>
      </view>

      <view class="section-head-out">
        <view class="section-title-out">已购买</view>
        <view class="section-note">共 {{summary.bookCount}} 本</view>
      </view>
      <view class="book-list">
        <view wx:for="{{books}}" wx:key="resBookId" class="book-row-card {{item.current ? 'book-row-current' : ''}}">
          <image class="row-cover" src="{{item.bookCover}}" mode="aspectFill" />
          <view class="row-copy">
            <view class="row-title">{{item.name}}</view>
            <view class="row-meta">{{item.press}} · {{item.totalWords}} 词</view>
            <view class="row-desc">已学 {{item.learnedWords}} · 进度 {{item.percent}}%</view>
            <view class="row-progress">
              <view class="row-progress-fill" style="{{item.progressStyle}}"></view>
            </view>
          </view>
          <view class="row-side">
            <view
              class="row-action {{item.current ? 'row-action-current' : ''}}"
              data-res-book-id="{{item.resBookId}}"
              bindtap="switchBook"
            >
              {{item.current ? '当前' : '切换'}}
            </view>
            <view
              class="row-link"
              data-res-book-id="{{item.resBookId}}"
              bindtap="openCatalogue"
            >目录</view>
          </view>
        </view>
      </view>
    </block>

    <view class="scroll-spacer"></view>
  </scroll-view>
</view>
