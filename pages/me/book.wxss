page {
  height: 100%;
  background: #fbfaf5;
  color: #101010;
}

.sub-page {
  height: 100%;
  overflow: hidden;
  display: flex;
  flex-direction: column;
  background: #fbfaf5;
  font-family: PingFang SC, PingFangSC-Regular, sans-serif;
}

.nav-title {
  width: 100%;
  text-align: center;
  font-size: 32rpx;
  font-weight: 700;
}

.sub-scroll {
  flex: 1;
  min-height: 0;
  box-sizing: border-box;
  padding: 18rpx 31rpx 0;
}

.state-card {
  padding: 56rpx 30rpx;
  color: #8b9098;
  font-size: 26rpx;
  text-align: center;
  background: #ffffff;
  border: 1rpx solid rgba(240, 237, 229, 0.95);
  border-radius: 24rpx;
  box-shadow: 0 10rpx 24rpx rgba(47, 96, 150, 0.045);
}

.state-title {
  color: #111318;
  font-size: 30rpx;
  font-weight: 700;
}

.state-copy {
  margin-top: 10rpx;
  font-size: 24rpx;
}

.library-summary {
  min-height: 164rpx;
  padding: 28rpx 30rpx;
  box-sizing: border-box;
  display: flex;
  align-items: center;
  justify-content: space-between;
  background: linear-gradient(135deg, #f4fff6 0%, #fff7e8 100%);
  border: 1rpx solid rgba(224, 235, 215, 0.95);
  border-radius: 26rpx;
  box-shadow: 0 14rpx 30rpx rgba(88, 111, 86, 0.08);
}

.summary-copy {
  min-width: 0;
}

.summary-kicker {
  color: #24aa66;
  font-size: 22rpx;
  line-height: 28rpx;
  font-weight: 800;
}

.summary-title {
  margin-top: 6rpx;
  color: #111318;
  font-size: 36rpx;
  line-height: 44rpx;
  font-weight: 800;
}

.summary-label {
  margin-top: 8rpx;
  color: #787f87;
  font-size: 23rpx;
  line-height: 30rpx;
}

.book-count {
  color: #111318;
  font-weight: 800;
}

.summary-action {
  flex: none;
  min-width: 154rpx;
  height: 66rpx;
  padding: 0 28rpx;
  box-sizing: border-box;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #ffffff;
  background: #111318;
  border-radius: 999rpx;
  font-size: 25rpx;
  font-weight: 800;
  box-shadow: 0 10rpx 20rpx rgba(17, 19, 24, 0.12);
}

.section-head-out {
  margin: 34rpx 4rpx 16rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.section-title-out {
  color: #25282d;
  font-size: 27rpx;
  line-height: 34rpx;
  font-weight: 800;
}

.section-note {
  color: #9aa0a8;
  font-size: 22rpx;
  line-height: 30rpx;
}

.book-list {
  display: flex;
  flex-direction: column;
  gap: 18rpx;
}

.book-row-card {
  position: relative;
  min-height: 164rpx;
  padding: 24rpx;
  box-sizing: border-box;
  display: flex;
  align-items: center;
  background: #ffffff;
  border: 1rpx solid rgba(239, 241, 244, 0.95);
  border-radius: 22rpx;
  box-shadow: 0 10rpx 22rpx rgba(47, 96, 150, 0.055);
}

.book-row-current {
  border-color: rgba(36, 170, 102, 0.32);
  box-shadow: 0 12rpx 26rpx rgba(36, 170, 102, 0.08);
}

.book-row-current::before {
  content: '';
  position: absolute;
  top: 24rpx;
  bottom: 24rpx;
  left: 0;
  width: 6rpx;
  background: #24aa66;
  border-radius: 0 999rpx 999rpx 0;
}

.row-cover {
  flex: none;
  width: 84rpx;
  height: 116rpx;
  border-radius: 12rpx;
  background: #f2f2f2;
  box-shadow: 0 8rpx 16rpx rgba(47, 96, 150, 0.13);
}

.row-copy {
  flex: 1;
  min-width: 0;
  margin-left: 24rpx;
  padding-right: 18rpx;
}

.row-title {
  color: #14161a;
  font-size: 29rpx;
  line-height: 37rpx;
  font-weight: 800;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.row-meta,
.row-desc {
  margin-top: 6rpx;
  color: #8b9098;
  font-size: 22rpx;
  line-height: 30rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.row-desc {
  color: #5f6872;
}

.row-progress {
  margin-top: 12rpx;
  width: 100%;
  height: 8rpx;
  overflow: hidden;
  background: #eef0f3;
  border-radius: 999rpx;
}

.row-progress-fill {
  height: 100%;
  min-width: 8rpx;
  background: linear-gradient(90deg, #24aa66, #2f7ff0);
  border-radius: 999rpx;
}

.row-side {
  flex: none;
  width: 88rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.row-action {
  width: 88rpx;
  height: 50rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #ffffff;
  background: #111318;
  border-radius: 28rpx;
  font-size: 23rpx;
  font-weight: 800;
}

.row-action-current {
  color: #24aa66;
  background: #edf9f1;
}

.row-link {
  margin-top: 14rpx;
  color: #7f8790;
  font-size: 21rpx;
  line-height: 28rpx;
}

.scroll-spacer {
  height: 72rpx;
}
