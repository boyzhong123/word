page {
  height: 100%;
  background: #fffdf8;
  color: #101010;
}

.sub-page {
  height: 100%;
  overflow: hidden;
  display: flex;
  flex-direction: column;
  background: #fffdf8;
  font-family: PingFang SC, PingFangSC-Regular, sans-serif;
}

.nav-title {
  width: 100%;
  text-align: center;
  font-size: 32rpx;
  font-weight: 700;
}

.sub-scroll {
  flex: 1;
  min-height: 0;
  box-sizing: border-box;
  padding: 18rpx 31rpx 0;
}

.state-card,
.hero-card,
.section-card,
.book-list {
  background: #ffffff;
  border: 1rpx solid rgba(247, 247, 247, 0.9);
  border-radius: 24rpx;
  box-shadow: 0 8rpx 18rpx rgba(47, 96, 150, 0.045);
}

.state-card {
  padding: 46rpx 30rpx;
  color: #8b9098;
  font-size: 26rpx;
  text-align: center;
}

.state-title {
  color: #111318;
  font-size: 30rpx;
  font-weight: 700;
}

.state-copy {
  margin-top: 10rpx;
  font-size: 24rpx;
}

.hero-card {
  padding: 28rpx;
}

.hero-kicker,
.section-title-out {
  color: #51545c;
  font-size: 24rpx;
  font-weight: 700;
}

.book-main {
  margin-top: 18rpx;
  display: flex;
  align-items: center;
}

.book-cover {
  flex: none;
  width: 128rpx;
  height: 178rpx;
  border-radius: 14rpx;
  background: #f2f2f2;
  box-shadow: 0 8rpx 14rpx rgba(47, 96, 150, 0.12);
}

.book-info {
  flex: 1;
  min-width: 0;
  margin-left: 24rpx;
}

.book-name {
  font-size: 31rpx;
  line-height: 40rpx;
  font-weight: 700;
  color: #111318;
}

.book-meta,
.book-desc {
  margin-top: 10rpx;
  color: #8b9098;
  font-size: 23rpx;
  line-height: 32rpx;
}

.book-desc {
  color: #51545c;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
}

.section-card {
  margin-top: 24rpx;
  padding: 28rpx;
}

.section-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.section-title {
  font-size: 28rpx;
  font-weight: 700;
}

.section-tag {
  color: #2f7ff0;
  font-size: 25rpx;
  font-weight: 700;
}

.progress-bar {
  margin-top: 22rpx;
  height: 16rpx;
  overflow: hidden;
  background: #eef0f3;
  border-radius: 999rpx;
}

.progress-fill {
  height: 100%;
  background: linear-gradient(90deg, #2f7ff0, #24aa66);
  border-radius: 999rpx;
}

.stat-grid {
  margin-top: 28rpx;
  display: flex;
}

.stat-item {
  flex: 1;
  text-align: center;
}

.stat-num {
  font-size: 34rpx;
  line-height: 42rpx;
  font-weight: 800;
}

.stat-label {
  margin-top: 6rpx;
  color: #8b9098;
  font-size: 21rpx;
}

.action-row {
  margin-top: 28rpx;
  display: flex;
  gap: 18rpx;
}

.ghost-btn,
.primary-btn {
  flex: 1;
  height: 72rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 36rpx;
  font-size: 26rpx;
  font-weight: 700;
}

.ghost-btn {
  color: #111318;
  background: #eef0f3;
}

.primary-btn {
  color: #ffffff;
  background: #111318;
}

.section-title-out {
  margin: 32rpx 0 16rpx 4rpx;
}

.book-list {
  overflow: hidden;
}

.book-row {
  position: relative;
  min-height: 124rpx;
  padding: 22rpx 26rpx;
  display: flex;
  align-items: center;
}

.book-row::after {
  content: '';
  position: absolute;
  left: 126rpx;
  right: 0;
  bottom: 0;
  height: 1rpx;
  background: #f2f2f2;
}

.book-row:last-child::after {
  display: none;
}

.row-cover {
  flex: none;
  width: 72rpx;
  height: 96rpx;
  border-radius: 10rpx;
  background: #f2f2f2;
}

.row-copy {
  flex: 1;
  min-width: 0;
  margin-left: 22rpx;
}

.row-title {
  color: #1a1a1a;
  font-size: 27rpx;
  line-height: 36rpx;
  font-weight: 700;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.row-desc {
  margin-top: 6rpx;
  color: #8b9098;
  font-size: 22rpx;
}

.row-action {
  flex: none;
  min-width: 74rpx;
  height: 50rpx;
  padding: 0 18rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #ffffff;
  background: #111318;
  border-radius: 28rpx;
  font-size: 23rpx;
  font-weight: 700;
}

.row-action-current {
  color: #24aa66;
  background: #f1fbf3;
}

.scroll-spacer {
  height: 72rpx;
}
