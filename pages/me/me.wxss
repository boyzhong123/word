page {
  height: 100%;
  background: #fffdf8;
  color: #101010;
}

.me-page {
  position: relative;
  height: 100%;
  overflow: hidden;
  background: #fffdf8;
  font-family: PingFang SC, PingFangSC-Regular, sans-serif;
}

.me-scroll {
  height: 100%;
}

/* ---------- header ---------- */
.profile-header {
  position: relative;
  padding: 0 31rpx 34rpx;
  overflow: hidden;
  border-radius: 0 0 34rpx 34rpx;
}

.profile-header-bg {
  position: absolute;
  z-index: 0;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
}

.profile-main {
  position: relative;
  z-index: 1;
  height: 164rpx;
  display: flex;
  align-items: center;
}

.avatar-wrap {
  flex: none;
}

.avatar {
  width: 108rpx;
  height: 108rpx;
  border-radius: 50%;
  border: 4rpx solid rgba(255, 255, 255, 0.95);
  box-shadow: 0 8rpx 18rpx rgba(23, 64, 111, 0.14);
}

.avatar-empty {
  display: flex;
  align-items: center;
  justify-content: center;
  background: rgba(255, 255, 255, 0.72);
  font-size: 54rpx;
}

.profile-copy {
  flex: 1;
  min-width: 0;
  margin-left: 24rpx;
}

.nickname {
  font-size: 33rpx;
  line-height: 43rpx;
  font-weight: 700;
  color: #17406f;
  text-shadow: 0 4rpx 10rpx rgba(255, 255, 255, 0.72);
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.profile-sub {
  margin-top: 8rpx;
  font-size: 23rpx;
  line-height: 32rpx;
  color: #111318;
  text-shadow: 0 3rpx 8rpx rgba(255, 255, 255, 0.78);
}

/* ---------- stats card ---------- */
.stats-card {
  position: relative;
  z-index: 2;
  height: 124rpx;
  margin: 24rpx 31rpx 0;
  display: flex;
  align-items: center;
  background: #ffffff;
  border: 1rpx solid rgba(247, 247, 247, 0.9);
  border-radius: 24rpx;
  box-shadow: 0 8rpx 18rpx rgba(47, 96, 150, 0.055);
}

.stats-card-clickable:active {
  transform: scale(0.985);
  opacity: 0.92;
}

.stat-item {
  flex: 1;
  text-align: center;
}

.stat-number {
  font-size: 38rpx;
  line-height: 46rpx;
  font-weight: 700;
  color: #101010;
}

.stat-label {
  margin-top: 5rpx;
  font-size: 21rpx;
  line-height: 28rpx;
  color: #8a8a8a;
}

.stat-divider {
  flex: none;
  width: 1rpx;
  height: 54rpx;
  background: #eeeeee;
}

/* ---------- menu ---------- */
.message-section {
  padding: 36rpx 31rpx 0;
}

.menu-section {
  padding: 26rpx 31rpx 0;
}

.menu-section-tight {
  padding-top: 28rpx;
}

.section-title {
  margin: 0 0 17rpx 4rpx;
  color: #51545c;
  font-size: 24rpx;
  line-height: 32rpx;
  font-weight: 700;
}

.menu-group {
  background: #ffffff;
  border: 1rpx solid rgba(247, 247, 247, 0.9);
  border-radius: 24rpx;
  box-shadow: 0 8rpx 18rpx rgba(47, 96, 150, 0.045);
  overflow: hidden;
}

/* ---------- message and official account ---------- */
.message-card {
  background: #ffffff;
  border: 1rpx solid rgba(247, 247, 247, 0.9);
  border-radius: 24rpx;
  box-shadow: 0 8rpx 18rpx rgba(47, 96, 150, 0.045);
  overflow: hidden;
}

.message-row {
  min-height: 112rpx;
  padding: 22rpx 26rpx;
  display: flex;
  align-items: center;
  gap: 20rpx;
}

.message-row-official {
  padding-bottom: 18rpx;
}

.message-row-icon {
  flex: none;
  width: 56rpx;
  height: 56rpx;
  border-radius: 18rpx;
  background-repeat: no-repeat;
  background-position: center;
  background-size: 34rpx 34rpx;
}

.message-row-icon-remind {
  background-color: #f1fbf3;
  background-image: url("data:image/svg+xml;base64,");
}

.message-row-icon-official {
  display: flex;
  align-items: center;
  justify-content: center;
  color: #7a5200;
  font-size: 23rpx;
  font-weight: 800;
  background: #fff4d6;
}

.message-row-copy {
  flex: 1;
  min-width: 0;
}

.message-row-title {
  font-size: 28rpx;
  line-height: 36rpx;
  font-weight: 500;
  color: #1a1a1a;
}

.message-row-desc {
  margin-top: 4rpx;
  font-size: 22rpx;
  line-height: 30rpx;
  color: #8b9098;
}

.message-row-action {
  flex: none;
  height: 52rpx;
  padding: 0 24rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #ffffff;
  font-size: 23rpx;
  font-weight: 700;
  background: #111318;
  border-radius: 28rpx;
}

.message-divider {
  height: 1rpx;
  margin-left: 102rpx;
  background: #f2f2f2;
}

.official-account-wrap {
  margin: 0 26rpx 22rpx;
  overflow: hidden;
  border-radius: 18rpx;
}

.menu-item {
  position: relative;
  height: 112rpx;
  padding: 0 26rpx;
  display: flex;
  align-items: center;
}

.menu-item::after {
  content: '';
  position: absolute;
  left: 106rpx;
  right: 0;
  bottom: 0;
  height: 1rpx;
  background: #f2f2f2;
}

.menu-item:last-child::after {
  display: none;
}

.contact-hit {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  margin: 0;
  padding: 0;
  background: transparent;
  opacity: 0;
}

.contact-hit::after {
  border: none;
}

.menu-icon {
  flex: none;
  width: 56rpx;
  height: 56rpx;
  margin-right: 24rpx;
  border-radius: 18rpx;
  background-repeat: no-repeat;
  background-position: center;
  background-size: 34rpx 34rpx;
}

.menu-ic-book {
  background-color: #e8f1ff;
  background-image: url("data:image/svg+xml;base64,");
}

.menu-ic-notify {
  background-color: #f1fbf3;
  background-image: url("data:image/svg+xml;base64,");
}

.menu-ic-contact {
  background-color: #eef0f3;
  background-image: url("data:image/svg+xml;base64,");
}

.menu-ic-privacy {
  background-color: #eef0f3;
  background-image: url("data:image/svg+xml;base64,");
}

.menu-copy {
  flex: 1;
  min-width: 0;
}

.menu-label {
  font-size: 28rpx;
  line-height: 36rpx;
  font-weight: 500;
  color: #1a1a1a;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.menu-desc {
  margin-top: 4rpx;
  color: #8b9098;
  font-size: 22rpx;
  line-height: 30rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.menu-arrow {
  flex: none;
  color: #c4c4c4;
  font-size: 38rpx;
  line-height: 38rpx;
}

.scroll-spacer {
  height: calc(102rpx + 36rpx + env(safe-area-inset-bottom));
}
