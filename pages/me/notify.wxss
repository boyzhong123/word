page {
  height: 100%;
  background: #fffdf8;
  color: #101010;
}

.sub-page {
  height: 100%;
  overflow: hidden;
  display: flex;
  flex-direction: column;
  background: #fffdf8;
  font-family: PingFang SC, PingFangSC-Regular, sans-serif;
}

.nav-title {
  width: 100%;
  text-align: center;
  font-size: 32rpx;
  font-weight: 700;
}

.sub-scroll {
  flex: 1;
  min-height: 0;
  box-sizing: border-box;
  padding: 18rpx 31rpx 0;
}

.status-card,
.section-card,
.tip-card {
  background: #ffffff;
  border: 1rpx solid rgba(247, 247, 247, 0.9);
  border-radius: 24rpx;
  box-shadow: 0 8rpx 18rpx rgba(47, 96, 150, 0.045);
}

.status-card {
  min-height: 128rpx;
  padding: 26rpx;
  display: flex;
  align-items: center;
}

.status-icon {
  flex: none;
  width: 62rpx;
  height: 62rpx;
  border-radius: 20rpx;
  background-color: #f1fbf3;
  background-repeat: no-repeat;
  background-position: center;
  background-size: 36rpx 36rpx;
}

.status-icon-bell {
  background-image: url("data:image/svg+xml;base64,");
}

.status-copy {
  flex: 1;
  min-width: 0;
  margin-left: 22rpx;
}

.status-title,
.section-title,
.tip-title {
  color: #111318;
  font-size: 29rpx;
  line-height: 38rpx;
  font-weight: 700;
}

.status-desc,
.section-desc,
.tip-line {
  margin-top: 6rpx;
  color: #8b9098;
  font-size: 23rpx;
  line-height: 32rpx;
}

.status-pill {
  flex: none;
  height: 52rpx;
  padding: 0 20rpx;
  display: flex;
  align-items: center;
  color: #24aa66;
  background: #f1fbf3;
  border-radius: 28rpx;
  font-size: 23rpx;
  font-weight: 700;
}

.section-card,
.tip-card {
  margin-top: 24rpx;
  padding: 28rpx;
}

.section-head {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 24rpx;
}

.switch-state {
  flex: none;
  color: #51545c;
  font-size: 23rpx;
  font-weight: 700;
}

.primary-btn,
.ghost-btn {
  height: 76rpx;
  margin-top: 24rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 38rpx;
  font-size: 26rpx;
  font-weight: 700;
}

.primary-btn {
  color: #ffffff;
  background: #111318;
}

.primary-btn-disabled {
  color: #8b9098;
  background: #eef0f3;
}

.ghost-btn {
  color: #111318;
  background: #eef0f3;
}

.section-desc-wide {
  margin-top: 10rpx;
}

.official-wrap {
  margin-top: 22rpx;
  overflow: hidden;
  border-radius: 18rpx;
}

.scroll-spacer {
  height: 72rpx;
}
