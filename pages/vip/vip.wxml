<view class="page">
  <navigation class="title-box" background="#fffdf8">
    <view class="vip-nav-title-wrap">
      <view class="vip-nav-title">确认订单</view>
    </view>
  </navigation>

  <view class="content">
    <!-- 商品信息 -->
    <view class="order-card">
      <view class="order-book">
        <image class="order-cover" src="{{bookCover}}" mode="aspectFill" />
        <view class="order-book-meta">
          <text class="order-book-name">{{name}}</text>
          <text wx:if="{{press}}" class="order-book-press">{{press}}</text>
          <view class="order-package-pill">{{packageName}}</view>
        </view>
        <view class="order-price-col">
          <text class="order-price-currency">¥</text>
          <text class="order-price-value">{{price}}</text>
        </view>
      </view>
    </view>

    <!-- 订单明细 -->
    <view class="order-card">
      <view class="order-row">
        <text class="order-row-label">套餐</text>
        <text class="order-row-value">{{packageName}}</text>
      </view>
      <view class="order-row">
        <text class="order-row-label">有效期</text>
        <text class="order-row-value">长期有效</text>
      </view>
      <view class="order-row">
        <text class="order-row-label">支付方式</text>
        <text class="order-row-value">微信支付</text>
      </view>
      <view class="order-divider"></view>
      <view class="order-row">
        <text class="order-row-label">合计</text>
        <view class="order-total">
          <text class="order-total-currency">¥</text>
          <text class="order-total-value">{{price}}</text>
        </view>
      </view>
    </view>

    <view class="order-tip">
      <text class="order-tip-text">当前为测试环境，支付流程为模拟操作，不会产生真实扣款。</text>
    </view>
  </view>

  <view class="pay-bar" style="padding-bottom: {{safeAreaBottom}}px;">
    <view class="pay-amount">
      <text class="pay-amount-label">合计</text>
      <text class="pay-amount-currency">¥</text>
      <text class="pay-amount-value">{{price}}</text>
    </view>
    <view wx:if="{{paid}}" class="pay-button pay-button-paid">已支付</view>
    <view wx:else class="pay-button" bindtap="pay">立即支付</view>
  </view>
</view>
