page {
  height: 100%;
  background: #fffdf8;
  color: #101010;
}

.page {
  height: 100%;
  display: flex;
  flex-direction: column;
  overflow: hidden;
  background: #fffdf8;
  color: #17406f;
  font-family: PingFang SC, PingFangSC-Regular, sans-serif;
}

.title-box {
  position: relative;
  flex: none;
  background: #fffdf8;
  border-bottom: 1rpx solid rgba(17, 19, 24, 0.12);
}

.vip-nav-title-wrap {
  position: absolute;
  left: 0;
  right: 0;
  top: 0;
  bottom: 0;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 0 120rpx;
  box-sizing: border-box;
  pointer-events: none;
}

.vip-nav-title {
  color: #0f3559;
  font-size: 32rpx;
  font-weight: 700;
  line-height: 44rpx;
}

.content {
  flex: 1;
  min-height: 0;
  overflow-y: auto;
}

.order-card {
  margin: 20rpx 29rpx 0;
  padding: 26rpx 25rpx;
  border-radius: 29rpx;
  background: #ffffff;
  border: 1rpx solid rgba(17, 19, 24, 0.14);
  box-shadow: 0 8rpx 18rpx rgba(17, 19, 24, 0.05);
}

.order-book {
  display: flex;
  align-items: flex-start;
  gap: 24rpx;
}

.order-cover {
  width: 120rpx;
  height: 168rpx;
  border-radius: 12rpx;
  flex: none;
  box-shadow: 0 8rpx 18rpx rgba(169, 118, 14, 0.16);
}

.order-book-meta {
  flex: 1;
  min-width: 0;
}

.order-book-name {
  display: block;
  color: #17406f;
  font-size: 30rpx;
  font-weight: 700;
  line-height: 42rpx;
}

.order-book-press {
  display: block;
  margin-top: 8rpx;
  color: #9aa3b2;
  font-size: 22rpx;
  line-height: 32rpx;
}

.order-package-pill {
  display: inline-block;
  margin-top: 14rpx;
  padding: 6rpx 18rpx;
  border-radius: 999rpx;
  background: rgba(255, 130, 0, 0.1);
  border: 1rpx solid rgba(255, 130, 0, 0.22);
  color: #b06200;
  font-size: 22rpx;
  line-height: 32rpx;
}

.order-price-col {
  flex: none;
  display: flex;
  align-items: baseline;
}

.order-price-currency {
  color: #ff8200;
  font-size: 24rpx;
  font-weight: 700;
}

.order-price-value {
  margin-left: 2rpx;
  color: #ff8200;
  font-size: 40rpx;
  font-weight: 700;
  font-variant-numeric: tabular-nums;
}

.order-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 14rpx 0;
}

.order-row-label {
  color: #7a8798;
  font-size: 26rpx;
  line-height: 38rpx;
}

.order-row-value {
  color: #17406f;
  font-size: 26rpx;
  font-weight: 500;
  line-height: 38rpx;
}

.order-divider {
  height: 1rpx;
  margin: 10rpx 0;
  background: rgba(17, 19, 24, 0.08);
}

.order-total {
  display: flex;
  align-items: baseline;
}

.order-total-currency {
  color: #ff8200;
  font-size: 24rpx;
  font-weight: 700;
}

.order-total-value {
  margin-left: 2rpx;
  color: #ff8200;
  font-size: 36rpx;
  font-weight: 700;
  font-variant-numeric: tabular-nums;
}

.order-tip {
  margin: 24rpx 29rpx 0;
  padding: 18rpx 22rpx;
  border-radius: 18rpx;
  background: rgba(255, 130, 0, 0.06);
  border: 1rpx dashed rgba(255, 130, 0, 0.3);
}

.order-tip-text {
  color: #b06200;
  font-size: 22rpx;
  line-height: 34rpx;
}

/* 底部支付栏 */
.pay-bar {
  flex: none;
  z-index: 10;
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 24rpx;
  box-sizing: border-box;
  padding: 18rpx 29rpx;
  border-top: 1rpx solid rgba(17, 19, 24, 0.12);
  background: rgba(255, 253, 248, 0.98);
  box-shadow: 0 -10rpx 30rpx rgba(17, 19, 24, 0.06);
}

.pay-amount {
  display: flex;
  align-items: baseline;
  min-width: 0;
}

.pay-amount-label {
  margin-right: 8rpx;
  color: #7a8798;
  font-size: 24rpx;
}

.pay-amount-currency {
  color: #ff8200;
  font-size: 26rpx;
  font-weight: 700;
}

.pay-amount-value {
  margin-left: 2rpx;
  color: #ff8200;
  font-size: 44rpx;
  font-weight: 700;
  font-variant-numeric: tabular-nums;
}

.pay-button {
  flex: none;
  min-width: 320rpx;
  height: 88rpx;
  padding: 0 48rpx;
  box-sizing: border-box;
  border-radius: 999rpx;
  background: linear-gradient(180deg, #ffa11c 0%, #ff8200 100%);
  color: #ffffff;
  font-size: 32rpx;
  font-weight: 700;
  line-height: 88rpx;
  text-align: center;
  box-shadow: 0 8rpx 18rpx rgba(255, 130, 0, 0.24);
}

.pay-button:active {
  opacity: 0.9;
}

.pay-button-paid {
  background: rgba(34, 197, 94, 0.12);
  color: #1f9445;
  box-shadow: none;
}
