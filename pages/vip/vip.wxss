.title-box {
  z-index: 1;/*图层显示优先级*/
}

.vip-container {
  height: 100%;
  display: flex;
  flex-direction: column;/*主轴垂直 起点在上*/
  box-sizing: border-box;
  background-color: #eaf4ff;
} 

.head {
  position: fixed;
  width: 100%;
}

.item {
  border-radius: 30rpx;
  margin: 29rpx 30rpx 0;
  position: relative;
  background: white;
  padding-bottom: 40rpx;
  box-shadow: 0 0 20rpx 0 rgba(0, 0, 0, 0.06);
}

.vip-info-bg {
  border-radius: 30rpx;
  padding: 25rpx 0 44rpx;
  margin: 0 30rpx 44rpx;
  position: relative;
  box-shadow: 0 0 20rpx 0 rgba(0, 0, 0, 0.06);
  background: linear-gradient(135deg, #2c313b, #111318);
}

.vip-top {
  padding: 46rpx 0 0 38rpx;
  display: flex;
  flex-direction: row;
  align-items: baseline;
}

.center-row {
  margin-top: 58rpx;
  margin-left: 38rpx;
  margin-right: 32rpx;
  flex-direction: row;
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.vip-content {
  max-width: 450rpx;
  font-size: 40rpx;
  font-family: PingFang SC;
  font-weight: bold;
  color: #17324f;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.vip-money {
  max-width: 350rpx;
  font-size: 72rpx;
  font-weight: bold;
  font-family: OPPOSans;
  color: #F85A42;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.vip-content2 {
  width: 150rpx;
  font-size: 30rpx;
  font-family: PingFang SC;
  font-weight: 500;
  color: #17324f;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.tip {
  padding-bottom: 44rpx;
  margin-left: 32rpx;
  margin-top: 110rpx;
  position: relative;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  height: 30rpx;
  font-size: 30rpx;
  font-family: PingFang SC;
  font-weight: 500;
  color: #FFFFFF;
  line-height: 29rpx;
}

.vip-label {
  width: 93rpx;
  height: 81rpx;
  top: -10rpx;
  right: 15rpx;
  position: absolute;
}

.go-vip {
  width: 220rpx;
  background: #111318;
  font-size: 36rpx;
  font-family: PingFang SC;
  font-weight: 700;
  height: 90rpx;
  border-radius: 999rpx;
  color: #ffffff;
  line-height: 90rpx;
  text-align: center;
  box-shadow: 0 8rpx 18rpx rgba(17, 19, 24, 0.18);
}
