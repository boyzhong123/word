.listen-page {
  position: fixed;
  inset: 0;
  display: flex;
  flex-direction: column;
  background: linear-gradient(180deg, #e7f0e8 0%, #e9efe9 32%, #dbe7df 52%, #9fc0b6 74%, #6f99c0 100%);
  overflow: hidden;
}

/* ---------------- 导航 ---------------- */
.nav {
  position: relative;
  display: flex;
  align-items: center;
  box-sizing: content-box;
  padding-left: 20rpx;
  padding-right: 20rpx;
}
.nav-btn {
  width: 64rpx;
  height: 64rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 2;
}
.close-x {
  position: relative;
  width: 34rpx;
  height: 34rpx;
}
.close-x::before,
.close-x::after {
  content: '';
  position: absolute;
  top: 50%;
  left: 0;
  width: 100%;
  height: 3rpx;
  background: #4a5752;
  border-radius: 3rpx;
}
.close-x::before { transform: rotate(45deg); }
.close-x::after { transform: rotate(-45deg); }
.gear {
  font-size: 40rpx;
  color: #4a5752;
  line-height: 1;
}
.nav-title-wrap {
  position: absolute;
  left: 0;
  right: 0;
  top: 0;
  bottom: 0;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
}
.nav-title {
  font-size: 34rpx;
  font-weight: 600;
  color: #2f3a35;
  max-width: 60%;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}
.nav-dots {
  display: flex;
  align-items: center;
  margin-top: 12rpx;
}
.dot {
  width: 10rpx;
  height: 10rpx;
  border-radius: 10rpx;
  background: rgba(80, 110, 95, 0.35);
  margin: 0 6rpx;
  transition: all 0.25s;
}
.dot-active {
  width: 30rpx;
  background: #46c073;
}

/* ---------------- 主体 ---------------- */
.stage {
  flex: 1;
  width: 100%;
}
.cover-page {
  height: 100%;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
}
.cover-disc {
  width: 540rpx;
  height: 540rpx;
  border-radius: 50%;
  box-shadow: 0 24rpx 60rpx rgba(60, 90, 110, 0.28);
}
.spinning {
  animation: spin 16s linear infinite;
}
@keyframes spin {
  from { transform: rotate(0deg); }
  to { transform: rotate(360deg); }
}
.cover-hint {
  margin-top: 70rpx;
  font-size: 28rpx;
  color: #5d6e66;
  letter-spacing: 2rpx;
}

.lyrics {
  height: 100%;
  width: 100%;
  box-sizing: border-box;
  padding: 0 56rpx;
}
.lyrics-pad {
  height: 40rpx;
}
.lyric-item {
  padding: 26rpx 0;
  transition: all 0.2s;
}
.lyric-en {
  font-size: 40rpx;
  color: #51605a;
  line-height: 1.25;
  font-weight: 400;
}
.lyric-cn {
  margin-top: 8rpx;
  font-size: 36rpx;
  color: #51605a;
  line-height: 1.3;
}
.lyric-active .lyric-en {
  color: #1f8a47;
  font-weight: 700;
  font-size: 46rpx;
}
.lyric-active .lyric-cn {
  color: #2a6e44;
  font-weight: 600;
}

/* ---------------- 控制区 ---------------- */
.controls {
  padding: 0 40rpx;
}
.seek-row {
  display: flex;
  align-items: center;
}
.seek {
  flex: 1;
  margin: 0 12rpx 0 0;
}
.speed-badge {
  min-width: 72rpx;
  height: 44rpx;
  padding: 0 14rpx;
  border-radius: 24rpx;
  background: rgba(255, 255, 255, 0.7);
  color: #3f4b45;
  font-size: 24rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}
.time-row {
  display: flex;
  justify-content: space-between;
  margin-top: 2rpx;
  font-size: 22rpx;
  color: rgba(60, 75, 68, 0.7);
}

.buttons {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-top: 40rpx;
  padding: 0 6rpx;
}
.ctrl {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
}

/* 循环 */
.ctrl-loop {
  position: relative;
  width: 70rpx;
  height: 70rpx;
}
.loop-ring {
  font-size: 50rpx;
  color: #3f4b45;
  line-height: 1;
}
.loop-label {
  position: absolute;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -42%);
  font-size: 20rpx;
  font-weight: 700;
  color: #3f4b45;
}

/* 上一首 / 下一首 */
.icon-prev,
.icon-next {
  position: relative;
  width: 46rpx;
  height: 40rpx;
}
.icon-prev::before,
.icon-next::before {
  content: '';
  position: absolute;
  top: 0;
  width: 0;
  height: 0;
  border-top: 20rpx solid transparent;
  border-bottom: 20rpx solid transparent;
}
.icon-prev::after,
.icon-next::after {
  content: '';
  position: absolute;
  top: 0;
  width: 4rpx;
  height: 40rpx;
  background: #2f3a35;
  border-radius: 4rpx;
}
.icon-prev::before {
  left: 6rpx;
  border-right: 24rpx solid #2f3a35;
}
.icon-prev::after { left: 0; }
.icon-next::before {
  right: 6rpx;
  border-left: 24rpx solid #2f3a35;
}
.icon-next::after { right: 0; }

/* 播放 / 暂停 */
.ctrl-play {
  width: 132rpx;
  height: 132rpx;
  border: 3rpx solid #2f3a35;
  border-radius: 50%;
}
.icon-play {
  width: 0;
  height: 0;
  margin-left: 12rpx;
  border-top: 30rpx solid transparent;
  border-bottom: 30rpx solid transparent;
  border-left: 48rpx solid #2f3a35;
}
.icon-pause {
  display: flex;
}
.icon-pause .bar {
  width: 12rpx;
  height: 52rpx;
  background: #2f3a35;
  border-radius: 4rpx;
  margin: 0 7rpx;
}

/* 播放列表 */
.icon-list {
  width: 50rpx;
  height: 42rpx;
  display: flex;
  flex-direction: column;
  justify-content: space-between;
  padding: 4rpx 0;
  box-sizing: border-box;
}
.list-line {
  height: 4rpx;
  background: #2f3a35;
  border-radius: 4rpx;
}
.list-line:nth-child(1) { width: 100%; }
.list-line:nth-child(2) { width: 70%; }
.list-line:nth-child(3) { width: 100%; }

/* ---------------- 期切换面板 ---------------- */
.sheet-mask {
  position: fixed;
  inset: 0;
  background: rgba(0, 0, 0, 0);
  z-index: 50;
  visibility: hidden;
  transition: background 0.25s;
}
.sheet-show {
  visibility: visible;
  background: rgba(0, 0, 0, 0.4);
}
.sheet {
  position: absolute;
  left: 0;
  right: 0;
  bottom: 0;
  max-height: 70%;
  background: #f6f8f6;
  border-radius: 28rpx 28rpx 0 0;
  transform: translateY(100%);
  transition: transform 0.28s ease;
  display: flex;
  flex-direction: column;
}
.sheet-show .sheet {
  transform: translateY(0);
}
.sheet-head {
  display: flex;
  align-items: baseline;
  justify-content: space-between;
  padding: 34rpx 40rpx 20rpx;
}
.sheet-title {
  font-size: 34rpx;
  font-weight: 700;
  color: #2f3a35;
}
.sheet-count {
  font-size: 24rpx;
  color: #9aa6a0;
}
.sheet-list {
  flex: 1;
  max-height: 640rpx;
}
.sheet-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 28rpx 40rpx;
  border-top: 1rpx solid #eceeec;
}
.sheet-item-main {
  display: flex;
  flex-direction: column;
}
.sheet-item-name {
  font-size: 30rpx;
  color: #33403a;
}
.sheet-item-active .sheet-item-name {
  color: #1f8a47;
  font-weight: 700;
}
.sheet-item-sub {
  margin-top: 6rpx;
  font-size: 22rpx;
  color: #9aa6a0;
}
.sheet-vip {
  font-size: 22rpx;
  color: #c79a3a;
  background: #fbf2dc;
  padding: 4rpx 16rpx;
  border-radius: 20rpx;
}
.sheet-playing {
  font-size: 24rpx;
  color: #46c073;
}
.sheet-close {
  text-align: center;
  padding: 30rpx 0;
  font-size: 30rpx;
  color: #5d6e66;
  border-top: 1rpx solid #eceeec;
}

/* ---------------- 加载 ---------------- */
.loading {
  position: absolute;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
  display: flex;
}
.loading-dot {
  width: 16rpx;
  height: 16rpx;
  border-radius: 50%;
  background: #6f99c0;
  margin: 0 8rpx;
  animation: bounce 1s infinite ease-in-out;
}
.loading-dot:nth-child(2) { animation-delay: 0.15s; }
.loading-dot:nth-child(3) { animation-delay: 0.3s; }
@keyframes bounce {
  0%, 80%, 100% { transform: scale(0.6); opacity: 0.5; }
  40% { transform: scale(1); opacity: 1; }
}
