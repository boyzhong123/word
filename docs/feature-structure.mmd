%% Word 英语学习小程序 · 功能结构图（含已实现 + 待开发）
%% 图例：done=已实现 | partial=部分实现 | todo=待开发 | infra=基础设施

flowchart TB
    LEGEND["图例说明<br/>🟢 绿色=已实现且已接后端<br/>🟡 黄色=前端已有/部分实现<br/>🔴 红色=待开发占位<br/>🔵 蓝色=公共基础能力"]

    subgraph ENTRY["① 用户入口层"]
        WX["微信小程序启动"]
        TAB["自定义 TabBar<br/>学习 · 我的 · 迷你播放条"]
        WX --> TAB
    end

    subgraph HOME["② 学习首页 pages/home"]
        direction TB
        H1["词书卡片与切换 ✅"]
        H2["关卡地图 / 分类列表 ✅"]
        H3["今日任务与打卡进度 ⚠️本地"]
        H4["每关三任务入口 ✅"]
        H5["错词复习关 ⚠️Mock"]
        H6["小怪兽 PK 动效 ✅"]
        H1 --> H2 --> H4
        H2 --> H5
        H1 --> H3
    end

    subgraph LEARN["③ 核心学习流"]
        direction LR
        P_WORD["单词新学<br/>practice/word<br/>⚠️标记未上报"]
        P_RECITE["跟读背诵<br/>practice/recitation<br/>⚠️分数未上报"]
        L_QUIZ["听力小测<br/>listen/quiz ✅"]
        FINISH["关卡完成<br/>finish/today ✅"]
        P_WORD --> P_RECITE --> L_QUIZ --> FINISH
    end

    subgraph PRACTICE_EXT["③-A 背单词扩展"]
        P_DETAIL["单词详情 Tab ✅"]
        P_SEARCH["搜索查词 ✅"]
        P_CATALOGUE["关卡目录 ✅"]
        P_REVIEW["错词复习模式 ⚠️Mock"]
    end

    subgraph LISTEN_EXT["③-B 随身听扩展"]
        L_PLAYER["黑胶播放器 ✅"]
        L_FOLLOW["课文跟读评测 ✅"]
        L_MINI["跨页迷你播放条 ✅"]
        L_WRONG["错词本地暂存 ⚠️"]
    end

    subgraph COMMERCE["④ 商品与购买（重点待完善）"]
        direction TB
        AD_SUMMARY["教材商品摘要 ✅ UI"]
        AD_PACKAGES["套餐选择<br/>学习卡 / 词典 ⚠️本地配置"]
