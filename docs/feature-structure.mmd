        S_BASE["基础 path 分享 ⚠️practice/ad"]
        S_CARD["分享卡片 title+imageUrl ❌"]
        S_REPORT["报告成绩分享 ❌"]
        S_CHECKIN["打卡天数分享 ❌"]
        S_HOME["首页关卡分享 ❌"]
        S_TIMELINE["朋友圈分享 ❌"]
        S_INVITE["邀请好友/归因奖励 ❌"]
