        T3["单词标记 word-mark"]
        T4["跟读成绩 recitation-score"]
        T5["商品列表 book-product-list"]
        T6["下单支付 order + 回调"]
        T7["订单查询/会员状态"]
        T8["学习计划 study-plan"]
        T9["打卡写入/奖励核销"]
        T10["分享归因 share-track"]
        T11["头像上传 upload-avatar"]
    end

    TAB -->|学习 Tab| HOME
