    subgraph SUPPORT["⑦ 辅助功能页"]
        PLAN["学习计划 plan ⚠️仅本地"]
        CHECKIN["打卡日历 checkin ⚠️混合数据"]
        REPORT["学习报告 report ❌Mock"]
        INDEX["遗留页 index ❌未接入"]
    end

    subgraph INFRA["⑧ 公共基础层"]
        API["utils/api.js"]
        LOGIN["utils/login.js"]
        CHIVOX["Chivox 语音评测"]
        PLAYER["utils/player.js"]
        COMP["公共组件库"]
    end

    subgraph API_DONE["⑨ 已接后端接口"]
        B1["login · user/info · user-books"]
        B2["book-units · unit-resources"]
        B3["save-record · search · word-info"]
        B4["listening-quiz-result"]
    end

    subgraph API_TODO["⑩ 待开发后端接口"]
        T1["错词复习 review-words"]
