        M_HISTORY["学习记录/报告历史 ❌"]
        M_PLAN_SYNC["学习计划云端同步 ❌"]
        M_NOTIFY["消息中心/系统通知 ❌"]
        M_FEEDBACK["意见反馈 ❌"]
        M_ABOUT["关于我们/版本说明 ❌"]
        M_LOGOUT["退出登录 ❌"]
        M_CHILD["家长绑定/学情 ❌"]
